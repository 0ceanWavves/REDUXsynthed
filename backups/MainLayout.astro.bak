---
// Get layout properties
const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Coverage tracking script -->
    <script is:inline src="http://localhost:3001/instrumented/public/js/coverage-client.js"></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    
    <title>{title || "Synthed"}</title>
    <meta name="description" content={description || "Transforming ideas into digital solutions"} />
    
    <!-- Lockdown Fix - MUST be the very first script for SES/lockdown environments -->
    <script is:inline src="http://localhost:3001/instrumented/public/js/lockdown-fix.js"></script>
    
    <!-- Emergency Shader Fix - Directly patches WebGL for shader issues -->
    <script is:inline src="http://localhost:3001/instrumented/public/js/emergency-shader-fix.js"></script>
    
    <!-- Centralized THREE.js loader must be first -->
    <!-- <script is:inline src="http://localhost:3001/instrumented/public/js/three-loader.js"></script> -->
    
    <!-- Module fixers and loaders -->
    <script is:inline src="http://localhost:3001/instrumented/public/js/module-loader.js"></script>
    
    <!-- Load our hero layout fix -->
    <link rel="stylesheet" href="/css/hero-layout-fix.css">
    <script is:inline src="http://localhost:3001/instrumented/public/js/fix-hero-layout.js"></script>
    
    <!-- Use system fonts instead of custom fonts -->
    <link rel="stylesheet" href="/fonts/system-fonts.css">
    
    <!-- Debug controls fix - hide debug UI -->
    <link rel="stylesheet" href="../styles/debug-fix.css">
    
    <!-- Process section fix - ensure proper styling -->
    <link rel="stylesheet" href="../styles/process-fix.css">
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" type="image/png" href="/favicon.png">
    
    <!-- Local styles -->
    <slot name="head" />
    
    <!-- Add base CSS for system fonts -->
    <style>
      /* Disable custom fonts and use system fonts only */
      html, body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
      }
    </style>
  </head>
  <body>
    <slot />
    
    <!-- Script to ensure 3D content is visible and properly positioned -->
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        // Fix z-index of text elements vs 3D canvas
        const textElements = document.querySelectorAll('.title-word, .title-shadow, h1, h2, h3, h4, h5, h6, p, .splash-title, .splash-content');
        textElements.forEach(element => {
          if (element) {
            // Use type assertion for TypeScript
            (element as HTMLElement).style.position = 'relative';
            (element as HTMLElement).style.zIndex = '100';
          }
        });
        
        // Ensure canvas is visible and at correct z-index
        const morphCanvas = document.getElementById('morphing-poly-canvas');
        if (morphCanvas) {
          morphCanvas.style.zIndex = '5';
          morphCanvas.style.opacity = '1';
          morphCanvas.style.visibility = 'visible';
        }
        
        // Hide any debug UI elements
        const hideDebugElements = () => {
          // Find elements that contain debug info text
          document.querySelectorAll('div, span, p').forEach(el => {
            if (
              el.textContent && (
                el.textContent.includes('Hold SHIFT') ||
                el.textContent.includes('Z-axis') ||
                el.textContent.includes('Desktop:') ||
                el.textContent.includes('Mouse:') ||
                el.textContent.includes('Touch:')
              )
            ) {
              (el as HTMLElement).style.display = 'none';
              (el as HTMLElement).style.visibility = 'hidden';
              (el as HTMLElement).style.opacity = '0';
            }
          });
        };
        
        // Run immediately and after a delay to catch dynamically added elements
        hideDebugElements();
        setTimeout(hideDebugElements, 500);
        setTimeout(hideDebugElements, 1500);
      });
    </script>
  </body>
</html>
