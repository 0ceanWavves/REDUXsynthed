---
// Get layout properties
const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Basic meta tags -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    
    <title>Synthed</title>
    <meta name="description" content={description || "Transforming ideas into digital solutions"} />
    
    <!-- Force-enable WebGL and add proper content type -->
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    
    <!-- Content Security Policy (CSP) for Three.js and GSAP -->
    <meta http-equiv="Content-Security-Policy" content="
      default-src 'self';
      script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https://cdn.jsdelivr.net https://unpkg.com https://static.cloudflareinsights.com;
      style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;
      font-src 'self' 'unsafe-inline' data: https://fonts.googleapis.com https://fonts.gstatic.com https://*.synthed.xyz;
      img-src 'self' data: blob: https://*.synthed.xyz;
      connect-src 'self' https://cdn.jsdelivr.net https://unpkg.com https://*.synthed.xyz;
      worker-src 'self' blob:;
      frame-src 'self';
    ">
    
    <!-- Import map for bare module specifiers -->
    <script type="importmap">
      {
        "imports": {
          "three": "https://cdn.jsdelivr.net/npm/three@0.154.0/build/three.module.js"
        }
      }
    </script>
    
    <!-- Preload Three.js to improve loading time -->
    <link rel="modulepreload" href="https://cdn.jsdelivr.net/npm/three@0.154.0/build/three.module.js" as="script" fetchpriority="high" crossorigin="anonymous" />
    
    <!-- Load local GSAP library -->
    <script is:inline src="/gsap.min.js"></script>
    
    <!-- Lockdown Fix -->
    <script is:inline src="/js/lockdown-fix.js"></script>
    
    <!-- Emergency Shader Fix -->
    <script is:inline src="/js/emergency-shader-fix.js"></script>
    
    <!-- Standalone shader fix -->
    <script is:inline src="/js/shader-fix-standalone.js"></script>
    
    <!-- CSS Files -->
    <link rel="stylesheet" href="/css/hero-layout-fix.css">
    <link rel="stylesheet" href="/css/debug-fix.css">
    <link rel="stylesheet" href="/css/process-fix.css">
    <link rel="stylesheet" href="/css/loading-indicator.css">
    
    <!-- Load our hero layout fix -->
    <script is:inline src="/js/fix-hero-layout.js"></script>
    
    <!-- Use system fonts instead of custom fonts -->
    <link rel="stylesheet" href="/fonts/system-fonts.css">
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    
    <!-- Early Three.js script - Make it available before everything else -->
    <script is:inline>
      // Create a temporary THREE placeholder to prevent errors
      if (!window.THREE) {
        console.log("Setting up THREE placeholder until library loads");
        window.THREE = {
          Vector3: function() { return {x: 0, y: 0, z: 0}; },
          Color: function() { return {r: 0, g: 0, b: 0}; },
          Texture: function() { return {}; },
          __isPlaceholder: true
        };
      }
      
      // Detect mobile devices
      window.isMobileDevice = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) 
        || (window.innerWidth < 768);
      
      // Firefox WebGL helper
      window.__FIREFOX_WEBGL2_HELPER = function(canvas) {
        try {
          if (navigator.userAgent.toLowerCase().indexOf('firefox') > -1) {
            return canvas.getContext('webgl2', {
              alpha: true,
              antialias: false,
              depth: true,
              failIfMajorPerformanceCaveat: false,
              powerPreference: 'high-performance'
            });
          }
        } catch (e) {
          console.warn("Firefox WebGL2 helper failed:", e);
        }
        return null;
      };
    </script>
    
    <!-- CSS Variables -->
    <style is:inline>
      :root {
        --color-primary: #06b6d4;
        --color-primary-rgb: 6, 182, 212;
        --color-text: #ffffff;
        --color-offset: #94a3b8;
        --color-background: #0f172a;
      }
      
      /* Add global styles for consistency */
      body {
        background-color: var(--color-background);
        color: var(--color-text);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
      }
      
      .text-primary {
        color: var(--color-primary);
      }
      
      .text-offset {
        color: var(--color-offset);
      }
      
      /* Canvas styles */
      #morphing-poly-canvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        display: block;
      }
      
      .content-wrapper {
        position: relative;
        z-index: 10;
      }
    </style>
    
    <!-- Local styles -->
    <slot name="head" />
  </head>
  <body>
    <!-- Canvas for 3D visualization -->
    
    <!-- Firefox WebGL fallback container -->
    
    <!-- Loading indicator -->
    
    
    <!-- Main content wrapper for proper z-index layering -->
    <main class="w-full h-full flex flex-col relative">
      <slot />
    </main>
    
    <!-- Remove debug UI -->
    <script is:inline src="/js/remove-gooey-menu.js"></script>
    <script is:inline src="/js/remove-debug-ui.js"></script>
    
    <!-- Script to ensure 3D content is visible and properly positioned -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        // Fix z-index of text elements vs 3D canvas
        const textElements = document.querySelectorAll('.title-word, .title-shadow, h1, h2, h3, h4, h5, h6, p, .splash-title, .splash-content');
        textElements.forEach(element => {
          if (element) {
            element.style.position = 'relative';
            element.style.zIndex = '100';
          }
        });
        
        // Ensure canvas is visible and at correct z-index
        const morphCanvas = document.getElementById('morphing-poly-canvas');
        if (morphCanvas) {
          morphCanvas.style.zIndex = '5';
          morphCanvas.style.opacity = '1';
          morphCanvas.style.visibility = 'visible';
        }
        
        // Hide any debug UI elements
        const hideDebugElements = () => {
          // Find elements that contain debug info text
          document.querySelectorAll('div, span, p').forEach(el => {
            if (
              el.textContent && (
                el.textContent.includes('Hold SHIFT') ||
                el.textContent.includes('Z-axis') ||
                el.textContent.includes('Desktop:') ||
                el.textContent.includes('Mouse:') ||
                el.textContent.includes('Touch:')
              )
            ) {
              el.style.display = 'none';
              el.style.visibility = 'hidden';
              el.style.opacity = '0';
            }
          });
        };
        
        // Run immediately and after a delay to catch dynamically added elements
        hideDebugElements();
        setTimeout(hideDebugElements, 500);
        setTimeout(hideDebugElements, 1500);
      });
    </script>
    
    <!-- Load Three.js visualization after DOM is ready -->
    
  </body>
</html>
