---
import "@fontsource-variable/inter";
import MainLayout from '~/layouts/MainLayout.astro';
// import HeroSection from '~/components/HeroSection.astro'; // Commented out old hero
import Features from '~/components/features.astro';
import Process from '~/components/process.astro'; // Uncommented for debugging
// import Projects from '~/components/projects.astro'; // Commented out for debugging
import SectionDivider from '~/components/SectionDivider.astro';
// import AmorphousPrism from '~/components/AmorphousPrism.astro'; // Now imported within HeroSectionRebuild
import HeroSectionRebuild from '~/components/rebuild/HeroSectionRebuild.astro'; // Corrected path

// Define meta data for this specific page
const title = "Synthed - Custom Software & Application Development";
const description = "Transform your ideas into reality with Synthed. We specialize in custom application development, modern web solutions, and strategic technology consulting tailored to your business needs.";
const image = "/social.jpg"; // Path relative to public folder

// REMOVED section mapping for debugging
// const sections = [
//   { id: 'features-section', component: Features },
//   { id: 'process-section', component: Process },
//   { id: 'projects-section', component: Projects },
//   // Add contact section if it becomes a component
//   // { id: 'contact-section', component: Contact }
// ];
---

<MainLayout title={title} description={description} image={image}>

  <!-- Commented out AmorphousPrism call as it's handled within HeroSectionRebuild -->
  <!-- <AmorphousPrism /> -->

  <!-- Hero section -->
  <!-- <HeroSection /> --> <!-- Commented out old hero -->
  <HeroSectionRebuild /> <!-- Use the rebuilt hero -->

  <!-- Main content wrapper -->
  <div class="relative z-30 px-4 md:px-8 py-4 md:py-8 mx-auto w-full content-wrapper"
       style="margin-top: 0; margin-bottom: 0; max-width: none !important; position: relative; z-index: 30;">

    <!-- Features section -->
    <div class="section-wrapper" id="features-section" style="display:block; visibility:visible; opacity:1; z-index:30;">
      <Features />
    </div>
    
    <SectionDivider />
    
    <!-- Process section -->
    <div class="section-wrapper" id="process-section" style="display:block; visibility:visible; opacity:1; z-index:30;">
      <Process />
    </div>
    
    <!-- REMOVED dynamic section rendering for debugging -->
    {/* {sections.map((section, index) => (
      <>
        <div class="section-wrapper" id={section.id}>
          <section.component />
        </div>
        {/* Add a divider after each section except the last one */}
        {/* {index < sections.length - 1 && <SectionDivider />} */}
      </>
    ))} */}

  </div>

</MainLayout>

<!-- Remove GooeyMenu - must load before any other scripts -->
<script is:inline src="/js/remove-gooey-menu.js"></script>

<!-- Remove Debug UI - Load after GooeyMenu removal -->
<script is:inline src="/js/remove-debug-ui.js"></script>

<!-- Standalone shader fix -->
<script is:inline src="/js/shader-fix-standalone.js"></script>

<!-- Import our custom animation scripts -->
<script src="../scripts/letter-animation.js"></script>
<script src="../scripts/digital-text-effects.js"></script>

<!-- Import the page-specific JavaScript -->
<script src="../scripts/index-page.js"></script>

<!-- Script to ensure sections are visible -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    // Force display of sections below hero after everything has loaded
    setTimeout(function() {
      const sections = document.querySelectorAll('.section-wrapper');
      sections.forEach(section => {
        section.style.display = 'block';
        section.style.visibility = 'visible';
        section.style.opacity = '1';
        section.style.zIndex = '30';
        section.style.position = 'relative';
      });
      
      // Ensure the content wrapper is properly positioned
      const contentWrapper = document.querySelector('.content-wrapper');
      if (contentWrapper) {
        contentWrapper.style.position = 'relative';
        contentWrapper.style.zIndex = '30';
        contentWrapper.style.display = 'block';
        contentWrapper.style.visibility = 'visible';
      }
    }, 1000);
  });
</script>

<!--
  Removed from here and moved to respective components/files:
  - <!doctype html>, <html>, <head>, <body> tags -> MainLayout.astro
  - Meta tags, links, theme script, browser detection -> CommonHead.astro
  - <nav> element and its JS -> Navigation.astro
  - Wave container, gradient, overlay divs and styles -> BackgroundDecorations.astro
  - Large <style> block -> index-page.css (imported by MainLayout)
  - Large <script> block -> index-page.js (imported above)
  - LoadingScreen -> MainLayout.astro
  - Footer -> MainLayout.astro
  - Cursor glow div -> MainLayout.astro
-->

<style is:global>
  /* Ensure content below hero is visible */
  .section-wrapper {
    position: relative;
    z-index: 30;
    display: block;
    visibility: visible;
    opacity: 1;
    background-color: rgba(15, 23, 42, 0.9);
    padding: 2rem 0;
    margin-bottom: 2rem;
  }
  
  /* Add background to ensure content is visible */
  .content-wrapper {
    position: relative;
    z-index: 30;
    background-color: rgba(15, 23, 42, 0.95);
    min-height: 100vh;
  }
  
  /* Make sure dividers are visible */
  .section-divider {
    position: relative;
    z-index: 31;
    height: 4px;
    margin: 3rem 0;
    background: linear-gradient(90deg, transparent, rgba(120, 70, 255, 0.6), transparent);
  }
</style>
