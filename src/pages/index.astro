---
import "@fontsource-variable/inter";
import Features from "~/components/features.astro";
import Footer from "~/components/footer.astro";
import Header from "~/components/header.astro";
import Intro from "~/components/intro.astro";
import Process from "~/components/process.astro";
import Projects from "~/components/projects.astro";
import Splash from "~/components/splash.astro";
import "~/styles/index.css";

const { generator, site } = Astro;
const image = new URL("social.jpg", site);
const description =
  "Transform your ideas into reality with Synthed. We specialize in custom application development, modern web solutions, and strategic technology consulting tailored to your business needs.";
---

<!doctype html>
<html lang="en" class="h-full motion-safe:scroll-smooth" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={generator} />

    <title>Synthed - Custom Software & Application Development</title>
    <meta name="description" content={description} />

    <!-- social media -->
    <meta property="og:title" content="Synthed - Custom Software & Application Development" />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={site} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- initialize theme -->
    <script is:inline>
      const themeSaved = localStorage.getItem("theme");

      if (themeSaved) {
        document.documentElement.dataset.theme = themeSaved;
      } else {
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        document.documentElement.dataset.theme = prefersDark ? "dark" : "light";
      }

      window
        .matchMedia("(prefers-color-scheme: dark)")
        .addEventListener("change", (event) => {
          if (!localStorage.getItem("theme")) {
            document.documentElement.dataset.theme = event.matches
              ? "dark"
              : "light";
          }
        });
    </script>
  </head>
  <body
    class="h-full overflow-x-hidden bg-default text-default text-base selection:bg-secondary selection:text-white"
  >
    <Header />
    <Splash />
    <div class="relative">
      <canvas id="wave-canvas" class="fixed top-0 left-0 w-full h-full -z-10 opacity-20"></canvas>
      <div class="relative space-y-24 px-8 py-32">
        <Intro />
        <Features />
        <Process />
        <Projects />
      </div>
      <Footer />
    </div>
    
    <!-- Cursor effect -->
    <div id="cursor-glow" class="hidden md:block"></div>
  </body>
</html>

<style>
  /* Custom cursor effect */
  #cursor-glow {
    position: fixed;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(96, 165, 250, 0.3) 0%, rgba(96, 165, 250, 0) 70%);
    pointer-events: none;
    z-index: 9999;
    opacity: 0;
    transition: opacity 0.3s ease;
    mix-blend-mode: screen;
  }
</style>

<script>
  class Wave {
    constructor(
      private readonly canvas: HTMLCanvasElement,
      private readonly ctx: CanvasRenderingContext2D,
      private readonly width: number,
      private readonly height: number,
      private readonly frequency: number = 0.005,
      private readonly amplitude: number = 30,
      private readonly speed: number = 0.01,
      private phase: number = 0
    ) {}

    draw() {
      this.ctx.beginPath();
      
      // Create multiple waves
      for (let i = 0; i < 3; i++) {
        this.ctx.moveTo(0, this.height / 2);
        
        for (let x = 0; x < this.width; x++) {
          const y =
            this.height / 2 +
            Math.sin(x * this.frequency + this.phase + i * Math.PI * 0.5) * 
            this.amplitude * (1 - i * 0.2);
          
          if (i === 0) {
            this.ctx.moveTo(x, y);
          } else {
            this.ctx.lineTo(x, y);
          }
        }
      }

      this.ctx.lineTo(this.width, this.height);
      this.ctx.lineTo(0, this.height);
      this.ctx.closePath();

      const gradient = this.ctx.createLinearGradient(
        0,
        0,
        this.width,
        this.height
      );
      gradient.addColorStop(0, "rgba(96, 165, 250, 0.1)"); // blue-400
      gradient.addColorStop(1, "rgba(74, 222, 128, 0.1)"); // green-400

      this.ctx.fillStyle = gradient;
      this.ctx.fill();
    }

    update() {
      this.phase += this.speed;
      this.ctx.clearRect(0, 0, this.width, this.height);
      this.draw();
    }
  }

  // Helper function to throttle function calls
  function throttle(func, limit) {
    let inThrottle;
    return function() {
      const args = arguments;
      const context = this;
      if (!inThrottle) {
        func.apply(context, args);
        inThrottle = true;
        setTimeout(() => inThrottle = false, limit);
      }
    };
  }

  // Initialize wave animation
  function initWaveAnimation() {
    const canvas = document.getElementById("wave-canvas") as HTMLCanvasElement;
    const ctx = canvas.getContext("2d");

    if (canvas && ctx) {
      const resizeCanvas = () => {
        canvas.width = window.innerWidth;
        canvas.height = Math.max(
          window.innerHeight,
          document.documentElement.scrollHeight
        );
      };

      resizeCanvas();
      window.addEventListener("resize", throttle(resizeCanvas, 200));

      const wave = new Wave(canvas, ctx, canvas.width, canvas.height);
      
      const animate = () => {
        wave.update();
        requestAnimationFrame(animate);
      };

      animate();
    }
  }
  
  // Custom cursor glow effect
  function initCursorGlow() {
    const cursorGlow = document.getElementById('cursor-glow');
    if (!cursorGlow) return;
    
    let isVisible = false;
    
    // Show the cursor glow when mouse moves
    document.addEventListener('mousemove', (e) => {
      if (!isVisible) {
        cursorGlow.style.opacity = '1';
        isVisible = true;
      }
      
      // Position the glow at the cursor with a slight delay for smooth effect
      cursorGlow.style.transform = `translate(${e.clientX - 25}px, ${e.clientY - 25}px)`;
    });
    
    // Change glow color/size based on elements hovered
    const interactiveElements = document.querySelectorAll('a, button, .service-card, .process-icon, .project-card');
    
    interactiveElements.forEach(el => {
      el.addEventListener('mouseenter', () => {
        cursorGlow.style.width = '80px';
        cursorGlow.style.height = '80px';
        cursorGlow.style.background = 'radial-gradient(circle, rgba(96, 165, 250, 0.4) 0%, rgba(96, 165, 250, 0) 70%)';
      });
      
      el.addEventListener('mouseleave', () => {
        cursorGlow.style.width = '50px';
        cursorGlow.style.height = '50px';
        cursorGlow.style.background = 'radial-gradient(circle, rgba(96, 165, 250, 0.3) 0%, rgba(96, 165, 250, 0) 70%)';
      });
    });
  }
  
  // Parallax scrolling effect
  function initParallaxEffect() {
    const parallaxElements = document.querySelectorAll('.intro-icon, .process-line');
    
    window.addEventListener('scroll', throttle(() => {
      const scrolled = window.scrollY;
      
      parallaxElements.forEach(el => {
        const element = el as HTMLElement;
        const speed = 0.15; // Adjust for more or less parallax effect
        
        if (element.classList.contains('intro-icon')) {
          element.style.transform = `translateY(${scrolled * speed}px)`;
        } else if (element.classList.contains('process-line')) {
          element.style.height = `${Math.min(100, scrolled * 0.1)}%`;
        }
      });
    }, 10));
  }
  
  // Prefers-reduced-motion check
  function shouldReduceMotion() {
    return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Initialize basic animations
    initWaveAnimation();
    
    // Only add the fancier effects if the user doesn't prefer reduced motion
    if (!shouldReduceMotion()) {
      initCursorGlow();
      initParallaxEffect();
      
      // Add extra interactive effects
      document.addEventListener('mousemove', (e) => {
        // Calculate the mouse position as a percentage of the window
        const mouseX = e.clientX / window.innerWidth;
        const mouseY = e.clientY / window.innerHeight;
        
        // Subtle movement of background elements based on mouse position
        document.documentElement.style.setProperty('--mouse-x', mouseX.toString());
        document.documentElement.style.setProperty('--mouse-y', mouseY.toString());
      });
    }
  });
</script>
