---
import "@fontsource-variable/inter";
import Features from "~/components/features.astro";
import Footer from "~/components/footer.astro";
import Intro from "~/components/intro.astro";
import Process from "~/components/process.astro";
import Projects from "~/components/projects.astro";
import Splash from "~/components/splash.astro";
import AmorphousPrism from "~/components/AmorphousPrism.astro";
import FlowBackground from "~/components/FlowBackground.astro";
import "~/styles/index.css";

const { generator, site } = Astro;
const image = new URL("social.jpg", site);
const description =
  "Transform your ideas into reality with Synthed. We specialize in custom application development, modern web solutions, and strategic technology consulting tailored to your business needs.";
---

<!doctype html>
<html lang="en" class="h-full motion-safe:scroll-smooth" data-theme="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/synthedlogo.svg" type="image/svg+xml" />
		<meta name="generator" content={generator} />

    <title>Synthed - Custom Software & Application Development</title>
    <meta name="description" content={description} />
		
		<!-- social media -->
		<meta property="og:title" content="Synthed - Custom Software & Application Development" />
		<meta property="og:type" content="website" />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:url" content={site} />
		<meta name="twitter:card" content="summary_large_image" />
		
		<!-- initialize theme -->
		<script is:inline>
			const themeSaved = localStorage.getItem("theme");

			if (themeSaved) {
				document.documentElement.dataset.theme = themeSaved;
			} else {
				const prefersDark = window.matchMedia(
					"(prefers-color-scheme: dark)",
				).matches;
				document.documentElement.dataset.theme = prefersDark ? "dark" : "light";
			}

			window
				.matchMedia("(prefers-color-scheme: dark)")
				.addEventListener("change", (event) => {
					if (!localStorage.getItem("theme")) {
						document.documentElement.dataset.theme = event.matches
							? "dark"
							: "light";
					}
				});
		</script>
	</head>
  <body
    class="h-full overflow-x-hidden bg-default text-default text-base selection:bg-secondary selection:text-white"
  >
    <!-- Remove wave canvas as it's causing visual clashes -->
    <!-- <canvas id="wave-canvas" class="fixed top-0 left-0 w-full h-full -z-20 opacity-60 transition-opacity duration-700" style="display: block;"></canvas> -->

    <!-- Flow background to provide liquid texture around the prism -->
    <FlowBackground />
    
    <!-- Navigation initially at bottom, moves to top on scroll -->
    <nav id="main-nav" class="fixed bottom-0 left-0 w-full z-50 bg-black/70 backdrop-blur-md py-4 px-6 transition-all duration-500">
      <div class="max-w-screen-xl mx-auto flex justify-between items-center">
        <a href="/" class="text-xl font-bold text-white">Synthed</a>
        <div class="flex items-center gap-6">
          <a href="#features" class="text-sm text-white hover:text-blue-300 transition-colors">Services</a>
          <a href="#projects" class="text-sm text-white hover:text-blue-300 transition-colors">Projects</a>
          <a href="#contact" class="text-sm text-white hover:text-blue-300 transition-colors">Contact</a>
        </div>
      </div>
    </nav>
    
    <!-- Hero section with prism positioned at top - eliminate empty space -->
    <div class="relative min-h-screen">
      <!-- Amorphous prism moved up to top of viewport -->
      <div id="prism-background" class="absolute top-0 left-0 w-full h-screen pointer-events-auto" style="z-index: 15; transform: translateZ(0); will-change: transform;">
        <AmorphousPrism />
      </div>
      
      <!-- Splash content with higher z-index to appear over prism -->
      <div class="relative z-30" style="transform: translateZ(0.1px);">
        <Splash />
      </div>
    </div>
    
    <!-- Main content with higher z-index to appear above backgrounds -->
    <div class="relative z-40 space-y-24 px-8 py-16 mt-12 bg-black/50 backdrop-blur-sm">
      <Features />
      <Process />
      <Projects />
    </div>
    <Footer />
    
    <!-- Cursor effect only on desktop -->
    <div id="cursor-glow" class="hidden md:block"></div>

<style>
  /* Custom cursor effect */
  #cursor-glow {
    position: fixed;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(129, 98, 255, 0.3) 0%, rgba(129, 98, 255, 0) 70%);
    pointer-events: none;
    z-index: 9999;
    opacity: 0;
    transition: opacity 0.3s ease;
    mix-blend-mode: screen;
    will-change: transform, opacity;
  }
  
  @media (prefers-reduced-motion: reduce) {
    #cursor-glow {
      display: none;
    }
    
    /* Remove reference to wave-canvas since we removed it */
    /*
    #wave-canvas {
      display: none;
    }
    */
    
    #prism-background {
      display: none !important;
    }
    
    #flow-bg-canvas {
      display: none !important;
    }
  }

  /* Chrome-specific fixes */
  @media screen and (-webkit-min-device-pixel-ratio: 0) and (min-resolution: 0.001dpcm) {
    .chrome-fix {
      /* Force text to be on top with proper compositing */
      transform: translateZ(0.5px) !important;
      filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5));
    }
  }
</style>

<script>
  // Initialize for all devices
  const isMobile = window.innerWidth < 768;
  
  // Handle initial setup on page load
  document.addEventListener('DOMContentLoaded', () => {
    console.log('DOM Content Loaded');
    
    // Check and log the visibility status of both elements
    const waveCanvas = document.getElementById('wave-canvas') as HTMLCanvasElement;
    const prismBackground = document.getElementById('prism-background');
    
    // Remove wave canvas initialization since we've disabled it
    /* 
    if (waveCanvas) {
      console.log('Wave canvas found, initializing');
      console.log('Wave canvas visibility:', window.getComputedStyle(waveCanvas).visibility);
      console.log('Wave canvas display:', window.getComputedStyle(waveCanvas).display);
      console.log('Wave canvas opacity:', window.getComputedStyle(waveCanvas).opacity);
      
      // Make sure canvas is properly sized and visible
      waveCanvas.width = window.innerWidth;
      waveCanvas.height = window.innerHeight;
      waveCanvas.style.display = 'block';
      
      const wave = new Wave(waveCanvas);
      requestAnimationFrame(wave.animate);
    } else {
      console.error('Wave canvas element not found during initialization!');
    }
    */
    
    if (prismBackground) {
      console.log('Prism background found');
      console.log('Prism background visibility:', window.getComputedStyle(prismBackground).visibility);
      console.log('Prism background display:', window.getComputedStyle(prismBackground).display);
    } else {
      console.error('Prism background element not found!');
    }
    
    // Init cursor effect (desktop only)
    if (!isMobile) {
      const cursorGlow = document.getElementById('cursor-glow');
      if (!cursorGlow) return;
      
      cursorGlow.style.opacity = '1';
      
      document.addEventListener('mousemove', (e) => {
        requestAnimationFrame(() => {
          cursorGlow.style.transform = `translate(${e.clientX - 25}px, ${e.clientY - 25}px)`;
        });
      });
    }
    
    // Handle navbar scrolling behavior
    handleNavbarScroll();

    // Browser detection for cross-browser optimizations
    const isFirefox = navigator.userAgent.toLowerCase().indexOf('firefox') > -1;
    const isChrome = navigator.userAgent.toLowerCase().indexOf('chrome') > -1 && 
                    navigator.userAgent.toLowerCase().indexOf('edge') === -1;
    
    // Fix text visibility issues in Chrome
    if (isChrome) {
      // Force repaint to ensure text renders properly
      setTimeout(() => {
        const splash = document.querySelector('.splash-title');
        if (splash) {
          // Slightly nudge the element to force a repaint
          splash.classList.add('chrome-fix');
        }
      }, 500);
    }
    
    // Optimize rendering in Firefox
    if (isFirefox) {
      // Reduce animation complexity for better performance
      if (prismBackground) {
        prismBackground.style.willChange = 'auto'; // Disable will-change optimization which can be expensive
      }
    }
  });
  
  // Navbar scroll behavior
  function handleNavbarScroll() {
    const navbar = document.getElementById('main-nav');
    if (!navbar) return;
    
    let lastScrollTop = 0;
    const scrollThreshold = window.innerHeight * 0.7; // 70% of viewport height
    
    window.addEventListener('scroll', () => {
      const scrollTop = window.scrollY;
      
      // If we've scrolled down past threshold, move navbar to top
      if (scrollTop > scrollThreshold) {
        navbar.classList.remove('bottom-0');
        navbar.classList.add('top-0');
      } 
      // If we're near the top of the page, move navbar to bottom
      else if (scrollTop < 50) {
        navbar.classList.remove('top-0');
        navbar.classList.add('bottom-0');
      }
      
      lastScrollTop = scrollTop;
    });
  }
</script>
