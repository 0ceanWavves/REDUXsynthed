---
import "@fontsource-variable/inter";
import Features from "~/components/features.astro";
import Footer from "~/components/footer.astro";
import Header from "~/components/header.astro";
import Intro from "~/components/intro.astro";
import Process from "~/components/process.astro";
import Projects from "~/components/projects.astro";
import Splash from "~/components/splash.astro";
import "~/styles/index.css";

const { generator, site } = Astro;
const image = new URL("social.jpg", site);
const description =
  "Transform your ideas into reality with Synthed. We specialize in custom application development, modern web solutions, and strategic technology consulting tailored to your business needs.";
---

<!doctype html>
<html lang="en" class="h-full motion-safe:scroll-smooth" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={generator} />

    <title>Synthed - Custom Software & Application Development</title>
    <meta name="description" content={description} />

    <!-- social media -->
    <meta property="og:title" content="Synthed - Custom Software & Application Development" />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={site} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- initialize theme -->
    <script is:inline>
      const themeSaved = localStorage.getItem("theme");

      if (themeSaved) {
        document.documentElement.dataset.theme = themeSaved;
      } else {
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        document.documentElement.dataset.theme = prefersDark ? "dark" : "light";
      }

      window
        .matchMedia("(prefers-color-scheme: dark)")
        .addEventListener("change", (event) => {
          if (!localStorage.getItem("theme")) {
            document.documentElement.dataset.theme = event.matches
              ? "dark"
              : "light";
          }
        });
    </script>
  </head>
  <body
    class="h-full overflow-x-hidden bg-default text-default text-base selection:bg-secondary selection:text-white"
  >
    <Header />
    <Splash />
    <div class="relative">
      <!-- Wave canvas only shown on desktop -->
      <canvas id="wave-canvas" class="fixed top-0 left-0 w-full h-full -z-10 opacity-30 hidden md:block"></canvas>
      <div class="relative space-y-24 px-8 py-32">
        <Intro />
        <Features />
        <Process />
        <Projects />
      </div>
      <Footer />
    </div>
    
    <!-- Cursor effect only on desktop -->
    <div id="cursor-glow" class="hidden md:block"></div>
  </body>
</html>

<style>
  /* Custom cursor effect */
  #cursor-glow {
    position: fixed;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(96, 165, 250, 0.3) 0%, rgba(96, 165, 250, 0) 70%);
    pointer-events: none;
    z-index: 9999;
    opacity: 0;
    transition: opacity 0.3s ease;
    mix-blend-mode: screen;
    will-change: transform, opacity;
  }
  
  @media (prefers-reduced-motion: reduce) {
    #cursor-glow {
      display: none;
    }
    
    #wave-canvas {
      display: none;
    }
  }
</style>

<script>
  // Only initialize performance-intensive features if not on mobile
  const isMobile = window.innerWidth < 768;
  
  // Wave canvas class with performance optimizations
  class Wave {
    constructor(
      private canvas: HTMLCanvasElement,
      private freq: number = 0.008,
      private phase: number = 0,
      private amplitude: number = 70
    ) {
      this.ctx = this.canvas.getContext('2d') as CanvasRenderingContext2D;
      this.canvas.width = window.innerWidth;
      this.canvas.height = window.innerHeight;
      this.centers = [];
      this.lastFrameTime = 0;
      
      // Create less wave centers on mobile
      const maxCenters = isMobile ? 3 : 8;
      
      for (let i = 0; i < maxCenters; i++) {
        this.centers.push({
          x: Math.random() * this.canvas.width,
          y: Math.random() * this.canvas.height,
          angle: Math.random() * Math.PI * 2,
          speed: 0.5 + Math.random() * 0.5,
          size: 60 + Math.random() * 40
        });
      }
    }
    
    private ctx: CanvasRenderingContext2D;
    private centers: {x: number, y: number, angle: number, speed: number, size: number}[];
    private lastFrameTime: number;
    
    animate = (currentTime: number) => {
      if (!this.canvas) return;
      
      // Limit FPS for better performance
      if (currentTime - this.lastFrameTime < 33) { // ~30fps
        requestAnimationFrame(this.animate);
        return;
      }
      
      this.lastFrameTime = currentTime;
      
      // Skip drawing if canvas is outside viewport
      if (!this.isInViewport()) {
        requestAnimationFrame(this.animate);
        return;
      }
      
      this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
      this.ctx.strokeStyle = 'rgba(96, 165, 250, 0.4)';
      this.ctx.lineWidth = 1.5;
      
      this.phase += 0.01;
      
      this.centers.forEach(center => {
        center.angle += center.speed / 100;
        
        center.x = this.canvas.width * (0.5 + 0.4 * Math.cos(center.angle));
        center.y = this.canvas.height * (0.5 + 0.4 * Math.sin(center.angle * 0.8));
        
        this.drawWave(center.x, center.y, center.size);
      });
      
      requestAnimationFrame(this.animate);
    }
    
    isInViewport() {
      const rect = this.canvas.getBoundingClientRect();
      return (
        rect.top <= window.innerHeight &&
        rect.bottom >= 0
      );
    }
    
    drawWave(centerX: number, centerY: number, size: number) {
      this.ctx.beginPath();
      
      for (let i = 0; i < Math.PI * 2; i += 0.1) {
        const wave1 = Math.sin(i * 6 + this.phase) * this.amplitude / 8;
        const wave2 = Math.sin(i * 4 + this.phase * 1.3) * this.amplitude / 12;
        const waveHeight = wave1 + wave2;
        
        const x = centerX + Math.cos(i) * (size + waveHeight);
        const y = centerY + Math.sin(i) * (size + waveHeight);
        
        if (i === 0) {
          this.ctx.moveTo(x, y);
        } else {
          this.ctx.lineTo(x, y);
        }
      }
      
      this.ctx.closePath();
      this.ctx.stroke();
      
      this.ctx.save();
      this.ctx.strokeStyle = 'rgba(96, 165, 250, 0.1)';
      this.ctx.lineWidth = 4;
      this.ctx.stroke();
      this.ctx.restore();
    }
  }
  
  // Cursor glow effect with throttling for better performance
  function setupCursorGlow() {
    const cursor = document.getElementById('cursor-glow');
    if (!cursor) return;
    
    let ticking = false;
    let isVisible = false;
    
    document.addEventListener('mousemove', (e) => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          // Reveal cursor on first move
          if (!isVisible) {
            cursor.style.opacity = '1';
            isVisible = true;
          }
          
          cursor.style.transform = `translate(${e.clientX - 25}px, ${e.clientY - 25}px)`;
          ticking = false;
        });
        
        ticking = true;
      }
    });
    
    document.addEventListener('mouseleave', () => {
      cursor.style.opacity = '0';
      isVisible = false;
    });
  }
  
  // Load scripts after page content is loaded
  document.addEventListener('DOMContentLoaded', () => {
    // Only initialize heavy animations on desktop
    if (!isMobile) {
      const canvas = document.getElementById('wave-canvas') as HTMLCanvasElement;
      if (canvas) {
        const wave = new Wave(canvas);
        setTimeout(() => {
          requestAnimationFrame(wave.animate);
        }, 500);
      }
      
      setupCursorGlow();
    }
    
    // Throttled mouse tracking
    if (!isMobile) {
      let ticking = false;
      document.addEventListener('mousemove', (e) => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            const mouseX = e.clientX / window.innerWidth;
            const mouseY = e.clientY / window.innerHeight;
            
            // Subtle movement of background elements based on mouse position
            document.documentElement.style.setProperty('--mouse-x', mouseX.toString());
            document.documentElement.style.setProperty('--mouse-y', mouseY.toString());
            
            ticking = false;
          });
          
          ticking = true;
        }
      });
    }
  });
</script>
