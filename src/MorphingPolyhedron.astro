  };

  // createCircleTexture function
  function createCircleTexture(THREE, size = 128) { /* ... same ... */
    const canvas = document.createElement('canvas'); canvas.width=size; canvas.height=size; const ctx=canvas.getContext('2d'); if(!ctx) return new THREE.Texture(); ctx.clearRect(0,0,size,size); const grad=ctx.createRadialGradient(size/2,size/2,0,size/2,size/2,size/2); grad.addColorStop(0,'rgba(255,255,255,1)'); grad.addColorStop(0.5,'rgba(255,255,255,0.5)'); grad.addColorStop(1,'rgba(255,255,255,0)'); ctx.fillStyle=grad; ctx.fillRect(0,0,size,size); const tex=new THREE.CanvasTexture(canvas); tex.generateMipmaps=false; tex.minFilter=THREE.LinearFilter; tex.magFilter=THREE.LinearFilter; tex.format=THREE.RGBAFormat; tex.needsUpdate=true; return tex;
   }

   // --- NEW: HSV to RGB conversion function for shaders ---
   // Source: https://stackoverflow.com/a/17897228 (adapted for GLSL vec3)
   const hsv2rgb = `
     vec3 hsv2rgb(vec3 c) {
         vec4 K = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
         vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
         return c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
     }
   `;


  document.addEventListener('DOMContentLoaded', () => {
    console.log("Advanced Wireframe initialization started");

    const loadingIndicator = document.getElementById('morphing-poly-loading');
    const canvas = document.getElementById('morphing-poly-canvas');

    if (!canvas) { /* ... error handling ... */ return; }

    setTimeout(async () => {
      if (loadingIndicator) { /* ... hide loader ... */ }

      try {
        console.log("Starting dependency load...");
        const { THREE, createNoise4D } = await loadDependencies();
        console.log("Dependencies finished loading.");

        setTimeout(() => {
          console.log("Yielded main thread, starting THREE.js setup...");

          // --- Configuration ---
           const colors = { // Main polyhedron color, particle colors
                background: new THREE.Color("#0a0a1a"),
                accent1: new THREE.Color("#8162ff"), // Main mesh color (less prominent now)
                particleColor1: new THREE.Color("#7142ff"),
                particleColor2: new THREE.Color("#00c489")
           };
           // Removed edgeColor as it's handled by shader

          const morphInterval = 3000;
          const holdDuration = 1000;
          // const edgeThresholdAngle = 5; // Still needed for EdgesGeometry generation
          const edgeThresholdAngle = 1; // Use 1 to get more edges for the effect
          const glowScaleFactor = 1.08; // Slightly smaller glow
          const glowOpacity = 0.15;
          const autoRotateSpeed = 0.0008;
          const dampingFactor = 0.94;
          const minVelocityThreshold = 0.00001;
          const noise4D = createNoise4D(); // Noise instance for JS use (if needed)
          const nudgeFactor = isMobile ? 0.00008 : 0.00005;

          // --- NEW: Wireframe Shader Configuration ---
          const wireframeColorSpeed = 0.3;    // Speed of color shifting
          const wireframeColorScale = 1.8;    // Spatial scale of color noise pattern
          const wireframePulseSpeed = 1.5;    // Speed of opacity pulsing
          const wireframeMinOpacity = 0.1;
          const wireframeMaxOpacity = 0.95;
          const wireframeSaturation = 0.85;   // Saturation of wireframe colors
          const wireframeValue = 1.0;         // Brightness of wireframe colors


          console.log("Starting THREE.js setup...");

          // --- Core THREE.js Setup (Scene, Camera, Renderer, Clock) ---
          const scene = new THREE.Scene();
          scene.background = colors.background;
          const fov = isMobile ? 60 : 55;
          const camera = new THREE.PerspectiveCamera(fov, window.innerWidth / window.innerHeight, 0.1, 100);
          camera.position.z = isMobile ? 4.8 : 4.2;
          const renderer = new THREE.WebGLRenderer({ /* ... */
              canvas: canvas, antialias: !isMobile, alpha: true, powerPreference: 'high-performance'
          });
          renderer.setSize(window.innerWidth, window.innerHeight);
          renderer.setPixelRatio(Math.min(window.devicePixelRatio, isMobile ? 1.5 : 2));
          renderer.setClearColor(0x000000, 0);
          const clock = new THREE.Clock(); // Use clock for time uniform


          // --- Geometry Setup for Morphing ---
          /* ... same target/base geometry and morph attribute generation ... */
            const targetGeometries = [ /* ... */ ]; const shapeNames = [ /* ... */ ];
            const baseGeometry = new THREE.SphereGeometry(1.1, 32, 16);
            baseGeometry.morphAttributes.position = [];
            const basePositionAttribute = baseGeometry.attributes.position;
            // Morph generation loop...
            for (let i = 0; i < targetGeometries.length; i++) { /* ... */ }


          // --- Material, Mesh ---
          const material = new THREE.MeshStandardMaterial({
                color: colors.accent1,
                metalness: 0.2, // Slightly less metallic
                roughness: 0.7, // More rough
                flatShading: true,
                transparent: true, // Make main mesh slightly transparent
                opacity: 0.65       // Let wireframe show through more
            });
          const mesh = new THREE.Mesh(baseGeometry, material);
          mesh.morphTargetInfluences = new Array(baseGeometry.morphAttributes.position.length).fill(0);
          scene.add(mesh);


          // --- START: Advanced Wireframe Setup ---
          console.log("Creating advanced wireframe...");
          const edgesGeometry = new THREE.EdgesGeometry(baseGeometry, edgeThresholdAngle);

          // Create and assign vertex colors based on original position
          const edgeVertexCount = edgesGeometry.attributes.position.count;
          const edgeColors = new Float32Array(edgeVertexCount * 3);
          const positionAttribute = edgesGeometry.attributes.position; // Use edge positions
          const tempColor = new THREE.Color();

          for (let i = 0; i < edgeVertexCount; i++) {
              // Use vertex position to derive a base hue
              const x = positionAttribute.getX(i);
              const y = positionAttribute.getY(i);
              const z = positionAttribute.getZ(i);
              // Simple mapping: map position components to HSL values
              // This provides a starting point for the shader
              const baseHue = (Math.atan2(y, x) / (Math.PI * 2)) + 0.5; // 0-1 range based on XY angle
              const baseSaturation = THREE.MathUtils.clamp(Math.abs(z / baseGeometry.parameters.radius), 0.5, 1.0); // Based on Z position
              const baseLightness = 0.6; // Constant base lightness

              tempColor.setHSL(baseHue, baseSaturation, baseLightness);

              edgeColors[i * 3] = tempColor.r;
              edgeColors[i * 3 + 1] = tempColor.g;
              edgeColors[i * 3 + 2] = tempColor.b;
          }
          edgesGeometry.setAttribute('color', new THREE.BufferAttribute(edgeColors, 3));
          console.log("Vertex colors assigned to edgesGeometry.");


          // Create ShaderMaterial for the wireframe
          const edgeMaterial = new THREE.ShaderMaterial({
              uniforms: {
                  time: { value: 0.0 },
                  colorSpeed: { value: wireframeColorSpeed },
                  colorScale: { value: wireframeColorScale },
                  pulseSpeed: { value: wireframePulseSpeed },
                  minOpacity: { value: wireframeMinOpacity },
                  maxOpacity: { value: wireframeMaxOpacity },
                  saturation: { value: wireframeSaturation },
                  value: { value: wireframeValue }, // Brightness
              },
              vertexShader: `
                  attribute vec3 color; // Base vertex color

                  uniform float time;
                  uniform float colorSpeed;
                  uniform float colorScale;
                  uniform float saturation;
                  uniform float value; // Brightness

                  varying vec3 vColor;

                  // Import Simplex Noise functions (requires providing them or using THREE.ShaderChunk)
                  // Using a basic pseudo-random hash for this example to avoid full noise lib injection
                  float hash(vec3 p) { return fract(sin(dot(p, vec3(127.1, 311.7, 74.7))) * 43758.5453); }
                  float noise(vec3 p) {
                      vec3 i = floor(p); vec3 f = fract(p);
                      f = f*f*(3.0-2.0*f);
                      float res = mix(mix(mix(hash(i+vec3(0,0,0)), hash(i+vec3(1,0,0)),f.x),
                                          mix(hash(i+vec3(0,1,0)), hash(i+vec3(1,1,0)),f.x),f.y),
                                      mix(mix(hash(i+vec3(0,0,1)), hash(i+vec3(1,0,1)),f.x),
                                          mix(hash(i+vec3(0,1,1)), hash(i+vec3(1,1,1)),f.x),f.y),f.z);
                      return res;
                  }

                  // Import hsv2rgb function
                  ${hsv2rgb} // Inject the function string

                  void main() {
                      // --- Morph Target Calculation (THREE.js handles this via ShaderMaterial flag) ---
                      vec3 morphedPosition = position; // Start with base position
                      #ifdef USE_MORPHTARGETS
                          morphedPosition = morphTarget0; // Assume morphTarget0 is base if influences are 0
                          morphedPosition += (morphTarget1 - morphTarget0) * morphTargetInfluences[0];
                          morphedPosition += (morphTarget2 - morphTarget0) * morphTargetInfluences[1];
                          morphedPosition += (morphTarget3 - morphTarget0) * morphTargetInfluences[2];
                          morphedPosition += (morphTarget4 - morphTarget0) * morphTargetInfluences[3];
                          // Add more lines if you have more morph targets
                      #endif


                      // --- Calculate Animated Color ---
                      // Use noise based on morphed position and time for hue shifting
                      float timeScaled = time * colorSpeed;
                      float hueNoise = noise(morphedPosition * colorScale + vec3(0.0, 0.0, timeScaled)); // Noise value 0-1

                      // Get base hue from vertex color attribute (approximate)
                      // Note: Converting RGB->HSL in shader is complex, using noise directly is easier
                      // float baseHue = color.r; // Simplification: using r as proxy for initial hue

                      float finalHue = fract(hueNoise + timeScaled * 0.1); // Combine noise and slow overall shift

                      // Convert HSV to RGB
                      vColor = hsv2rgb(vec3(finalHue, saturation, value));

                      // Standard position calculation
                      gl_Position = projectionMatrix * modelViewMatrix * vec4(morphedPosition, 1.0);
                  }
              `,
              fragmentShader: `
                  varying vec3 vColor;

                  uniform float time;
                  uniform float pulseSpeed;
                  uniform float minOpacity;
                  uniform float maxOpacity;

                  // Simple hash for opacity variation
                  float hash(float n) { return fract(sin(n)*43758.5453); }


                  void main() {
                      // --- Calculate Pulsing Opacity ---
                      float pulseSin = sin(time * pulseSpeed + gl_FragCoord.x * 0.05); // Vary pulse based on screen pos slightly
                      float pulseValue = (pulseSin + 1.0) / 2.0; // Map to 0-1
                      float opacity = minOpacity + pulseValue * (maxOpacity - minOpacity);

                      // Add slight noise to opacity? Optional.
                      // opacity *= (0.8 + hash(time + vColor.r * 10.0) * 0.2);

                      gl_FragColor = vec4(vColor, opacity);
                      // gl_FragColor = vec4(vColor, 1.0); // Debug: Full opacity
                  }
              `,
              vertexColors: true,   // Use the 'color' attribute
              morphTargets: true,   // Enable morph targets for this material
              transparent: true,
              // blending: THREE.AdditiveBlending, // Optional: make lines glow more when overlapping
              depthWrite: false, // Good for transparent lines
          });

          const edges = new THREE.LineSegments(edgesGeometry, edgeMaterial);
          edges.morphTargetInfluences = mesh.morphTargetInfluences; // Share influences!
          mesh.add(edges); // Add wireframe as child
          console.log("Advanced wireframe shader material created.");
          // --- END: Advanced Wireframe Setup ---


          // --- Glow (Less prominent) ---
          const glowMaterial = new THREE.MeshBasicMaterial({
               color: colors.accent1, // Maybe use a less saturated color?
               transparent: true,
               opacity: glowOpacity,
               side: THREE.BackSide
           });
           const glowMesh = new THREE.Mesh(baseGeometry, glowMaterial);
           glowMesh.scale.set(glowScaleFactor, glowScaleFactor, glowScaleFactor);
           glowMesh.morphTargetInfluences = mesh.morphTargetInfluences;
           mesh.add(glowMesh);


          // --- Particle System Setup ---
          /* ... same particle setup ... */
          const particleCount = isFirefox ? 400 : (isMobile ? 500 : 720); // Denser particles
          /* ... rest of particle code ... */
          const particleGeometry = new THREE.BufferGeometry(); /* ... */
          const particleMaterial = new THREE.ShaderMaterial({ /* ... */ });
          const particleSystem = new THREE.Points(particleGeometry, particleMaterial);
          scene.add(particleSystem);


          // --- Lighting ---
          /* ... same lighting ... */


          // --- Animation & State (Morphing, Interaction) ---
          /* ... same state variables ... */


          // --- Morphing Update Function ---
           function updateMorphing() { /* ... same morph logic ... */ }

          // --- User Interaction Handlers (Nudge) ---
          function onPointerDown(event: PointerEvent) { /* ... same nudge down logic ... */ }
          function onPointerMove(event: PointerEvent) { /* ... same nudge move logic ... */ }
          function onPointerUp(event: PointerEvent) { /* ... same nudge up logic ... */ }
          canvas.addEventListener('pointerdown', onPointerDown);


          // --- Animation loop ---
          function animate() {
            animationId = requestAnimationFrame(animate);
            const elapsedTime = clock.getElapsedTime(); // Use clock time
            const deltaTime = clock.getDelta(); // Time since last frame

            // Update time uniform for wireframe shader
            edgeMaterial.uniforms.time.value = elapsedTime;

            // Update morphing state
            updateMorphing();

            // --- Rotation Logic (Nudge/Auto-Rotate) ---
             rotationVelocity.x *= dampingFactor; rotationVelocity.y *= dampingFactor;
             if (!isUserInteracting) { /* ... add auto-rotate pull ... */ }
             if (Math.abs(rotationVelocity.x) < minVelocityThreshold) rotationVelocity.x = 0;
             if (Math.abs(rotationVelocity.y) < minVelocityThreshold) rotationVelocity.y = 0;
             mesh.rotation.x += rotationVelocity.x; mesh.rotation.y += rotationVelocity.y;

            // --- Update Particle System ---
            particleSystem.rotation.y += 0.0005; particleSystem.rotation.x += 0.0003;
            if (particleMaterial.uniforms.time) { particleMaterial.uniforms.time.value = elapsedTime; }

            // Render scene
            renderer.render(scene, camera);
          }

          // --- Start animation, Resize Handling, Visibility Handling ---
          /* ... same setup ... */


          // --- Cleanup on navigation ---
          document.addEventListener('astro:before-swap', () => {
            console.log("Cleaning up Advanced Wireframe component...");
            if (animationId) cancelAnimationFrame(animationId); animationId = null;

            // Remove listeners...

            scene.traverse(object => {
                 if (object.geometry) object.geometry.dispose();
                 if (object.material) {
                    if (Array.isArray(object.material)) {
                        object.material.forEach(mat => {
                            // Dispose textures/uniforms...
                             if (mat.uniforms && mat.uniforms.pointTexture && mat.uniforms.pointTexture.value) { mat.uniforms.pointTexture.value.dispose(); }
                            mat.dispose();
                        });
                    } else {
                         // Dispose textures/uniforms...
                         if (object.material.uniforms && object.material.uniforms.pointTexture && object.material.uniforms.pointTexture.value) { object.material.uniforms.pointTexture.value.dispose(); }
                         object.material.dispose();
                    }
                 }
            });
            // Explicit dispose just in case (especially for attributes)
             if (particleTexture) particleTexture.dispose();
             if (edgesGeometry) { // Dispose custom attribute
                if(edgesGeometry.attributes.color) edgesGeometry.attributes.color.dispose();
                edgesGeometry.dispose();
             }
             console.log("Advanced Wireframe cleanup complete.");


            if (renderer) renderer.dispose();
          }, { once: true });

          console.log("Advanced Wireframe initialization completed.");

        }, 0); // End inner setTimeout

      } catch (error) { /* ... error handling ... */ }
    }, 50); // End outer setTimeout
  });
</script>