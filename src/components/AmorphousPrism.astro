---
// src/components/AmorphousPrism.astro - Refactored to use morph targets with edge definition
---

<canvas id="prism-bg-canvas" class="absolute top-0 left-0 w-full h-full" style="pointer-events: auto; z-index: 5;"></canvas>

<script>
  import * as THREE from 'three';
  import { createNoise4D } from 'simplex-noise';

  // Create a simple circular texture for particles
  function createCircleTexture(size = 64) {
    // Create a canvas element
    const canvas = document.createElement('canvas');
    canvas.width = size;
    canvas.height = size;
    const ctx = canvas.getContext('2d');
    
    // Return a blank texture if context is null
    if (!ctx) {
      console.warn('Failed to get 2D context for particle texture');
      return new THREE.Texture();
    }
    
    // Create a radial gradient (white in center, transparent at edges)
    const gradient = ctx.createRadialGradient(
      size/2, size/2, 0,
      size/2, size/2, size/2
    );
    gradient.addColorStop(0, 'rgba(255,255,255,1)');
    gradient.addColorStop(0.5, 'rgba(255,255,255,0.5)');
    gradient.addColorStop(1, 'rgba(255,255,255,0)');
    
    // Draw the gradient
    ctx.fillStyle = gradient;
    ctx.fillRect(0, 0, size, size);
    
    // Create a texture from the canvas
    const texture = new THREE.CanvasTexture(canvas);
    texture.needsUpdate = true;
    return texture;
  }

  document.addEventListener('DOMContentLoaded', () => {
    console.log("Prism initialization started");
    const canvas = document.getElementById('prism-bg-canvas') as HTMLCanvasElement | null;
    if (!canvas) {
        console.error("Canvas element #prism-bg-canvas not found!");
        return;
    }

    // Ensure pointer events are explicitly set
    canvas.style.cssText += '; pointer-events: auto !important;';
    console.log("Canvas pointer-events set to:", canvas.style.pointerEvents);

    // Add browser detection for optimizations
    const isFirefox = navigator.userAgent.toLowerCase().indexOf('firefox') > -1;
    const isChrome = navigator.userAgent.toLowerCase().indexOf('chrome') > -1 && 
                    navigator.userAgent.toLowerCase().indexOf('edge') === -1;
    const isMobile = window.innerWidth < 768;
    
    console.log('Browser detection:', { isFirefox, isChrome, isMobile });
    
    // --- Configuration ---
    const colors = {
        background: new THREE.Color("#0a0a1a"), // Dark blue/purple background
        accent1: new THREE.Color("#8162ff"),    // Vibrant purple
        accent2: new THREE.Color("#00e599"),    // Teal
        accent3: new THREE.Color("#ffffff"),    // White for highlights
        edgeColor: new THREE.Color("#e0e0ff"),  // Light blueish white for edges
        particleColor1: new THREE.Color("#7142ff"), // Darker purple for particles
        particleColor2: new THREE.Color("#00c489")  // Darker teal for particles
    };
    
    // Shape morphing configuration
    const morphSpeed = isFirefox ? 0.02 : (isMobile ? 0.015 : 0.03); // Faster for smoother transition
    const morphInterval = isMobile ? 4000 : 6000; // Time spent on each shape
    const wobbleSpeed = 0.5; // Noise time multiplier
    const wobbleIntensity = 0.05; // Reduced intensity for subtle effect
    const noiseScale = 1.5;
    
    // Create noise function for organic deformations
    const noise4D = createNoise4D();
    
    // --- Core THREE.js Setup ---
    // Create scene
    const scene = new THREE.Scene();
    scene.background = new THREE.Color(colors.background);
    
    // Create camera
    const fov = isMobile ? 65 : 75;
    const camera = new THREE.PerspectiveCamera(fov, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.z = isMobile ? 5.0 : 4.0; // Increased distance for mobile to show more of the scene
    // Center camera horizontally
    camera.position.x = 0;
    
    // Create renderer
    const renderer = new THREE.WebGLRenderer({
        canvas: canvas,
        antialias: !(isFirefox || isMobile),
        alpha: true,
        powerPreference: 'high-performance'
    });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, isFirefox ? 1.5 : (isMobile ? 1.5 : 2)));
    renderer.setClearColor(0x000000, 0.1);
    renderer.setClearAlpha(0.1);
    
    // --- Geometry Setup for Morphing ---
    // 1. Define the target shapes (Platonic Solids)
    const targetGeometries = [
      new THREE.TetrahedronGeometry(1.0, 0),    // Target 0
      new THREE.BoxGeometry(1.6, 1.6, 1.6),     // Target 1
      new THREE.OctahedronGeometry(1.1, 0),     // Target 2
      new THREE.DodecahedronGeometry(1.2, 0),   // Target 3
      new THREE.IcosahedronGeometry(1.1, 0)     // Target 4
    ];
    const platonicNames = ["Tetrahedron", "Cube", "Octahedron", "Dodecahedron", "Icosahedron"];
    
    // 2. Create the Base Geometry (subdivided sphere for consistent vertex count)
    const baseGeometry = new THREE.SphereGeometry(1.1, 32, 16); // Radius, WidthSegments, HeightSegments
    baseGeometry.morphAttributes.position = []; // Initialize morph position attributes array

    const basePositionAttribute = baseGeometry.attributes.position;
    const baseVertex = new THREE.Vector3();
    const targetVertex = new THREE.Vector3();

    console.log(`Base geometry has ${basePositionAttribute.count} vertices.`);

    // 3. Generate Morph Target Attributes
    for (let i = 0; i < targetGeometries.length; i++) {
        const targetGeo = targetGeometries[i];
        const targetPositionAttribute = targetGeo.attributes.position;
        const morphPositions = new Float32Array(basePositionAttribute.count * 3);

        console.log(`Processing target ${platonicNames[i]} with ${targetPositionAttribute.count} vertices.`);

        if (!targetPositionAttribute) {
            console.error(`Target geometry ${platonicNames[i]} has no position attribute!`);
            continue;
        }

        // For each vertex in the BASE geometry...
        for (let j = 0; j < basePositionAttribute.count; j++) {
            baseVertex.fromBufferAttribute(basePositionAttribute, j);

            // Find the closest vertex in the TARGET geometry
            let closestDistSq = Infinity;
            let closestVertexIndex = -1;

            for (let k = 0; k < targetPositionAttribute.count; k++) {
                targetVertex.fromBufferAttribute(targetPositionAttribute, k);
                const distSq = baseVertex.distanceToSquared(targetVertex);
                if (distSq < closestDistSq) {
                    closestDistSq = distSq;
                    closestVertexIndex = k;
                }
            }

            // Get the position of the closest target vertex
            if (closestVertexIndex !== -1) {
                targetVertex.fromBufferAttribute(targetPositionAttribute, closestVertexIndex);
            } else {
                // Fallback: use the base vertex position itself if no target vertex found
                targetVertex.copy(baseVertex);
            }

            // Store this target position in the morph attribute array
            morphPositions[j * 3] = targetVertex.x;
            morphPositions[j * 3 + 1] = targetVertex.y;
            morphPositions[j * 3 + 2] = targetVertex.z;
        }

        // Add the calculated positions as a morph target attribute
        baseGeometry.morphAttributes.position.push(
            new THREE.Float32BufferAttribute(morphPositions, 3)
        );

        // Dispose of the temporary target geometry to save memory
        targetGeo.dispose();
    }
    targetGeometries.length = 0; // Clear the array, we only needed them temporarily

    // 4. Create Material with Morph Targets Enabled
    const material = new THREE.MeshPhysicalMaterial({
        color: 0x8162ff,
        metalness: 0.3, // Increased for better definition
        roughness: 0.3, // Increased for better diffusion
        clearcoat: 0.8,
        clearcoatRoughness: 0.05,
        transmission: 0.4, // Reduced for better visibility
        transparent: true,
        opacity: 0.9,
        ior: 1.5,
        reflectivity: 0.5,
        // @ts-ignore - morphTargets is supported in THREE.js but missing in type definitions
        morphTargets: true // IMPORTANT for morph targets
    });

    // 5. Create the Mesh
    const prism = new THREE.Mesh(baseGeometry, material);

    // Size and position - REDUCED SIZE (by 10-15%)
    const sizeMultiplier = isMobile ? 0.75 : 1.0; // Reduced from 0.9/1.2
    prism.scale.set(sizeMultiplier, sizeMultiplier, sizeMultiplier);
    
    // Position the prism - adjusted for perfect centering
    const yPosition = isMobile ? -0.1 : 0.2; // Slight adjustment downward on mobile
    const xPosition = 0; // No x-offset for perfect horizontal centering
    prism.position.set(xPosition, yPosition, 0);
    prism.rotation.x = 0.4;
    prism.rotation.y = isMobile ? 0.5 : 0.6; // Adjusted rotation for mobile
    
    // Center the scene origin
    scene.position.x = 0;
    scene.add(prism);
    
    // --- NEW: Create Particle Atmosphere ---
    const particleCount = isFirefox ? 200 : (isMobile ? 300 : 500);
    const particleGeometry = new THREE.BufferGeometry();
    const particlePositions = new Float32Array(particleCount * 3);
    const particleSizes = new Float32Array(particleCount);
    const particleColors = new Float32Array(particleCount * 3);
    
    // Create a larger sphere around the prism for particle positions
    const atmosphereRadius = 2.0 * sizeMultiplier;
    
    // Generate random particles in a sphere arrangement
    for (let i = 0; i < particleCount; i++) {
        // Generate points in a spherical distribution
        const theta = Math.random() * Math.PI * 2;
        const phi = Math.acos(2 * Math.random() - 1);
        
        // Calculate radius with some variation (not all particles at exact sphere surface)
        const radius = atmosphereRadius * (0.7 + Math.random() * 0.6);
        
        // Convert to Cartesian coordinates
        const x = radius * Math.sin(phi) * Math.cos(theta);
        const y = radius * Math.sin(phi) * Math.sin(theta);
        const z = radius * Math.cos(phi);
        
        particlePositions[i * 3] = x;
        particlePositions[i * 3 + 1] = y;
        particlePositions[i * 3 + 2] = z;
        
        // Random sizes
        particleSizes[i] = 0.05 + Math.random() * 0.15;
        
        // Interpolate between colors based on position
        const lerpFactor = Math.random();
        particleColors[i * 3] = colors.particleColor1.r * (1 - lerpFactor) + colors.particleColor2.r * lerpFactor;
        particleColors[i * 3 + 1] = colors.particleColor1.g * (1 - lerpFactor) + colors.particleColor2.g * lerpFactor;
        particleColors[i * 3 + 2] = colors.particleColor1.b * (1 - lerpFactor) + colors.particleColor2.b * lerpFactor;
    }
    
    particleGeometry.setAttribute('position', new THREE.BufferAttribute(particlePositions, 3));
    particleGeometry.setAttribute('size', new THREE.BufferAttribute(particleSizes, 1));
    particleGeometry.setAttribute('color', new THREE.BufferAttribute(particleColors, 3));
    
    // Create particle material with custom shader
    const particleMaterial = new THREE.ShaderMaterial({
        uniforms: {
            time: { value: 0 },
            pointTexture: { value: createCircleTexture() }
        },
        vertexShader: `
            attribute float size;
            attribute vec3 color;
            varying vec3 vColor;
            uniform float time;
            
            void main() {
                vColor = color;
                vec3 pos = position;
                
                // Simple oscillation effect
                float noise = sin(position.x * 5.0 + time) * 0.05 + cos(position.y * 5.0 + time * 0.8) * 0.05;
                pos.x += sin(position.y * 0.8 + time * 0.6) * 0.08;
                pos.y += cos(position.z * 0.8 + time * 0.5) * 0.08;
                pos.z += noise;
                
                vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
                gl_PointSize = size * (300.0 / -mvPosition.z);
                gl_Position = projectionMatrix * mvPosition;
            }
        `,
        fragmentShader: `
            uniform sampler2D pointTexture;
            varying vec3 vColor;
            
            void main() {
                gl_FragColor = vec4(vColor, 1.0) * texture2D(pointTexture, gl_PointCoord);
                if (gl_FragColor.a < 0.3) discard;
            }
        `,
        blending: THREE.AdditiveBlending,
        depthWrite: false,
        transparent: true,
    });
    
    // Create and add particle system
    const particleSystem = new THREE.Points(particleGeometry, particleMaterial);
    particleSystem.position.copy(prism.position);
    scene.add(particleSystem);

    // --- NEW: Create Edges Outline ---
    const edgesGeometry = new THREE.EdgesGeometry(baseGeometry, 15); // Threshold angle in degrees
    const edgeMaterial = new THREE.LineBasicMaterial({
        color: colors.edgeColor,
        linewidth: isMobile ? 1.5 : 1, // Note: linewidth > 1 only works on some platforms
        transparent: true,
        opacity: 0.75,
        // @ts-ignore - morphTargets is supported in THREE.js but missing in type definitions
        morphTargets: true // CRUCIAL for edges to morph!
    });
    const prismEdges = new THREE.LineSegments(edgesGeometry, edgeMaterial);

    // Edges need the same initial transform as the prism
    prismEdges.scale.copy(prism.scale);
    prismEdges.position.copy(prism.position);
    prismEdges.rotation.copy(prism.rotation);
    scene.add(prismEdges);

    // --- Glow Effect ---
    // The glow mesh also needs to use the morph targets
    const glowMaterial = new THREE.MeshBasicMaterial({
      color: 0x8162ff,
      transparent: true,
      opacity: isMobile ? 0.35 : 0.25, // Reduced for better edge visibility
      side: THREE.BackSide,
      // @ts-ignore - morphTargets is supported in THREE.js but missing in type definitions
      morphTargets: true // IMPORTANT for glow too
    });

    const glowMesh = new THREE.Mesh(baseGeometry, glowMaterial); // Use the SAME geometry
    const glowScaleFactor = 1.1; // Reduced to make glow closer to the shape
    glowMesh.scale.copy(prism.scale).multiplyScalar(glowScaleFactor);
    glowMesh.position.copy(prism.position);
    glowMesh.rotation.copy(prism.rotation);
    scene.add(glowMesh);

    // --- Lighting ---
    const ambientLight = new THREE.AmbientLight(0xffffff, isMobile ? 1.5 : 0.8); // Increased intensity for mobile
    scene.add(ambientLight);

    const directionalLight = new THREE.DirectionalLight(colors.accent1, isMobile ? 4.0 : 2.5); // Brighter on mobile
    directionalLight.position.set(2, 3, 5);
    scene.add(directionalLight);

    const directionalLight2 = new THREE.DirectionalLight(colors.accent2, isMobile ? 3.5 : 2.0); // Brighter on mobile
    directionalLight2.position.set(-3, -1, 2);
    scene.add(directionalLight2);
    
    const spotLight = new THREE.SpotLight(0xffffff, isFirefox ? 2.0 : (isMobile ? 5.0 : 3.0)); // Much brighter on mobile
    spotLight.position.set(0, 5, 2);
    spotLight.angle = Math.PI / 6;
    spotLight.penumbra = 0.3;
    scene.add(spotLight);

    // --- Animation & Morphing State ---
    let time = 0;
    let animationId: number | null = null;
    let frameCounter = 0;
    let currentShapeIndex = 0;
    let targetShapeIndex = 1;
    let morphProgress = 0;
    let isMorphing = true;
    let lastMorphTime = performance.now();
    let holdStartTime = 0; // When did we reach the target shape?
    const holdDuration = 1500; // Milliseconds to hold a shape before starting next morph
    
    // --- User Interaction ---
    const rotationVelocity = { x: 0, y: 0 };
    let isUserInteracting = false;
    let morphingPausedByUser = false;
    let previousMousePosition = { x: 0, y: 0 };
    const userRotationSpeed = isMobile ? 0.007 : 0.005;
    const dampingFactor = 0.95;
    const minVelocityThreshold = 0.00005;
    
    // Hint for user interaction
    const addInteractionHint = () => {
        if (isMobile) return;
        
        const hintElement = document.createElement('div');
        hintElement.textContent = 'Drag to rotate the crystal';
        hintElement.style.position = 'absolute';
        hintElement.style.top = '45%';
        hintElement.style.left = '50%';
        hintElement.style.transform = 'translate(-50%, -50%)';
        hintElement.style.color = 'rgba(255, 255, 255, 0.9)';
        hintElement.style.fontSize = '16px';
        hintElement.style.fontFamily = 'Inter, sans-serif';
        hintElement.style.padding = '8px 16px';
        hintElement.style.borderRadius = '8px';
        hintElement.style.backgroundColor = 'rgba(129, 98, 255, 0.3)';
        hintElement.style.backdropFilter = 'blur(4px)';
        hintElement.style.zIndex = '100';
        hintElement.style.pointerEvents = 'none';
        hintElement.style.opacity = '0';
        hintElement.style.transition = 'opacity 0.8s ease';
        hintElement.style.boxShadow = '0 2px 10px rgba(129, 98, 255, 0.4)';
        
        if (canvas.parentElement) {
            canvas.parentElement.appendChild(hintElement);
            
            setTimeout(() => {
                hintElement.style.opacity = '1';
            }, 2000);
            
            setTimeout(() => {
                hintElement.textContent = 'Watch it transform over time';
            }, 4000);
            
            setTimeout(() => {
                hintElement.style.opacity = '0';
                setTimeout(() => {
                    if (hintElement.parentElement) {
                        hintElement.parentElement.removeChild(hintElement);
                    }
                }, 800);
            }, 6000);
        }
    };
    
    // Show hint after a delay
    if (!('ontouchstart' in window) && !isMobile) {
      setTimeout(addInteractionHint, 1500);
    }
    
    // --- Morphing Update Function (Refactored for Morph Targets) ---
    function updateMorphing() {
      if (!isMorphing || morphingPausedByUser) return;

      const now = performance.now();
      
      // Are we currently holding a shape?
      if (morphProgress === 1.0) {
        if (holdStartTime === 0) {
            holdStartTime = now; // Start the hold timer
        }
        // Check if hold duration has passed
        if (now - holdStartTime > holdDuration) {
            // Start morphing to the next shape
            currentShapeIndex = targetShapeIndex;
            targetShapeIndex = (targetShapeIndex + 1) % baseGeometry.morphAttributes.position.length;
            morphProgress = 0;
            lastMorphTime = now; // Reset timer for the new morph
            holdStartTime = 0; // Reset hold timer
            console.log("Morphing to new shape:", platonicNames[targetShapeIndex]);
        } else {
            // Still holding, no need to update influences yet
            return;
        }
      }

      // Update morph progress (if not holding)
      if (morphProgress < 1.0) {
         // Calculate time elapsed since morph started
         let morphElapsedTime = now - lastMorphTime;
         // Calculate progress based on desired duration
         morphProgress = Math.min(1.0, morphElapsedTime / morphInterval);
      }
      
      // Smooth easing
      const easedProgress = 0.5 - 0.5 * Math.cos(morphProgress * Math.PI);
      
      // --- Update Morph Influences ---
      // Ensure the influences array exists and has the correct length
      if (!prism.morphTargetInfluences || prism.morphTargetInfluences.length !== baseGeometry.morphAttributes.position.length) {
          // Initialize if needed
          prism.morphTargetInfluences = new Array(baseGeometry.morphAttributes.position.length).fill(0);
      }
      
      // Initialize glow influences if needed
      if (!glowMesh.morphTargetInfluences || glowMesh.morphTargetInfluences.length !== baseGeometry.morphAttributes.position.length) {
          glowMesh.morphTargetInfluences = new Array(baseGeometry.morphAttributes.position.length).fill(0);
      }
      
      // Initialize edge influences if needed
      if (!prismEdges.morphTargetInfluences || prismEdges.morphTargetInfluences.length !== baseGeometry.morphAttributes.position.length) {
          prismEdges.morphTargetInfluences = new Array(baseGeometry.morphAttributes.position.length).fill(0);
      }

      // Reset all influences first
      for (let i = 0; i < prism.morphTargetInfluences.length; i++) {
          prism.morphTargetInfluences[i] = 0;
          if (glowMesh.morphTargetInfluences) {
              glowMesh.morphTargetInfluences[i] = 0;
          }
          if (prismEdges.morphTargetInfluences) {
              prismEdges.morphTargetInfluences[i] = 0;
          }
      }

      // Apply influence based on progress between current and target shapes
      prism.morphTargetInfluences[currentShapeIndex] = 1 - easedProgress;
      prism.morphTargetInfluences[targetShapeIndex] = easedProgress;

      // Sync glow mesh influences
      if (glowMesh.morphTargetInfluences) {
          glowMesh.morphTargetInfluences[currentShapeIndex] = 1 - easedProgress;
          glowMesh.morphTargetInfluences[targetShapeIndex] = easedProgress;
      }
      
      // Sync edge mesh influences
      if (prismEdges.morphTargetInfluences) {
          prismEdges.morphTargetInfluences[currentShapeIndex] = 1 - easedProgress;
          prismEdges.morphTargetInfluences[targetShapeIndex] = easedProgress;
      }

      // Adjust material properties during transition
      const transitionFactor = Math.sin(easedProgress * Math.PI);
      material.roughness = 0.3 + transitionFactor * 0.2; // More rough during transition
      material.metalness = 0.3 - transitionFactor * 0.15;
      // Make edges slightly more visible during transitions
      edgeMaterial.opacity = 0.6 + transitionFactor * 0.4;
    }
    
    // --- User interaction handlers ---
    function onPointerDown(event: PointerEvent | TouchEvent) {
      // Check if it's a touch event and we're on mobile
      const isTouchEvent = 'touches' in event;
      
      // Only prevent default for mouse events, not touch events on mobile
      // This allows mobile scrolling to work normally
      if (!isTouchEvent || !isMobile) {
        event.preventDefault();
      }
      
      console.log("Pointer down detected on prism canvas");
      
      isUserInteracting = true;
      morphingPausedByUser = true; // Pause morphing during interaction
      document.body.style.cursor = 'grabbing';
      
      // Get coordinates (works for both mouse and touch)
      const clientX = 'clientX' in event ? event.clientX : (event.touches[0].clientX);
      const clientY = 'clientY' in event ? event.clientY : (event.touches[0].clientY);
      
      previousMousePosition = { x: clientX, y: clientY };
      
      // Add document-level event listeners with passive: true for touch events on mobile
      document.addEventListener('pointermove', onPointerMove, { passive: isMobile && isTouchEvent });
      document.addEventListener('pointerup', onPointerUp, { passive: isMobile && isTouchEvent });
      document.addEventListener('pointercancel', onPointerUp, { passive: isMobile && isTouchEvent });
      
      // Add touch-specific events
      if (isTouchEvent && canvas) {
        canvas.addEventListener('touchmove', onPointerMove as EventListener, { passive: isMobile });
        canvas.addEventListener('touchend', onPointerUp as EventListener, { passive: true });
        canvas.addEventListener('touchcancel', onPointerUp as EventListener, { passive: true });
      }
    }
    
    function onPointerMove(event: PointerEvent | TouchEvent) {
      if (!isUserInteracting) return;
      
      // Check if it's a touch event and we're on mobile
      const isTouchEvent = 'touches' in event;
      
      // Only prevent default for mouse events or non-mobile touch events
      if (!isTouchEvent || !isMobile) {
        event.preventDefault();
      }
      
      // Get coordinates
      const clientX = 'clientX' in event ? event.clientX : (event.touches[0].clientX);
      const clientY = 'clientY' in event ? event.clientY : (event.touches[0].clientY);
      
      // Calculate rotation delta
      const deltaX = clientX - previousMousePosition.x;
      const deltaY = clientY - previousMousePosition.y;
      
      // On mobile with touch events, check if this looks like a scroll attempt
      if (isMobile && isTouchEvent && Math.abs(deltaY) > Math.abs(deltaX) * 1.5) {
        // This looks like a vertical scroll attempt, release the interaction
        isUserInteracting = false;
        morphingPausedByUser = false;
        
        // Clean up event listeners
        document.removeEventListener('pointermove', onPointerMove);
        document.removeEventListener('pointerup', onPointerUp);
        document.removeEventListener('pointercancel', onPointerUp);
        
        if (canvas) {
          canvas.removeEventListener('touchmove', onPointerMove as EventListener);
          canvas.removeEventListener('touchend', onPointerUp as EventListener);
          canvas.removeEventListener('touchcancel', onPointerUp as EventListener);
        }
        
        return;
      }
      
      // Update rotation velocity - reduced on mobile
      const mobileFactor = isMobile ? 0.5 : 1.0;
      rotationVelocity.y = deltaX * userRotationSpeed * mobileFactor;
      rotationVelocity.x = -deltaY * userRotationSpeed * mobileFactor;
      
      previousMousePosition = { x: clientX, y: clientY };
    }
    
    function onPointerUp(event: PointerEvent | TouchEvent) {
      // Check if it's a touch event and we're on mobile
      const isTouchEvent = 'touches' in event;
      
      // Only prevent default for mouse events or non-mobile
      if (!isTouchEvent || !isMobile) {
        event.preventDefault();
      }
      
      if (!isUserInteracting) return; // Prevent multi-fires
      
      isUserInteracting = false;
      console.log("Pointer up, ending prism interaction");
      document.body.style.cursor = '';
      
      // Resume morphing after a short delay, reset timers
      setTimeout(() => {
        morphingPausedByUser = false;
        // Reset timers to avoid sudden jumps if morph was paused mid-way
        if (morphProgress < 1.0) {
            lastMorphTime = performance.now() - morphProgress * morphInterval;
        } else {
            // If shape was fully formed, reset hold timer too if needed
            holdStartTime = performance.now();
        }
        console.log("Resuming morphing");
      }, 800);
      
      // Remove event listeners
      document.removeEventListener('pointermove', onPointerMove);
      document.removeEventListener('pointerup', onPointerUp);
      document.removeEventListener('pointercancel', onPointerUp);
      
      if (canvas) {
        canvas.removeEventListener('touchmove', onPointerMove as EventListener);
        canvas.removeEventListener('touchend', onPointerUp as EventListener);
        canvas.removeEventListener('touchcancel', onPointerUp as EventListener);
      }
    }
    
    // --- Set up event listeners ---
    if (canvas) {
      // Ensure canvas can receive events but allow scrolling on mobile
      canvas.style.pointerEvents = 'auto';
      
      // On mobile, limit the interactive height to avoid blocking scrolling
      const canvasHeight = isMobile ? '70vh' : '100%';
      
      // Force canvas to be visible and interactive
      canvas.style.cssText += `; 
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: ${canvasHeight};
        z-index: 5;
        pointer-events: auto !important;
        visibility: visible !important;
        opacity: 1 !important;
      `;
      
      // Add event listeners - use passive for better scroll performance on mobile
      canvas.addEventListener('pointerdown', onPointerDown, { passive: isMobile });
      canvas.addEventListener('touchstart', onPointerDown as EventListener, { passive: isMobile });
      
      // Cursor hover effects
      canvas.addEventListener('mouseover', () => {
        document.body.style.cursor = 'grab';
      });
      
      canvas.addEventListener('mouseout', () => {
        if (!isUserInteracting) {
          document.body.style.cursor = '';
        }
      });
    }
    
    // --- Animation loop ---
    function animate() {
      animationId = requestAnimationFrame(animate);
      
      frameCounter++;
      time = performance.now() * 0.001;
      
      // Log status occasionally
      if (frameCounter % 300 === 0) {
        console.log("Animation status:", {
          frame: frameCounter,
          isMorphing,
          currentShape: platonicNames[currentShapeIndex],
          targetShape: platonicNames[targetShapeIndex]
        });
      }
      
      // Apply rotation velocity with damping
      rotationVelocity.x *= dampingFactor;
      rotationVelocity.y *= dampingFactor;
      
      // Reset velocity if it's very small
      if (Math.abs(rotationVelocity.x) < minVelocityThreshold) rotationVelocity.x = 0;
      if (Math.abs(rotationVelocity.y) < minVelocityThreshold) rotationVelocity.y = 0;
      
      if (isUserInteracting || Math.abs(rotationVelocity.x) > 0.0001 || Math.abs(rotationVelocity.y) > 0.0001) {
        // User-controlled rotation
        prism.rotation.x += rotationVelocity.x;
        prism.rotation.y += rotationVelocity.y;
      } else if (!morphingPausedByUser) {
        // Auto-rotation - subtle wobble
        prism.rotation.y += (isMobile ? 0.0003 : 0.0002);
        prism.rotation.x += Math.sin(time * 0.3) * 0.0001;
      }
      
      // Sync glow mesh rotation and position
      glowMesh.rotation.copy(prism.rotation);
      glowMesh.position.copy(prism.position);
      glowMesh.scale.copy(prism.scale).multiplyScalar(glowScaleFactor);
      
      // Sync edges mesh rotation and position
      prismEdges.rotation.copy(prism.rotation);
      prismEdges.position.copy(prism.position);
      prismEdges.scale.copy(prism.scale);
      
      // Update particle system
      particleSystem.rotation.y += 0.0005;
      particleSystem.rotation.x += 0.0003;
      
      // Update particle shader uniforms
      if (particleMaterial.uniforms) {
        particleMaterial.uniforms.time.value = time;
      }
      
      // Update shape morphing
        updateMorphing();
      
      // Render scene
      renderer.render(scene, camera);
    }
    
    // --- Start animation ---
    animate();
    
    // --- Handle window resize ---
    function onWindowResize() {
      // Update camera
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      
      // Update renderer
      renderer.setSize(window.innerWidth, window.innerHeight);
    }
    window.addEventListener('resize', onWindowResize, false);
    
    // --- Handle visibility change ---
    const handleVisibilityChange = () => {
      if (document.hidden && animationId) {
        cancelAnimationFrame(animationId);
        animationId = null;
      } else if (!document.hidden && !animationId) {
        animate();
      }
    };
    document.addEventListener('visibilitychange', handleVisibilityChange);
    
    // --- Cleanup on navigation ---
    document.addEventListener('astro:before-swap', () => {
      console.log("Cleaning up Prism component...");
      if (animationId) {
        cancelAnimationFrame(animationId);
      }
      
      document.removeEventListener('visibilitychange', handleVisibilityChange);
      window.removeEventListener('resize', onWindowResize);
      
      // Remove interaction listeners
      if (canvas) {
         canvas.removeEventListener('pointerdown', onPointerDown);
         canvas.removeEventListener('touchstart', onPointerDown as EventListener);
      }
      document.removeEventListener('pointermove', onPointerMove);
      document.removeEventListener('pointerup', onPointerUp);
      
      // Dispose THREE.js objects
      scene.traverse(object => {
          if (object instanceof THREE.Mesh || object instanceof THREE.LineSegments || object instanceof THREE.Points) {
              if (object.geometry) object.geometry.dispose();
              if (object.material) {
                  if (Array.isArray(object.material)) {
                      object.material.forEach(mat => mat.dispose());
                  } else {
                      object.material.dispose();
                  }
              }
          }
      });
      
      // Explicit disposal for clarity
      if (edgesGeometry) edgesGeometry.dispose();
      if (edgeMaterial) edgeMaterial.dispose();
      if (particleGeometry) particleGeometry.dispose();
      if (particleMaterial) particleMaterial.dispose();
      
      if (renderer) renderer.dispose();
      console.log("Prism cleanup complete.");
    });
    
    console.log("Prism initialization completed using Morph Targets with edge definition and particles.");
  });
</script> 