---
// AmorphousPrism.astro - Minimalist loader for the 3D visualization
import LoadingScreen from './LoadingScreen.astro';
---

<!-- Canvas for Three.js -->
<canvas id="morphing-poly-canvas" class="absolute top-0 left-0 w-full h-full morphing-poly-canvas" 
  style="pointer-events: auto !important; z-index: 5; touch-action: none !important; cursor: grab; opacity: 1; backface-visibility: hidden; transform: translateZ(0);" 
  data-interactive="true" data-priority="highest" tabindex="0">
</canvas>

<!-- Firefox WebGL fallback container -->
<div id="firefox-webgl-container" class="absolute top-0 left-0 w-full h-full" style="z-index: 5;"></div>

<!-- Cursor glow effect container -->
<div id="cursor-glow" class="absolute pointer-events-none w-24 h-24 rounded-full opacity-0 transition-opacity duration-300 z-10" style="background: radial-gradient(circle, rgba(120,70,255,0.4) 0%, rgba(120,70,255,0) 70%); transform: translate(-50%, -50%);"></div>

<!-- Original loading screen -->
<LoadingScreen />

<!-- Z-index fix script (load this FIRST to ensure correct stacking) -->
<script src="/js/z-index-fix.js" is:inline></script>

<!-- Three.js fixes loader (load this BEFORE any Three.js code) -->
<script src="/js/shader-extension-fix.js" is:inline></script>

<!-- Performance optimizations -->
<script src="/js/optimize-will-change.js" is:inline></script>

<!-- Main initialization script -->
<script src="/scripts/amorphous-prism-init.js" is:inline></script>

<!-- Add a canary log script to check if scripts are executing -->
<script is:inline>
  console.log("--- SCRIPT EXECUTION START: AmorphousPrism.astro ---");
  // Log DOM element availability
  console.log("Canvas element exists:", !!document.getElementById('morphing-poly-canvas'));
  console.log("Firefox container exists:", !!document.getElementById('firefox-webgl-container'));
  console.log("Cursor glow exists:", !!document.getElementById('cursor-glow'));
  
  // Check THREE.js availability
  console.log("THREE.js available:", typeof THREE !== 'undefined');
  if (typeof THREE !== 'undefined') {
    console.log("THREE.js version:", THREE.REVISION);
  }
</script>

<style>
  /* Essential styling for canvas */
  #morphing-poly-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 5;
    opacity: 1;
    touch-action: none;
    cursor: grab;
    backface-visibility: hidden;
    transform: translateZ(0);
    background: rgba(5,3,10,0.2);
    image-rendering: crisp-edges;
    pointer-events: auto !important;
  }
  
  /* Firefox-specific fixes */
  @-moz-document url-prefix() {
    #morphing-poly-canvas {
      image-rendering: -moz-crisp-edges;
    }
  }
  
  /* Critical z-index rules to ensure text visibility */
  :global(.splash-content) {
    z-index: 1000 !important;
    position: relative !important;
  }
  
  :global(.title-word),
  :global(.digital-solutions-text),
  :global(.transforming-text) {
    z-index: 1001 !important;
    position: relative !important;
  }
  
  /* Stronger shadows for better contrast against the 3D visualization */
  :global(.digital-solutions-text) {
    text-shadow: 
      0 0 30px rgba(0, 255, 170, 1),
      0 0 60px rgba(0, 255, 170, 0.8),
      0 0 90px rgba(0, 255, 170, 0.6),
      0 0 15px rgba(0, 0, 0, 0.9) !important; /* Dark shadow for contrast */
  }
  
  :global(.title-word) {
    text-shadow: 
      0 0 30px rgba(0, 255, 170, 1),
      0 0 60px rgba(129, 98, 255, 0.8),
      0 0 15px rgba(0, 0, 0, 0.9) !important; /* Dark shadow for contrast */
  }
  
  :global(.transforming-text) {
    text-shadow: 
      0 0 20px rgba(255, 255, 255, 1),
      0 0 40px rgba(255, 255, 255, 0.7),
      0 0 15px rgba(0, 0, 0, 0.8) !important; /* Dark shadow for contrast */
  }
</style>
