---
// src/components/MorphingPolyhedron.astro - Morphing intricate geometry visualization
---

<!-- Force-enable WebGL and add proper content type -->
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta http-equiv="Content-Type" content="text/html; charset=utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">

<!-- Hardware acceleration hints -->
<style>
  /* Force hardware acceleration */
  html, body {
    transform: translateZ(0);
    backface-visibility: hidden;
    perspective: 1000;
    -webkit-font-smoothing: antialiased;
  }

  /* Force GPU acceleration for smoother performance */
  canvas {
    transform: translateZ(0);
    will-change: transform;
    backface-visibility: hidden;
    touch-action: none !important; /* Prevent browser touch gestures */
  }
  
  /* Make sure mobile touch works well */
  @media (max-width: 768px) {
    canvas {
      touch-action: none !important;
      -webkit-overflow-scrolling: touch;
    }
  }
</style>

<!-- Canvas with WebGL-optimized attributes -->
<canvas id="morphing-poly-canvas" class="absolute top-0 left-0 w-full h-full morphing-poly-canvas" 
  width="800" height="600"
  style="pointer-events: auto !important; z-index: 50; touch-action: none !important; cursor: grab; opacity: 1; backface-visibility: hidden; transform: translateZ(0); will-change: transform; background: rgba(5,3,10,0.2);" 
  data-interactive="true" data-priority="highest" tabindex="0"></canvas>

<!-- Force element to remain visible -->
<style>
  /* Target both original and fallback canvas IDs */
  #morphing-poly-canvas,
  #morphing-poly-canvas-fallback {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 50;
    opacity: 1;
    touch-action: none;
    cursor: grab;
    backface-visibility: hidden;
    transform: translateZ(0);
    will-change: transform;
    background: rgba(5,3,10,0.2);
    image-rendering: crisp-edges;
    pointer-events: auto !important;
  }

  .morphing-poly-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 50;
    opacity: 1;
    image-rendering: crisp-edges;
  }

  @-moz-document url-prefix() {
    #morphing-poly-canvas,
    #morphing-poly-canvas-fallback,
    .morphing-poly-canvas {
      image-rendering: -moz-crisp-edges;
      will-change: transform;
    }
  }

  /* Canvas container for WebGL */
  .sacred-geometry-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 25;
  }

  .loading-indicator {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #0a0a1a;
    z-index: 10;
    width: 100%;
    height: 100%;
  }
</style>

<!-- Firefox WebGL fallback container -->
<div id="firefox-webgl-container" class="absolute top-0 left-0 w-full h-full" style="z-index: 999;"></div>

<!-- Loading indicator (unchanged) -->
<div id="morphing-poly-loading" class="absolute inset-0 flex items-center justify-center bg-[#0a0a1a] z-10" style="display: block; position: fixed; width: 100%; height: 100%;">
  <div class="flex flex-col items-center">
    <div class="w-16 h-16 border-4 border-t-[#ff00ff] border-r-transparent border-b-[#00ffff] border-l-transparent rounded-full animate-spin"></div>
    <p class="mt-6 text-white/80 text-base">Conjuring geometric realms...</p>
  </div>
</div>

<!-- Preload Three.js dependency to improve loading time -->
<link rel="modulepreload" href="https://cdn.jsdelivr.net/npm/three@0.154.0/build/three.module.js" as="script" fetchpriority="high" crossorigin="anonymous" />

<script>
  // TypeScript declarations to fix linter errors
  interface Window {
    __AMORPHOUS_PRISM_LOADING?: boolean;
    __THREE_LOADING_TRACKED?: boolean;
    THREE?: any;
    __FIREFOX_WEBGL2_HELPER?: (canvas: HTMLCanvasElement) => WebGL2RenderingContext | null;
    removeWebGLErrorMessage?: () => void;
    prismaticScene?: any;
    applyPrismRotation?: (deltaX: number, deltaY: number) => boolean;
  }

  interface WebGLRendererOptions {
    canvas: HTMLCanvasElement;
    antialias?: boolean;
    alpha?: boolean;
    preserveDrawingBuffer?: boolean;
    powerPreference?: string;
    context?: WebGLRenderingContext | WebGL2RenderingContext;
  }

  // Fix for THREE.js uniform value typing
  interface UniformValue {
    value: any;
    [key: string]: any;
  }

  // Fix for requestAnimationFrame typing
  let animationId: number | null = null;

  // Ensure we have exclusive ownership of the THREE global
  if (window.__AMORPHOUS_PRISM_LOADING) {
    console.log("AmorphousPrism already loading, skipping duplicate initialization");
  } else {
    // Mark as loading to prevent duplicate initialization
    window.__AMORPHOUS_PRISM_LOADING = true;
    
    // Create a temporary THREE placeholder to prevent "THREE is not defined" errors
    // This will be replaced with the actual THREE library when loaded
    if (!window.THREE) {
      console.log("Setting up THREE placeholder until library loads");
      window.THREE = {
        // Provide minimal stubs for commonly used properties/methods
        Vector3: function() { return {x: 0, y: 0, z: 0}; },
        Color: function() { return {r: 0, g: 0, b: 0}; },
        Texture: function() { return {}; },
        // Add a flag to identify this as a placeholder
        __isPlaceholder: true
      };
    }

    // Use dynamic imports
    let THREE;
    let createNoise4D;
    let isLoading = true;
    let isMobile = window.innerWidth < 768;

    // Check if THREE is already being tracked by the main layout
    const isThreeTracked = window.__THREE_LOADING_TRACKED === true;

    // Load dependencies with multiple fallback options
    const loadDependencies = async () => {
      try {
        console.log("Loading dependencies - first attempt...");
        
        // Check if THREE is already properly loaded in window
        if (window.THREE && !window.THREE.__isPlaceholder) {
          console.log("Using existing THREE instance - avoiding duplicate import");
          THREE = window.THREE;
          
          // Just need to load simplex-noise
          try {
            const simplexNoiseModule = await import('https://cdn.jsdelivr.net/npm/simplex-noise@4.0.1/dist/esm/simplex-noise.js');
            createNoise4D = simplexNoiseModule.createNoise4D;
            console.log("Simplex noise loaded separately");
          } catch (noiseError) {
            console.warn("Failed to load simplex-noise, using fallback:", noiseError);
            createNoise4D = () => {
              return (x, y, z, w) => Math.sin(x + y + z + w) * 0.5 + 0.5;
            };
          }
          
          // Still dispatch threeReady event for compatibility with other scripts
          if (!isThreeTracked) {
            window.dispatchEvent(new CustomEvent('threeReady', { detail: { THREE } }));
          }
          isLoading = false;
          return { THREE, createNoise4D };
        }
        
        // Otherwise load everything
        try {
          const threeModule = await import('https://cdn.jsdelivr.net/npm/three@0.154.0/build/three.module.js');
          const THREE = threeModule.default || threeModule;
          const simplexNoiseModule = await import('https://cdn.jsdelivr.net/npm/simplex-noise@4.0.1/dist/esm/simplex-noise.js');
          const createNoise4D = simplexNoiseModule.createNoise4D;
          console.log("Dependencies loaded from CDN successfully");
          
          // Make THREE globally available after loading
          window.THREE = THREE;
          delete window.THREE.__isPlaceholder;
          window.dispatchEvent(new CustomEvent('threeReady', { detail: { THREE } }));
          isLoading = false;
          return { THREE, createNoise4D };
        } catch (cdnError) {
          console.warn("Failed to load from CDN, trying unpkg fallback:", cdnError);
          
          // Try unpkg as fallback
          const threeModule = await import('https://unpkg.com/three@0.154.0/build/three.module.js');
          const THREE = threeModule.default || threeModule;
          const simplexNoiseModule = await import('https://unpkg.com/simplex-noise@4.0.1/dist/esm/simplex-noise.js');
          const createNoise4D = simplexNoiseModule.createNoise4D;
          console.log("Dependencies loaded from unpkg fallback");
          
          // Make THREE globally available after loading
          window.THREE = THREE;
          delete window.THREE.__isPlaceholder;
          window.dispatchEvent(new CustomEvent('threeReady', { detail: { THREE } }));
          isLoading = false;
          return { THREE, createNoise4D };
        }
      } catch (error) {
        console.error("Error loading dependencies:", error);
        
        // Last-resort fallback - try to use any existing THREE instance
        if (window.THREE && !window.THREE.__isPlaceholder) {
          console.log("Using existing THREE instance as fallback");
          const THREE = window.THREE;
          // Create a simple noise function since we couldn't load simplex-noise
          const createNoise4D = () => {
            return (x, y, z, w) => Math.sin(x + y + z + w) * 0.5 + 0.5;
          };
          window.dispatchEvent(new CustomEvent('threeReady', { detail: { THREE } }));
          isLoading = false;
          return { THREE, createNoise4D };
        }
        
        throw error;
      }
    };

    // Create particle texture function (unchanged)
    function createCircleTexture(THREE, size = 128) {
        // ... (keep the exact same function as before)
        const canvas = document.createElement('canvas');
        canvas.width = size; canvas.height = size;
        const ctx = canvas.getContext('2d');
        if (!ctx) return new THREE.Texture(); // Return blank if no context

        ctx.clearRect(0, 0, size, size);
        const gradient = ctx.createRadialGradient(size/2, size/2, 0, size/2, size/2, size/2);
        gradient.addColorStop(0, 'rgba(255,255,255,1)');
        gradient.addColorStop(0.5, 'rgba(255,255,255,0.5)');
        gradient.addColorStop(1, 'rgba(255,255,255,0)');
        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, size, size);

        const texture = new THREE.CanvasTexture(canvas);
        texture.generateMipmaps = false;
        texture.minFilter = THREE.LinearFilter;
        texture.magFilter = THREE.LinearFilter;
        texture.format = THREE.RGBAFormat;
        texture.needsUpdate = true;
        return texture;
    }

    // Function to add barycentric coordinates to geometry
    function addBarycentricCoordinates(geometry, THREE) {
        const count = geometry.attributes.position.count;
        const barycentric = new Float32Array(count * 3);

        for (let i = 0; i < count; i++) {
            const i3 = i * 3;
            const indexInTriangle = i % 3; // 0, 1, or 2

            if (indexInTriangle === 0) { // First vertex of triangle
                barycentric[i3 + 0] = 1.0;
                barycentric[i3 + 1] = 0.0;
                barycentric[i3 + 2] = 0.0;
            } else if (indexInTriangle === 1) { // Second vertex
                barycentric[i3 + 0] = 0.0;
                barycentric[i3 + 1] = 1.0;
                barycentric[i3 + 2] = 0.0;
            } else { // Third vertex
                barycentric[i3 + 0] = 0.0;
                barycentric[i3 + 1] = 0.0;
                barycentric[i3 + 2] = 1.0;
            }
        }
        geometry.setAttribute('a_barycentric', new THREE.BufferAttribute(barycentric, 3));
        console.log("Barycentric coordinates added to base geometry.");
    }


    document.addEventListener('DOMContentLoaded', async () => {
      console.log("Morphing Sacred Geometry initialization started");

      const loadingIndicator = document.getElementById('morphing-poly-loading');
      const canvas = document.getElementById('morphing-poly-canvas');

      if (!canvas) {
          console.error("Canvas element #morphing-poly-canvas not found!");
          if(loadingIndicator) loadingIndicator.style.display = 'none';
          return;
      }

      // Add WebGL debugging
      try {
        // Test WebGL availability
        const testContext = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
        if (!testContext) {
          console.error("🚨 WebGL NOT SUPPORTED in this browser!");
          const msg = document.createElement('div');
          msg.style.position = 'fixed';
          msg.style.top = '50%';
          msg.style.left = '50%';
          msg.style.transform = 'translate(-50%, -50%)';
          msg.style.backgroundColor = 'rgba(0,0,0,0.8)';
          msg.style.color = 'red';
          msg.style.padding = '20px';
          msg.style.borderRadius = '5px';
          msg.style.zIndex = '9999';
          msg.innerText = 'WebGL not supported in your browser. Please try Chrome or Firefox.';
          document.body.appendChild(msg);
        } else {
          console.log("✅ WebGL is supported in this browser");
          
          // Check for WebGL extensions
          const extensions = {
            standard: [
              'ANGLE_instanced_arrays',
              'EXT_blend_minmax',
              'OES_element_index_uint',
              'OES_standard_derivatives',
              'OES_texture_float',
              'WEBGL_debug_renderer_info'
            ],
            extra: [
              'OES_texture_float_linear',
              'OES_texture_half_float',
              'WEBGL_depth_texture'
            ]
          };
          
          console.log("📊 WebGL Info:", {
            renderer: testContext.getParameter(testContext.getExtension('WEBGL_debug_renderer_info')?.UNMASKED_RENDERER_WEBGL || 0) || 'Unknown',
            vendor: testContext.getParameter(testContext.getExtension('WEBGL_debug_renderer_info')?.UNMASKED_VENDOR_WEBGL || 0) || 'Unknown',
            standardExtensions: extensions.standard.map(ext => ({
              name: ext,
              supported: !!testContext.getExtension(ext)
            })),
            extraExtensions: extensions.extra.map(ext => ({
              name: ext,
              supported: !!testContext.getExtension(ext)
            }))
          });
        }
      } catch (e) {
        console.error("🚨 Error checking WebGL support:", e);
      }

      // Hide loading indicator sooner (optional, but might feel faster)
      if (loadingIndicator) {
        loadingIndicator.style.display = 'none';
        console.log("Loading indicator hidden.");
      }

      try {
        console.log("Starting dependency load...");
        // Directly await the dependency loading here
        const { THREE, createNoise4D } = await loadDependencies();
        console.log("Dependencies finished loading.");

        // After THREE is loaded (line 52)
        console.log("THREE.js version:", THREE.REVISION);

        // Check if WebGL is available before trying to create a renderer
        function isWebGLAvailable() {
          try {
            const canvas = document.createElement('canvas');
            return !!(window.WebGLRenderingContext && 
              (canvas.getContext('webgl') || canvas.getContext('experimental-webgl')));
          } catch(e) {
            return false;
          }
        }

        // --- Now THREE is guaranteed to be available for the rest of the setup ---
        console.log("Starting THREE.js setup...");
        console.log("WebGL Support Check:", isWebGLAvailable() ? "WebGL IS SUPPORTED" : "!!! WebGL NOT SUPPORTED !!!");

        // --- Configuration ---
         const colors = {
            background: new THREE.Color("#05030d"), // Even darker background
            shape1: new THREE.Color("#ff00ff"),     // Magenta / Fuchsia
            shape2: new THREE.Color("#00ffff"),     // Cyan / Aqua
            wireframe: new THREE.Color("#ffffff"),  // Bright white wireframe
            particle1: new THREE.Color("#cc00ff"),  // Vivid purple particle
            particle2: new THREE.Color("#00ccff")   // Vivid blue particle
        };

        const morphInterval = 3000; // 3 seconds per morph
        const holdDuration = 1000; // Hold shape for 1 second
        const autoRotateSpeed = 0.0015; // Slightly faster auto-rotate
        const userRotationSpeed = isMobile ? 0.007 : 0.005;
        const dampingFactor = 0.94; // Slightly less damping
        const minVelocityThreshold = 0.00005;
        // const noise4D = createNoise4D(); // Keep if using noise in shader

        // --- Core THREE.js Setup ---
        const scene = new THREE.Scene();
        scene.background = colors.background;
        const clock = new THREE.Clock(); // Use clock for shader time

        const fov = isMobile ? 60 : 55;
        const camera = new THREE.PerspectiveCamera(fov, window.innerWidth / window.innerHeight, 0.1, 100);
        camera.position.z = isMobile ? 4.8 : 4.2;

        // Use let instead of const so we can reassign if needed for fallback
        let canvas = document.getElementById('morphing-poly-canvas');

        if (!canvas) {
            console.error("Canvas element #morphing-poly-canvas not found!");
            if(loadingIndicator) loadingIndicator.style.display = 'none';
            return;
        }

        // Try to create the renderer with various fallback options
        let renderer;
        const isFirefox = navigator.userAgent.indexOf('Firefox') !== -1;
        
        try {
          // First attempt - standard settings
          console.log('Creating WebGLRenderer - first attempt');
          
          // Use Firefox helper for WebGL2 if available (from firefox-webgl-fix.js)
          let rendererOptions = {
            canvas: canvas,
            antialias: !isFirefox, // Disable antialiasing in Firefox
            alpha: true,
            preserveDrawingBuffer: isFirefox, // Needed for Firefox
            powerPreference: 'high-performance'
          };
          
          // For Firefox, try to use the helper function if available
          if (isFirefox && window.__FIREFOX_WEBGL2_HELPER) {
            console.log('Using Firefox WebGL2 helper');
            const webgl2Context = window.__FIREFOX_WEBGL2_HELPER(canvas);
            if (webgl2Context) {
              rendererOptions.context = webgl2Context;
              console.log('Firefox WebGL2 context created successfully');
            }
          }
          
          renderer = new THREE.WebGLRenderer(rendererOptions);
        } catch (err) {
          console.warn('Initial WebGLRenderer creation failed:', err);
          
          try {
            // Second attempt - minimal settings
            console.log('Creating WebGLRenderer - second attempt with minimal settings');
            renderer = new THREE.WebGLRenderer({
              canvas: canvas,
              antialias: false,
              alpha: true,
              powerPreference: 'default'
            });
          } catch (err2) {
            console.warn('Second WebGLRenderer attempt failed:', err2);
            
            try {
              // Third attempt - different context attributes
              console.log('Creating WebGLRenderer - third attempt with custom context');
              renderer = new THREE.WebGLRenderer({
                canvas: canvas,
                context: canvas.getContext('webgl', {
                  alpha: true,
                  antialias: false,
                  depth: true,
                  failIfMajorPerformanceCaveat: false,
                  premultipliedAlpha: false
                })
              });
            } catch (err3) {
              console.warn('Third WebGLRenderer attempt failed:', err3);
              
              // Final attempt - create a new canvas
              console.log('Final attempt: creating new canvas...');
              try {
                const container = document.querySelector('.sacred-geometry-container') || document.body;
                const newCanvas = document.createElement('canvas');
                newCanvas.width = window.innerWidth;
                newCanvas.height = window.innerHeight;
                newCanvas.className = 'morphing-poly-canvas';
                newCanvas.id = 'morphing-poly-canvas-fallback';
                newCanvas.style.cssText = `
                  position: absolute;
                  top: 0;
                  left: 0;
                  width: 100%;
                  height: 100%;
                  z-index: 50;
                  opacity: 1;
                  touch-action: none;
                  cursor: grab;
                  backface-visibility: hidden;
                  transform: translateZ(0);
                  will-change: transform;
                  background: rgba(5,3,10,0.2);
                  image-rendering: crisp-edges;
                  pointer-events: auto !important;
                `;
                
                if (canvas.parentNode) {
                  canvas.parentNode.replaceChild(newCanvas, canvas);
                } else {
                  container.appendChild(newCanvas);
                }
                
                canvas = newCanvas; // This works now since canvas is let not const
                
                renderer = new THREE.WebGLRenderer({
                  canvas: canvas,
                  antialias: false,
                  alpha: true
                });
                
                // Immediately apply size/aspect updates for the fallback canvas
                if (renderer && canvas.id === 'morphing-poly-canvas-fallback') {
                  console.log("Applying size/aspect updates for fallback canvas...");
                  // Use window dimensions initially, resize handler will refine
                  const width = window.innerWidth;
                  const height = window.innerHeight;
                  renderer.setSize(width, height); 
                  camera.aspect = width / height;
                  camera.updateProjectionMatrix();
                  renderer.setPixelRatio(Math.min(window.devicePixelRatio, isMobile ? 1.5 : 2)); // Reset pixel ratio too
                  console.log(`Fallback canvas resized to ${width}x${height}`);
                  
                  // Dispatch an event to notify other scripts the fallback is active
                  window.dispatchEvent(new CustomEvent('fallbackCanvasCreated', { 
                    detail: { 
                      canvasId: canvas.id,
                      width: width,
                      height: height
                    } 
                  }));
                }
              } catch (err4) {
                console.error('All renderer creation attempts failed:', err4);
                const errorMessage = document.createElement('div');
                errorMessage.className = 'webgl-error';
                errorMessage.style.cssText = 'position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1000; color: red; background-color: black; padding: 20px;';
                errorMessage.textContent = 'Failed to initialize WebGL. Please try a different browser or device.';
                container.appendChild(errorMessage);
                if(loadingIndicator) loadingIndicator.style.display = 'none';
                return;
              }
            }
          }
        }
        
        // If we've made it this far, we have a renderer, so dispatch an event to let other scripts know
        console.log("WebGLRenderer created successfully!");
        
        // Dispatch an event to let other scripts (like webgl-test.js) know the renderer was created successfully
        window.dispatchEvent(new CustomEvent('webglRendererCreated', { 
          detail: { 
            canvas: canvas.id,
            success: true 
          } 
        }));
        
        // If webgl-test showed an error message, try to remove it since we got a working renderer
        if (typeof window.removeWebGLErrorMessage === 'function') {
          window.removeWebGLErrorMessage();
        }
        
        console.log("WebGL Info:", {
          renderer: "Created successfully",
          webglContext: "Context acquired",
          contextAttributes: renderer.getContext().getContextAttributes()
        });
        
        // Add more debugging for renderer
        console.log("Canvas Dimensions:", {
          clientWidth: canvas.clientWidth,
          clientHeight: canvas.clientHeight,
          width: canvas.width,
          height: canvas.height,
          style: canvas.style.cssText
        });
        
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, isMobile ? 1.5 : 2));
        renderer.setClearColor(0x000000, 0);

        // Force hardware acceleration and try different blending mode
        renderer.setSize(window.innerWidth, window.innerHeight, false);  // false = don't update style
        renderer.shadowMap.enabled = false; // disable unnecessary features
        renderer.outputEncoding = THREE.sRGBEncoding || THREE.LinearEncoding; // prefer sRGB if available
        renderer.premultipliedAlpha = true; // try different alpha settings
        
        // Force a redraw by clearing with a visible color then restoring
        renderer.setClearColor(0x7700FF, 0.1);
        renderer.clear();
        renderer.setClearColor(0x000000, 0);
        
        // Log any WebGL errors/warnings
        const gl = renderer.getContext();
        gl?.getExtension('WEBGL_debug_renderer_info');
        const debugInfo = gl?.getExtension('WEBGL_debug_renderer_info');
        if (debugInfo) {
            console.log("GPU INFO:", {
                vendor: gl?.getParameter(debugInfo.UNMASKED_VENDOR_WEBGL),
                renderer: gl?.getParameter(debugInfo.UNMASKED_RENDERER_WEBGL)
            });
        }

        // --- Geometry Setup for Morphing ---
        // 1. Define target shapes (Unchanged)
        const targetGeometries = [
            new THREE.SphereGeometry(1.2, 6, 4),
            new THREE.OctahedronGeometry(1.3, 0),
            new THREE.DodecahedronGeometry(1.4, 0),
            new THREE.SphereGeometry(1.35, 10, 8),
            new THREE.IcosahedronGeometry(1.3, 1)
        ];
        const shapeNames = ["HexSphere", "Octahedron", "Dodecahedron", "DecaSphere", "Icosahedron"];

        // 2. Create Base Geometry (Higher res for smoother morph/wireframe)
        // Ensure the base geometry is NOT indexed, or barycentric logic needs adjustment
        // SphereGeometry is non-indexed by default.
        const baseGeometry = new THREE.SphereGeometry(1.1, 32, 32); // Increased detail slightly
        baseGeometry.morphAttributes.position = [];
        const basePositionAttribute = baseGeometry.attributes.position;

        // 3. Add Barycentric Coordinates BEFORE generating morph targets
         addBarycentricCoordinates(baseGeometry, THREE); // Pass THREE as parameter

        // 4. Generate Morph Target Attributes (Unchanged logic, but uses new base)
        console.log(`Base geometry has ${basePositionAttribute.count} vertices.`);
        const baseVertex = new THREE.Vector3();
        const targetVertex = new THREE.Vector3();

        for (let i = 0; i < targetGeometries.length; i++) {
            const targetGeo = targetGeometries[i];
            const targetPositionAttribute = targetGeo.attributes.position;
            console.log(`Processing target ${shapeNames[i]} with ${targetPositionAttribute.count} vertices.`);
            if (!targetPositionAttribute) { console.error(`Target geo ${shapeNames[i]} lacks position!`); continue; }

            const morphPositions = new Float32Array(basePositionAttribute.count * 3);
            for (let j = 0; j < basePositionAttribute.count; j++) {
                baseVertex.fromBufferAttribute(basePositionAttribute, j);
                let closestDistSq = Infinity; let closestVertexIndex = -1;
                for (let k = 0; k < targetPositionAttribute.count; k++) {
                    targetVertex.fromBufferAttribute(targetPositionAttribute, k);
                    const distSq = baseVertex.distanceToSquared(targetVertex);
                    if (distSq < closestDistSq) { closestDistSq = distSq; closestVertexIndex = k; }
                }
                if (closestVertexIndex !== -1) targetVertex.fromBufferAttribute(targetPositionAttribute, closestVertexIndex);
                else targetVertex.copy(baseVertex); // Fallback
                morphPositions[j * 3] = targetVertex.x;
                morphPositions[j * 3 + 1] = targetVertex.y;
                morphPositions[j * 3 + 2] = targetVertex.z;
