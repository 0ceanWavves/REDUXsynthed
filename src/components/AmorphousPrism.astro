---
// AmorphousPrism.astro - Minimalist loader for the 3D visualization
import LoadingScreen from './LoadingScreen.astro';
---

<!-- New container for both canvas and overlay -->
<div class="canvas-container" style="position: relative; width: 100%; height: 100%; overflow: hidden;">
  <!-- Canvas for Three.js -->
  <canvas id="morphing-poly-canvas" class="absolute top-0 left-0 w-full h-full morphing-poly-canvas"
    style="display: block; width: 100%; height: 100%; pointer-events: auto !important; z-index: 5; cursor: grab; opacity: 1; backface-visibility: hidden; transform: translateZ(0);"
    data-interactive="true" data-priority="highest" tabindex="0">
  </canvas>

  <!-- Firefox WebGL fallback container -->
  <div id="firefox-webgl-container" class="absolute top-0 left-0 w-full h-full" style="z-index: 5;"></div>

  <!-- Cursor glow effect container -->
  <div id="cursor-glow" class="absolute pointer-events-none w-24 h-24 rounded-full opacity-0 transition-opacity duration-300 z-10" style="background: radial-gradient(circle, rgba(120,70,255,0.4) 0%, rgba(120,70,255,0) 70%); transform: translate(-50%, -50%);"></div>

  <!-- START: HTML Content Overlay -->
  <div id="content-overlay">
    <div class="content-wrapper">
      <div class="title-block">
        <span class="title-word">Create</span>
        <span class="title-word">Design</span>
        <span class="title-word">Build</span>
      </div>
      <div class="tagline">
        <p>Transforming ideas into</p>
      </div>
      <div class="services">
        <div class="service-item">Custom Business Applications</div>
        <div class="service-item">Modern Web & Mobile Development</div>
        <div class="service-item">Strategic Technology Consulting</div>
        <div class="service-item">UI/UX Design Excellence</div>
      </div>
      <div class="digital-solutions">
        <h2>Digital Solutions</h2>
      </div>
      <div class="buttons">
        <button class="overlay-button">Our Services</button>
        <button class="overlay-button">Our Process</button>
      </div>
    </div>
  </div>
  <!-- END: HTML Content Overlay -->

</div> <!-- End of canvas-container -->


<!-- Original loading screen (might need adjustment if it covers overlay) -->
<LoadingScreen />

<!-- ADD correct script import -->
<script>
  // Import the CSS for the overlay
  import './AmorphousPrismOverlay.css';
</script>
<!-- Load Three.js fixes before any Three.js code -->
<script is:inline src="/three-fix-loader.js"></script>

<!-- Mobile interaction fix to prevent scroll issues -->
<script is:inline src="/mobile-interaction-fix.js"></script>

<!-- Mobile interaction CSS -->
<link rel="stylesheet" href="/mobile-interaction-fix.css">

<!-- Use script tag with src attribute for public directory scripts -->
<script type="module" src="/scripts/amorphous-prism-init.js"></script>

<!-- Add a canary log script to check if scripts are executing -->
<script is:inline>
  console.log("--- SCRIPT EXECUTION START: AmorphousPrism.astro ---");
  // Log DOM element availability
  console.log("Canvas element exists:", !!document.getElementById('morphing-poly-canvas'));
  console.log("Firefox container exists:", !!document.getElementById('firefox-webgl-container'));
  console.log("Cursor glow exists:", !!document.getElementById('cursor-glow'));
  console.log("Content overlay exists:", !!document.getElementById('content-overlay')); // Check overlay
  
  // Check THREE.js availability
  console.log("THREE.js available:", typeof THREE !== 'undefined');
  if (typeof THREE !== 'undefined') {
    console.log("THREE.js version:", THREE.REVISION);
  }
</script>

<!-- START: GSAP Animation Script -->
<script>
  import { gsap } from "gsap";

  // Function to run the animation
  function animateTitleWords() {
    const titleWords = document.querySelectorAll('.title-word');

    if (titleWords.length > 0) {
      console.log("Animating title words with GSAP...");
      gsap.to(titleWords, {
        opacity: 1,
        y: 0, // Animate transform: translateY(0)
        scale: 1, // Animate transform: scale(1)
        duration: 0.45, // <-- Shorter duration for more impact
        ease: "back.out(1.7)", // Keep or adjust overshoot (1.7)
        stagger: 0.18, // <-- Slightly faster stagger
        delay: 0.5 // Optional delay before the *first* word starts animating
      });
    } else {
      console.warn("Title words not found for animation.");
    }
  }

  // Run the animation (Astro executes component scripts after mount)
  // Add a small delay to ensure styles are fully applied, especially the initial opacity: 0
  setTimeout(animateTitleWords, 100); 

</script>
<!-- END: GSAP Animation Script -->

<style>
  /* Essential styling for canvas */
  #morphing-poly-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 5;
    opacity: 1;
    touch-action: none;
    cursor: grab;
    backface-visibility: hidden;
    transform: translateZ(0);
    background: rgba(5,3,10,0.2);
    image-rendering: crisp-edges;
    pointer-events: auto !important;
  }
  
  /* Firefox-specific fixes */
  @-moz-document url-prefix() {
    #morphing-poly-canvas {
      image-rendering: -moz-crisp-edges;
    }
  }
  
  /* Critical z-index rules to ensure text visibility */
  :global(.splash-content) {
    z-index: 1000 !important;
    position: relative !important;
  }
  
  :global(.title-word),
  :global(.digital-solutions-text),
  :global(.transforming-text) {
    z-index: 1001 !important;
    position: relative !important;
  }
  
  /* Stronger shadows for better contrast against the 3D visualization */
  :global(.digital-solutions-text) {
    text-shadow: 
      0 0 30px rgba(0, 255, 170, 1),
      0 0 60px rgba(0, 255, 170, 0.8),
      0 0 90px rgba(0, 255, 170, 0.6),
      0 0 15px rgba(0, 0, 0, 0.9) !important; /* Dark shadow for contrast */
  }
  
  :global(.title-word) {
    text-shadow: 
      0 0 30px rgba(0, 255, 170, 1),
      0 0 60px rgba(129, 98, 255, 0.8),
      0 0 15px rgba(0, 0, 0, 0.9) !important; /* Dark shadow for contrast */
  }
  
  :global(.transforming-text) {
    text-shadow: 
      0 0 20px rgba(255, 255, 255, 1),
      0 0 40px rgba(255, 255, 255, 0.7),
      0 0 15px rgba(0, 0, 0, 0.8) !important; /* Dark shadow for contrast */
  }

  /* Service items styling */
  .services {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 1.5rem 0;
  }

  .service-item {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.9);
    position: relative;
    padding-left: 1.2rem;
    transition: all 0.3s ease;
  }

  .service-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 0.6rem;
    height: 0.6rem;
    background: linear-gradient(135deg, #7846ff, #00ffaa);
    clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
  }

  .service-item:hover {
    color: #00ffaa;
    transform: translateX(5px);
  }

  /* Tagline styling enhancement */
  .tagline p {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    color: rgba(255, 255, 255, 0.85);
  }
</style>
