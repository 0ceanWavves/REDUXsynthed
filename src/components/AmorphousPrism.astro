        }
        targetGeometries.length = 0;

        // 5. Create Shader Material for Partial Wireframe/Mesh
        const shaderMaterial = new THREE.ShaderMaterial({
            uniforms: {
                uTime: { value: 0.0 },
                uColor1: { value: colors.shape1 },
                uColor2: { value: colors.shape2 },
                uWireframeColor: { value: colors.wireframe },
                uWireframeThickness: { value: isMobile ? 0.05 : 0.03 }, // Increased thickness from 0.018/0.012
                uFaceOpacity: { value: 0.5 }, // Reduced face opacity from 0.65
            },
            vertexShader: `
      // Attributes forwarded from THREE.js
      attribute vec3 a_barycentric; // Our custom attribute

