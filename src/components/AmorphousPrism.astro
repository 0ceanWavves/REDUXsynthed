          event.stopPropagation();
          
          const touch = event.touches[0];
          const deltaX = touch.clientX - previousPointerPosition.x;
          const deltaY = touch.clientY - previousPointerPosition.y;
          
          rotationVelocity.y = deltaX * userRotationSpeed;
          rotationVelocity.x = -deltaY * userRotationSpeed;
          
          previousPointerPosition = { x: touch.clientX, y: touch.clientY };
        }
        
        function onTouchEnd(event) {
          event.preventDefault();
          event.stopPropagation();
          
          isUserInteracting = false;
          canvas.style.cursor = 'grab';
          document.body.style.cursor = '';
          
          setTimeout(() => {
            morphingPausedByUser = false;
            if (morphProgress < 1.0) { lastMorphTime = performance.now() - morphProgress * morphInterval; }
            else { holdStartTime = performance.now(); }
          }, 500);
        }
        
        function onPointerMove(event) {
          if (!isUserInteracting) {
            return;
          }
          
          // Stop propagation to block SplashPrism
          event.stopPropagation();
          
          // Calculate deltas
          const deltaX = event.clientX - previousPointerPosition.x;
          const deltaY = event.clientY - previousPointerPosition.y;
          
          // Update rotation velocity
          rotationVelocity.y = deltaX * userRotationSpeed;
          rotationVelocity.x = -deltaY * userRotationSpeed; // Invert Y
          
          // Update previous position
          previousPointerPosition = { x: event.clientX, y: event.clientY };
        }
        
        function onPointerUp(event) {
          if (!isUserInteracting) {
            return;
          }
          
          // Stop propagation to block SplashPrism
          event.stopPropagation();
          
          // Reset state
          isUserInteracting = false;
          canvas.style.cursor = 'grab';
          document.body.style.cursor = ''; // Reset body cursor

          try {
            // Release pointer capture
            if (canvas.hasPointerCapture && canvas.hasPointerCapture(event.pointerId)) {
              canvas.releasePointerCapture(event.pointerId);
