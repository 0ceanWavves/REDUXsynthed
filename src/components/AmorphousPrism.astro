          setTimeout(() => {
            morphingPausedByUser = false;
            if (morphProgress < 1.0) { lastMorphTime = performance.now() - morphProgress * morphInterval; }
            else { holdStartTime = performance.now(); }
          }, 500);
        }
        console.log(">>> AmorphousPrism: Attaching pointer listeners to:", canvas);
        
        // IMPORTANT: Use capture=true to ensure we get the events before SplashPrism
        canvas.addEventListener('pointerdown', onPointerDown, { capture: true, passive: false });

        // --- Animation loop ---
        function animate() {
          animationId = requestAnimationFrame(animate);
          const elapsedTime = clock.getElapsedTime(); // Use clock for smooth time

          // Update shader time uniform
          shaderMaterial.uniforms.uTime.value = elapsedTime;
          particleMaterial.uniforms.uTime.value = elapsedTime; // Update particle time too

          // Update morphing state
          updateMorphing();

          // Apply rotation velocity with damping (Unchanged)
          rotationVelocity.x *= dampingFactor;
          rotationVelocity.y *= dampingFactor;
          if (Math.abs(rotationVelocity.x) < minVelocityThreshold) rotationVelocity.x = 0;
          if (Math.abs(rotationVelocity.y) < minVelocityThreshold) rotationVelocity.y = 0;

          if (isUserInteracting || rotationVelocity.x !== 0 || rotationVelocity.y !== 0) {
            mesh.rotation.x += rotationVelocity.x;
            mesh.rotation.y += rotationVelocity.y;
          } else {
            mesh.rotation.y += autoRotateSpeed;
            mesh.rotation.x += autoRotateSpeed * 0.3; // Slightly more tilt wobble
          }

           // Subtle particle system rotation (independent?)
           particleSystem.rotation.y -= 0.0003; // Slightly different speed/direction

          // Render scene
          renderer.render(scene, camera);
        }

        // --- Start animation ---
        console.log("Starting animation loop");
        animate();

        // --- Handle window resize (Unchanged) ---
        let resizeTimeout;
        function debounceResize() {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(() => {
                isMobile = window.innerWidth < 768; // Update mobile status on resize
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
                renderer.setPixelRatio(Math.min(window.devicePixelRatio, isMobile ? 1.5 : 2));
                // Update shader uniforms sensitive to screen size/type?
                shaderMaterial.uniforms.uWireframeThickness.value = isMobile ? 0.05 : 0.03;
                console.log("Resized renderer and camera");
            }, 150);
        }
        window.addEventListener('resize', debounceResize, false);


        // --- Handle visibility change (Unchanged) ---
        const handleVisibilityChange = () => {
          if (document.hidden && animationId) {
            cancelAnimationFrame(animationId); animationId = null;
            clock.stop(); // Pause the clock too
            console.log("Animation paused (tab hidden)");
          } else if (!document.hidden && !animationId && mesh) {
            clock.start(); // Resume the clock
            if (morphProgress < 1.0) { lastMorphTime = performance.now() - morphProgress * morphInterval; }
            else { holdStartTime = performance.now(); }
            animate();
            console.log("Animation resumed (tab visible)");
          }
        };
        document.addEventListener('visibilitychange', handleVisibilityChange);

        // --- Cleanup on navigation ---
        document.addEventListener('astro:before-swap', () => {
          console.log("Cleaning up Sacred Geometry component...");
          if (animationId) cancelAnimationFrame(animationId);
          animationId = null;

          document.removeEventListener('visibilitychange', handleVisibilityChange);
          window.removeEventListener('resize', debounceResize);
          clearTimeout(resizeTimeout);

          if (canvas) { // Remove listeners (unchanged)
              canvas.removeEventListener('pointerdown', onPointerDown);
              canvas.removeEventListener('pointermove', onPointerMove);
              canvas.removeEventListener('pointerup', onPointerUp);
              canvas.removeEventListener('pointercancel', onPointerUp);
          }

          // Dispose THREE.js objects (ensure shader material is disposed)
          scene.traverse(object => {
               if (object.geometry) object.geometry.dispose();
               if (object.material) {
                  if (Array.isArray(object.material)) {
                      object.material.forEach(mat => {
                          // Dispose textures in uniforms if they exist
                          Object.values(mat.uniforms || {}).forEach(uniform => {
                              if (uniform && uniform.value instanceof THREE.Texture) {
                                  uniform.value.dispose();
                              }
                          });
                          mat.dispose();
                      });
                  } else {
                       // Dispose textures in uniforms
                       Object.values(object.material.uniforms || {}).forEach(uniform => {
                          if (uniform && uniform.value instanceof THREE.Texture) {
                              uniform.value.dispose();
                          }
                      });
                       object.material.dispose(); // Dispose the material itself
                  }
               }
          });
          if (particleTexture) particleTexture.dispose(); // Explicit dispose just in case

          if (renderer) renderer.dispose();
          console.log("Sacred Geometry cleanup complete.");
        }, { once: true });

        console.log("Sacred Geometry initialization completed.");

      } catch (error) {
        console.error("Error in Sacred Geometry initialization:", error);
        // Ensure loading indicator is hidden on error even if it wasn't before
        if (loadingIndicator && loadingIndicator.style.display !== 'none') {
          loadingIndicator.style.display = 'none';
        }
      }
    });
  }
