      varying vec3 vBarycentric;
      varying vec3 vNormal;
      varying vec3 vWorldPosition;
      // varying float vMorphEffect; // REMOVED - No longer needed

      // Uniforms
      uniform float uTime;

      // Include standard THREE.js chunks (Order Matters!)
      #include <common>
      #include <uv_pars_vertex>
      #include <displacementmap_pars_vertex>
      #include <morphtarget_pars_vertex> // <<< Needs to be included
      #include <skinning_pars_vertex>
      #include <logdepthbuf_pars_vertex>
      #include <clipping_planes_pars_vertex>

      void main() {
          vBarycentric = a_barycentric; // Pass barycentric coords

          // --- Start Standard Calculations ---
          // Calculate the base normal (before morphing)
          #include <beginnormal_vertex>      // <<< IMPORTANT STANDARD CHUNK
          #include <morphnormal_vertex>      // <<< Calculates morphedNormal/transformedNormal variable
          #include <skinbase_vertex>
          #include <skinnormal_vertex>
          #include <defaultnormal_vertex>    // <<< Assigns final normal attribute

          // Calculate the base position (before morphing/skinning)
          #include <begin_vertex>            // <<< IMPORTANT STANDARD CHUNK (Initializes 'transformed')

          // Apply morph targets to 'transformed'
          #include <morphtarget_vertex>      // <<< Modifies 'transformed'

          // Apply skinning to 'transformed'
          #include <skinning_vertex>

          // Apply displacement map
          #include <displacementmap_vertex>

          // Calculate final projected position
          #include <project_vertex>          // <<< Calculates gl_Position from 'transformed'

          // Handle depth buffer and clipping
          #include <logdepthbuf_vertex>
          #include <clipping_planes_vertex>

          // --- Pass required data to Fragment Shader ---
          // Use 'transformedNormal' calculated by the includes
          vNormal = normalize(transformedNormal); // <<< USE THE CORRECT MORPHED NORMAL

          // Use 'transformed' position after morphing etc. for world position
          vec4 worldPosition_ = modelMatrix * vec4( transformed, 1.0 ); // <<< USE THE CORRECT MORPHED POSITION
          vWorldPosition = worldPosition_.xyz;

          #include <uv_vertex> // Pass UVs if needed
      }
  `,
            fragmentShader: `
                // Request OES_standard_derivatives extension for fwidth (required for wireframe)
                #extension GL_OES_standard_derivatives : enable

                // Varyings received from Vertex Shader
                varying vec3 vBarycentric;
                varying vec3 vNormal;
                varying vec3 vWorldPosition;

                // Uniforms
                uniform float uTime;
                uniform vec3 uColor1; // Primary face color
                uniform vec3 uColor2; // Secondary face color
                uniform vec3 uWireframeColor;
                uniform float uWireframeThickness;
                uniform float uFaceOpacity;

                // Manual implementation of fwidth in case extension is not available
                vec3 calculateFwidth(vec3 value) {
                    #ifdef GL_OES_standard_derivatives
                        return fwidth(value);
                    #else
                        // Fallback approximation (not as accurate but works)
                        return vec3(0.02); // Fixed width value that works reasonably well
                    #endif
                }

                // Function to calculate edge factor using barycentric coordinates
                float edgeFactor(float thickness){
                    // Calculate derivatives for screen-space thickness using our safe function
                    vec3 d = calculateFwidth(vBarycentric);
                    // Calculate smoothed minimum distance to edge
                    vec3 a3 = smoothstep(vec3(0.0), d * (1.0 + thickness * 20.0), vBarycentric); // Increase multiplier for sharper edges
                    // The factor is 1.0 on edges, 0.0 in the center
                    return clamp(1.0 - min(min(a3.x, a3.y), a3.z), 0.0, 1.0);
                }

                // Simple noise function (replace with Simplex/Perlin if needed)
                float hash( float n ) { return fract(sin(n)*43758.5453); }
                float noise( vec3 x ) {
                    vec3 p = floor(x); vec3 f = fract(x);
                    f = f*f*(3.0-2.0*f);
                    float n = p.x + p.y*57.0 + 113.0*p.z;
                    return mix(mix(mix( hash(n+0.0), hash(n+1.0),f.x),
                                 mix( hash(n+57.0), hash(n+58.0),f.x),f.y),
                                 mix(mix( hash(n+113.0), hash(n+114.0),f.x),
                                     mix( hash(n+170.0), hash(n+171.0),f.x),f.y),f.z);
                }

                void main() {
                    float edge = edgeFactor(uWireframeThickness);

                    // --- Calculate Face Color ---
                    // Mix base colors based on normal and add subtle noise
                    float normalMix = smoothstep(-0.5, 0.8, vNormal.y); // Mix based on vertical normal
                    float timeBasedMix = sin(uTime * 0.5 + vWorldPosition.y * 2.0) * 0.5 + 0.5; // Slow sine wave mix
                    vec3 baseFaceColor = mix(uColor1, uColor2, normalMix * 0.6 + timeBasedMix * 0.4);

                    // Add subtle noise pattern based on world position and time
                    float n = noise(vWorldPosition * 1.5 + uTime * 0.1);
                    vec3 noisyColor = mix(baseFaceColor * 0.8, baseFaceColor * 1.2, n);

                    // Modulate color slightly during morphing transitions
                    vec3 faceColor = noisyColor;


                    // --- Combine Wireframe and Face ---
                    vec3 finalColor = mix(faceColor, uWireframeColor, edge * 1.5); // Increased edge emphasis

                    // --- Calculate Opacity ---
                    // Make faces partially transparent, wireframe mostly opaque
                    float finalOpacity = mix(uFaceOpacity, 1.0, edge * 1.5); // Increased edge opacity
                    // Fade out if looking edge-on (optional)
                    float fresnel = pow(1.0 - abs(dot(vNormal, vec3(0.0, 0.0, 1.0))), 2.0); // View direction assumed (0,0,1), reduced power
                    finalOpacity *= mix(1.0, 0.3, fresnel * (1.0 - edge)); // Fade faces more than wireframe


                    gl_FragColor = vec4(finalColor, finalOpacity);

                    // Premultiplied Alpha blending is often better for transparency
                     gl_FragColor.rgb *= finalOpacity;

                    #include <tonemapping_fragment> // Apply tone mapping
                    #include <colorspace_fragment> // Apply color space correction (like linearTosRGB)
                }
            `,
            transparent: true, // MUST be true for opacity effects
            side: THREE.DoubleSide, // Render both sides for a more robust wireframe effect
            // blending: THREE.AdditiveBlending, // Could try Additive for a glowier look, but Normal is safer
            depthWrite: false, // Often needed with transparency, especially complex shapes
            extensions: {
                derivatives: true, // Explicitly request OES_standard_derivatives extension
                fragDepth: false,
                drawBuffers: false,
                shaderTextureLOD: false
            }
        });
        
        // DEBUG: Print vertex shader code to verify it's correct
        console.log("Using Vertex Shader:\n", shaderMaterial.vertexShader);

        // 6. Create the Mesh (using the ShaderMaterial)
        const mesh = new THREE.Mesh(baseGeometry, shaderMaterial);
        mesh.name = "sacredGeometryMesh"; // Assign a unique name for external reference
        mesh.morphTargetInfluences = new Array(baseGeometry.morphAttributes.position.length).fill(0);
        // shaderMaterial.uniforms.morphTargetInfluences.value = mesh.morphTargetInfluences; // Link if needed
        scene.add(mesh);

        // --- Edges and Glow REMOVED --- No longer needed!

        // --- Particle System (Keep, adjust colors maybe) ---
        const particleCount = isMobile ? 400 : 600; // Slightly more particles
        const particleGeometry = new THREE.BufferGeometry();
        const positions = new Float32Array(particleCount * 3);
        const colorsAttrib = new Float32Array(particleCount * 3);
        const sizes = new Float32Array(particleCount);
        const particleTexture = createCircleTexture(THREE);
        const atmosphereRadius = isMobile ? 3.0 : 3.5; // Slightly larger radius

        for (let i = 0; i < particleCount; i++) {
            const i3 = i * 3;
            // Spread particles more evenly on sphere surface (Fibonacci sphere / Golden angle)
            const y = 1 - (i / (particleCount - 1)) * 2; // y goes from 1 to -1
            const radius = Math.sqrt(1 - y * y) * atmosphereRadius * (0.8 + Math.random() * 0.4);
            const theta = (Math.PI * (3. - Math.sqrt(5.))) * i; // Golden angle increment

            positions[i3] = radius * Math.cos(theta);
            positions[i3 + 1] = y * atmosphereRadius * (0.8 + Math.random() * 0.4); // Add randomness to Y radius too
            positions[i3 + 2] = radius * Math.sin(theta);

            const lerpFactor = Math.random(); // Use random mix
            const color = new THREE.Color().lerpColors(colors.particle1, colors.particle2, lerpFactor);
            colorsAttrib[i3] = color.r; colorsAttrib[i3 + 1] = color.g; colorsAttrib[i3 + 2] = color.b;
            sizes[i] = isMobile ? (0.08 + Math.random() * 0.18) : (0.05 + Math.random() * 0.15); // Slightly larger/more varied
        }

        particleGeometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        particleGeometry.setAttribute('color', new THREE.BufferAttribute(colorsAttrib, 3));
        particleGeometry.setAttribute('size', new THREE.BufferAttribute(sizes, 1));

        const particleMaterial = new THREE.ShaderMaterial({
            uniforms: {
                uTime: { value: 0.0 },
                pointTexture: { value: particleTexture }
            },
            vertexShader: `
                attribute float size;
                varying vec3 vColor;
                uniform float uTime;
                void main() {
                    vColor = color;
                    vec3 pos = position;
                    // More dynamic movement - swirl + pulse
                    float angle = atan(pos.x, pos.z) + uTime * 0.2;
                    float radius = length(pos.xz);
                    pos.x = cos(angle) * radius + sin(pos.y * 1.5 + uTime * 0.6) * 0.1;
                    pos.z = sin(angle) * radius + cos(pos.x * 1.5 + uTime * 0.5) * 0.1;
                    pos.y += sin(length(position) * 0.5 + uTime * 0.7) * 0.15; // Pulse in/out slightly

                    vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
                    gl_PointSize = size * (400.0 / -mvPosition.z); // Adjust sizing maybe
                    gl_Position = projectionMatrix * mvPosition;
                }
            `,
            fragmentShader: `
                uniform sampler2D pointTexture;
                varying vec3 vColor;
                void main() {
                    float alpha = texture2D(pointTexture, gl_PointCoord).a;
                    if (alpha < 0.05) discard; // Harder edge discard
                    gl_FragColor = vec4(vColor, alpha * 0.9); // Slightly less intense alpha
                }
            `,
            blending: THREE.AdditiveBlending,
            depthWrite: false,
            transparent: true,
            vertexColors: true
        });

        const particleSystem = new THREE.Points(particleGeometry, particleMaterial);
        scene.add(particleSystem);

        // --- Lighting (Less crucial with ShaderMaterial, but good for particles) ---
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.8); // Increased intensity from 0.5
        scene.add(ambientLight);

        // Maybe one subtle directional light to give particles some directionality
        const directionalLight = new THREE.DirectionalLight(colors.shape1, 0.7); // Increased intensity from 0.4
        directionalLight.position.set(3, 2, 3);
        scene.add(directionalLight);
        const directionalLight2 = new THREE.DirectionalLight(colors.shape2, 0.7); // Increased intensity from 0.4
        directionalLight2.position.set(-3, -2, -3);
        scene.add(directionalLight2);


        // --- Animation & Morphing State (Unchanged logic) ---
        let currentShapeIndex = 0;
        let targetShapeIndex = 1;
        let morphProgress = 0;
        let isMorphing = true;
        let lastMorphTime = performance.now();
        let holdStartTime = 0;
        let morphingPausedByUser = false;

        // --- User Interaction State (Unchanged) ---
        const rotationVelocity = { x: 0, y: 0 };
        let isUserInteracting = false;
        let previousPointerPosition = { x: 0, y: 0 };

        // --- Morphing Update Function (Unchanged logic, affects mesh.morphTargetInfluences) ---
        function updateMorphing() {
          if (!isMorphing || morphingPausedByUser) return;
          const now = performance.now();
          const influences = mesh.morphTargetInfluences;
          if (!influences) return;

          if (morphProgress === 1.0) {
              if (holdStartTime === 0) { holdStartTime = now; }
              if (now - holdStartTime > holdDuration) {
                  currentShapeIndex = targetShapeIndex;
                  targetShapeIndex = (targetShapeIndex + 1) % influences.length;
                  morphProgress = 0;
                  lastMorphTime = now;
                  holdStartTime = 0;
                   console.log(`Morphing to: ${shapeNames[targetShapeIndex]}`);
              } else { return; } // Still holding
          }

          if (morphProgress < 1.0) {
              let morphElapsedTime = now - lastMorphTime;
              morphProgress = Math.min(1.0, morphElapsedTime / morphInterval);
          }
          const easedProgress = 0.5 - 0.5 * Math.cos(morphProgress * Math.PI);

          for (let i = 0; i < influences.length; i++) { influences[i] = 0; }
          influences[currentShapeIndex] = 1 - easedProgress;
          influences[targetShapeIndex] = easedProgress;

          // Update shader uniform if needed (optional, vMorphEffect tries to derive it)
          // shaderMaterial.uniforms.uMorphProgress.value = easedProgress;
        }

        // --- User interaction handlers (Unchanged) ---
        function onPointerDown(event) {
          console.log(">>> AmorphousPrism: Pointer Down Fired <<<", {
            target: event.target?.id || 'unknown',
            canvas: canvas?.id || 'unknown',
            pointerId: event.pointerId
          });
          
          // IMPORTANT: If this click is not on our canvas, do nothing
          if (!canvas || event.target !== canvas) {
            console.log(">>> AmorphousPrism: IGNORING event - wrong target <<<");
            return;
          }
          
          // Only prevent default on the canvas element to allow page scrolling
          // while still enabling 3D object interaction
          event.preventDefault();
          event.stopPropagation();
          
          isUserInteracting = true;
          morphingPausedByUser = true;
          
          if (canvas) {
            canvas.style.cursor = 'grabbing';
          }
          document.body.style.cursor = 'grabbing'; // Use body cursor too
          
          // Save initial position - handle both mouse and touch events
          if (event.type === 'touchstart') {
            if (event.touches && event.touches[0]) {
              previousPointerPosition = { 
                x: event.touches[0].clientX, 
                y: event.touches[0].clientY 
              };
            }
          } else {
            previousPointerPosition = { x: event.clientX, y: event.clientY };
          }
          
          try {
            // IMPORTANT: Set pointer capture to keep receiving events
            if (canvas) {
              canvas.setPointerCapture(event.pointerId);
              console.log(">>> AmorphousPrism: Pointer capture success <<<");
              
              // Store in window object to expose for other scripts
              window.prismaticScene = {
                onTouchStart: function(coords) {
                  console.log(">>> AmorphousPrism: External touch start <<<", coords);
                  morphingPausedByUser = true;
                },
                onTouchMove: function(coords, deltas) {
                  console.log(">>> AmorphousPrism: External touch move <<<", deltas);
                  rotationVelocity.y = deltas.deltaX * userRotationSpeed;
                  rotationVelocity.x = -deltas.deltaY * userRotationSpeed;
                },
                onTouchEnd: function() {
                  console.log(">>> AmorphousPrism: External touch end <<<");
                  setTimeout(() => {
                    morphingPausedByUser = false;
                  }, 500);
                },
                setInteraction: function(interacting) {
                  isUserInteracting = interacting;
                }
              };
              
              // Add move and up handlers
              canvas.addEventListener('pointermove', onPointerMove, { passive: false });
              canvas.addEventListener('pointerup', onPointerUp, { passive: false });
              canvas.addEventListener('pointercancel', onPointerUp, { passive: false });
              
              // Touch-specific handlers
              canvas.addEventListener('touchstart', onTouchStart, { passive: false });
              canvas.addEventListener('touchmove', onTouchMove, { passive: false });
              canvas.addEventListener('touchend', onTouchEnd, { passive: false });
              canvas.addEventListener('touchcancel', onTouchEnd, { passive: false });
            }
          } catch (err) { 
            console.warn(">>> AmorphousPrism: Pointer capture FAILED <<<", err); 
          }
        }
        
        // Touch-specific handlers to ensure mobile works properly
        function onTouchStart(event) {
          console.log(">>> AmorphousPrism: Touch Start <<<");
          if (!canvas || event.target !== canvas) return;
          
          event.preventDefault();
          event.stopPropagation();
          
          isUserInteracting = true;
          morphingPausedByUser = true;
          canvas.style.cursor = 'grabbing';
          
          if (event.touches && event.touches[0]) {
            previousPointerPosition = { 
              x: event.touches[0].clientX, 
              y: event.touches[0].clientY 
            };
          }
        }
        
