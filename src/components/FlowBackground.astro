---
// FlowBackground.astro - Creates a flowing liquid background effect that matches the prism texture
---

<canvas id="flow-bg-canvas" class="fixed top-0 left-0 w-full h-full z-0" style="opacity: 0.9; pointer-events: none;"></canvas>

<script>
  import * as THREE from 'three';
  import { createNoise4D } from 'simplex-noise';

  document.addEventListener('DOMContentLoaded', () => {
    console.log("FlowBackground initialization started");
    const canvas = document.getElementById('flow-bg-canvas') as HTMLCanvasElement | null;
    if (!canvas) {
      console.error("Canvas element #flow-bg-canvas not found!");
      return;
    }

    // Browser detection for optimizations
    const isFirefox = navigator.userAgent.toLowerCase().indexOf('firefox') > -1;
    const isChrome = navigator.userAgent.toLowerCase().indexOf('chrome') > -1 && 
                    navigator.userAgent.toLowerCase().indexOf('edge') === -1;
    
    console.log('FlowBackground browser detection:', { isFirefox, isChrome });

    // Allow FlowBackground in Firefox for testing, but with significantly reduced quality
    const enableInFirefox = true; // Set to false to completely disable in Firefox
    
    if (isFirefox && !enableInFirefox) {
      console.log("FlowBackground disabled for Firefox");
      // Make canvas fully transparent and disable rendering on Firefox
      canvas.style.display = 'none';
      return;
    }

    // --- Configuration ---
    const colors = {
      background: new THREE.Color("#0a0a1a"), // Dark blue/purple background
      accent1: new THREE.Color("#8162ff"),    // Vibrant purple (changed to match prism)
      accent2: new THREE.Color("#00e599"),    // Brighter teal (changed to match prism)
      accent3: new THREE.Color("#ffffff")     // White for highlights
    };

    // Flow animation parameters - Increased values for more visible effect
    const flowScale = 3.0;      // Scale of flow pattern
    const flowSpeed = isFirefox ? 0.01 : 0.02;  // Slower flow for Firefox
    const cellSize = 6;         // Size of each cell in the grid
    const noiseScale1 = 0.5;    // Primary flow scale
    const noiseScale2 = 0.8;    // Secondary flow scale
    const colorBlend = 0.9;     // Increased for stronger colors

    // --- Setup Canvas Renderer ---
    console.log("Initializing flow background");
    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: !isFirefox,  // Disable antialiasing on Firefox
      premultipliedAlpha: false,  // Important for correct transparency
      powerPreference: 'high-performance'  // Request high-performance GPU
    });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, isFirefox ? 1 : 2));
    renderer.setClearColor(0x000000, 0);
    renderer.setClearAlpha(0);  // Ensure alpha clearing is enabled

    // Log canvas status
    console.log('Flow canvas visibility check:');
    console.log('- Canvas size:', canvas.width, 'x', canvas.height);
    console.log('- Style:', canvas.style.cssText);
    console.log('- Computed style:', 
      'visibility:', window.getComputedStyle(canvas).visibility,
      'display:', window.getComputedStyle(canvas).display,
      'z-index:', window.getComputedStyle(canvas).zIndex
    );

    // --- Create Scene ---
    const scene = new THREE.Scene();
    const camera = new THREE.OrthographicCamera(
      -window.innerWidth / 2, 
      window.innerWidth / 2, 
      window.innerHeight / 2, 
      -window.innerHeight / 2, 
      0.1, 
      1000
    );
    camera.position.z = 10;

    // --- Noise Generator ---
    const noise4D = createNoise4D();
    
    // --- Flow Liquid Plane ---
    // Create a plane with adaptive detail level
    const planeSegments = isFirefox ? 50 : 100; // Reduced from 200, even more for Firefox
    const planeGeometry = new THREE.PlaneGeometry(window.innerWidth, window.innerHeight, planeSegments, planeSegments);
    
    // Custom shader material for the flowing liquid
    const flowMaterial = new THREE.ShaderMaterial({
      transparent: true,
      blending: THREE.NormalBlending,  // Changed from additive to normal blending
      uniforms: {
        time: { value: 0 },
        resolution: { value: new THREE.Vector2(window.innerWidth, window.innerHeight) },
        color1: { value: new THREE.Color(colors.accent1) },
        color2: { value: new THREE.Color(colors.accent2) },
        color3: { value: new THREE.Color(colors.background) },
        colorBlend: { value: colorBlend }
      },
      vertexShader: `
        varying vec2 vUv;
        void main() {
          vUv = uv;
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
        }
      `,
      fragmentShader: `
        uniform float time;
        uniform vec2 resolution;
        uniform vec3 color1;
        uniform vec3 color2;
        uniform vec3 color3;
        uniform float colorBlend;
        varying vec2 vUv;
        
        // Simplified noise function to avoid vec3/vec4 conversion issues
        float hash(float n) { return fract(sin(n) * 1e4); }
        
        float hash(vec2 p) {
          return fract(1e4 * sin(17.0 * p.x + p.y * 0.1) * (0.1 + abs(sin(p.y * 13.0 + p.x))));
        }
        
        float noise(vec2 x) {
          vec2 i = floor(x);
          vec2 f = fract(x);
          float a = hash(i);
          float b = hash(i + vec2(1.0, 0.0));
          float c = hash(i + vec2(0.0, 1.0));
          float d = hash(i + vec2(1.0, 1.0));
          vec2 u = f * f * (3.0 - 2.0 * f);
          return mix(a, b, u.x) + (c - a) * u.y * (1.0 - u.x) + (d - b) * u.x * u.y;
        }
        
        float fbm(vec2 x) {
          float v = 0.0;
          float a = 0.5;
          vec2 shift = vec2(100.0);
          
          // Rotate to reduce axial bias
          mat2 rot = mat2(cos(0.5), sin(0.5), -sin(0.5), cos(0.5));
          
          // Reduced octaves from 5 to 3
          for (int i = 0; i < 3; ++i) {
            v += a * noise(x);
            x = rot * x * 2.0 + shift;
            a *= 0.5;
          }
          return v;
        }
        
        void main() {
          vec2 uv = vUv;
          
          // Time-based animation
          float t = time * 0.2;
          
          // Create flowing liquid effect with multiple noise layers
          vec2 p1 = uv + vec2(0.0, t * 0.1);
          vec2 p2 = uv * 2.5 + vec2(t * 0.15, 0.0);
          
          // Reduced noise layers (removed third layer)
          float noise1 = fbm(p1 * 3.0);
          float noise2 = fbm(p2 * 1.5);
          
          // Combine noise layers - simplified
          float finalNoise = noise1 * 0.6 + noise2 * 0.4;
          finalNoise = (finalNoise * 0.5 + 0.5); // Normalize to 0-1 range
          
          // Create distortion effect
          vec2 distortedUV = uv;
          distortedUV.x += finalNoise * 0.05;
          distortedUV.y += finalNoise * 0.03;
          
          // Final flowing pattern
          float flowPattern = fbm(distortedUV * 4.0 + vec2(t * 0.25, t * 0.15));
          flowPattern = flowPattern * 0.7 + finalNoise * 0.3;
          flowPattern = smoothstep(0.2, 0.8, flowPattern); // Add contrast
          
          // Create color gradient based on noise value
          vec3 color;
          if (flowPattern < 0.4) {
            float t = flowPattern / 0.4;
            color = mix(color3, color2, t * colorBlend);
          } else if (flowPattern < 0.7) {
            float t = (flowPattern - 0.4) / 0.3;
            color = mix(color2, color1, t * colorBlend);
          } else {
            float t = (flowPattern - 0.7) / 0.3;
            color = mix(color1, vec3(1.0), t * 0.7 * colorBlend);
          }
          
          // Add focus effect in center (for prism visibility)
          float distance = length(uv - vec2(0.5));
          
          // Create a larger hole in the center for the prism to be more visible
          float centerHole = smoothstep(0.15, 0.35, distance); 
          
          // Add vignette effect
          float vignette = 1.0 - smoothstep(0.4, 1.1, distance * 1.8);
          color *= vignette;
          
          // Create varying opacity for more ethereal look
          float alpha = centerHole * (0.6 + flowPattern * 0.3) * 0.7; // Reduced overall opacity
          
          gl_FragColor = vec4(color, alpha);
        }
      `
    });

    const flowPlane = new THREE.Mesh(planeGeometry, flowMaterial);
    scene.add(flowPlane);
    
    console.log("Flow background initialized");

    // --- Animation ---
    let time = 0;
    let animationId: number | null = null;
    let frameCount = 0;

    function animate() {
      // Throttle to 30fps to save resources
      frameCount++;
      // More aggressive throttling for Firefox
      if ((isFirefox && frameCount % 3 !== 0) || (!isFirefox && frameCount % 2 !== 0)) {
        animationId = requestAnimationFrame(animate);
        return;
      }
      
      animationId = requestAnimationFrame(animate);

      // Update time for shader
      time += flowSpeed;
      (flowMaterial.uniforms.time as { value: number }).value = time;

      // Render scene
      renderer.render(scene, camera);
    }

    // --- Handle Window Resize ---
    function onWindowResize() {
      const width = window.innerWidth;
      const height = window.innerHeight;

      // Update camera
      camera.left = -width / 2;
      camera.right = width / 2;
      camera.top = height / 2;
      camera.bottom = -height / 2;
      camera.updateProjectionMatrix();

      // Update renderer
      renderer.setSize(width, height);
      
      // Update material uniforms
      (flowMaterial.uniforms.resolution as { value: THREE.Vector2 }).value.set(width, height);
      
      // Instead of recreating geometry, just scale existing plane
      flowPlane.scale.set(width / flowPlane.geometry.parameters.width, 
                          height / flowPlane.geometry.parameters.height, 
                          1);
    }
    window.addEventListener('resize', onWindowResize);

    // --- Pause rendering when not visible ---
    document.addEventListener('visibilitychange', () => {
      if (document.hidden && animationId) {
        cancelAnimationFrame(animationId);
        animationId = null;
      } else if (!document.hidden && !animationId) {
        animate();
      }
    });

    // --- Start Animation ---
    animate();
    console.log("FlowBackground animation started");

    // --- Cleanup ---
    document.addEventListener('astro:before-swap', () => {
      // Clean up resources when navigating away
      if (animationId) cancelAnimationFrame(animationId);
      window.removeEventListener('resize', onWindowResize);
      
      // Dispose THREE.js objects
      planeGeometry.dispose();
      flowMaterial.dispose();
      renderer.dispose();
      console.log("FlowBackground cleaned up");
    });
  });
</script> 