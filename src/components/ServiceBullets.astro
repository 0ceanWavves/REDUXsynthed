---
// ServiceBullets.astro - Component for the crystalline service bullets
import CrystalBulletItem from './CrystalBulletItem.astro';

// Define the service items with updated text to match screenshot
const serviceItems = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-glow">
            <path d="M12 3h7a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-7m0-18H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h7m0-18v18"></path>
          </svg>`,
    text: "Custom Business Applications",
    delay: 0
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-glow">
            <path d="M12 18H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-5l-5 4v-4z"></path>
          </svg>`,
    text: "Modern Web & Mobile Development",
    delay: 1
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-glow">
            <path d="M18 20V10m-6 10V4M6 20v-6"></path>
          </svg>`,
    text: "Strategic Technology Consulting",
    delay: 2
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-glow">
            <rect x="3" y="3" width="18" height="18" rx="2"></rect>
            <circle cx="8.5" cy="8.5" r="1.5"></circle>
            <path d="M20.4 14.5L16 10 4 20"></path>
          </svg>`,
    text: "UI/UX Design Excellence",
    delay: 3
  }
];
---

<div class="service-bullets my-4 mb-8 crystal-container">
  <div class="crystal-background"></div>
  
  {serviceItems.map(item => (
    <CrystalBulletItem
      icon={item.icon}
      text={item.text}
      delay={item.delay}
    />
  ))}
</div>

<style>
  /* Crystal container styling */
  .crystal-container {
    position: relative;
    padding: 1.5rem;
    margin: 2rem 0;
    border-radius: 0.75rem;
    overflow: hidden;
    animation: fadeIn 1s ease-out 3s both;
    /* Adjusted transform to move up and scale for better visibility */
    transform: translateY(-5px) scale(0.9);
    transform-origin: center;
  }

  .crystal-background {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(74, 87, 255, 0.05);
    backdrop-filter: blur(4px);
    border-radius: 0.75rem;
    border: 1px solid rgba(74, 87, 255, 0.1);
    z-index: -1;
    transform: translateZ(0);
    animation: borderPulse 8s ease-in-out infinite;
  }

  @keyframes borderPulse {
    0%, 100% {
      border-color: rgba(74, 87, 255, 0.1);
      box-shadow: 0 0 15px rgba(74, 87, 255, 0.1);
    }
    50% {
      border-color: rgba(0, 229, 153, 0.2);
      box-shadow: 0 0 25px rgba(0, 229, 153, 0.15);
    }
  }
  
  @keyframes fadeIn {
    0% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }
  
  /* Global sparkle animation */
  :global(@keyframes sparkleAnim) {
    0% { transform: scale(0); opacity: 0; }
    20% { transform: scale(1.2); opacity: 1; }
    80% { transform: scale(0.8); opacity: 0.8; }
    100% { transform: scale(0); opacity: 0; }
  }
</style>

<script>
  // Global animation reset for service bullets if needed
  document.addEventListener('DOMContentLoaded', () => {
    setTimeout(() => {
      document.querySelectorAll('.crystal-bullet-item').forEach((item, index) => {
        if (item instanceof HTMLElement) {
          // Force animation to play if it hasn't already
          if (item.style.opacity !== '1' && window.getComputedStyle(item).opacity !== '1') {
            item.style.animation = 'none';
            item.offsetHeight; // Trigger reflow
            item.style.animation = `crystalFadeIn 0.6s ease-out ${0.2 + (index * 0.2)}s forwards`;
          }
        }
      });
      
      // Force the container to be visible as well
      const container = document.querySelector('.crystal-container');
      if (container instanceof HTMLElement) {
        container.style.opacity = '1';
      }
    }, 1000); // Reduced delay for faster visibility
  });
</script>
