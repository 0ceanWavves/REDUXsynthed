---
// import { Icon } from "astro-icon/components";
import Icon from "~/components/Icon.astro";
import ContentSection from "~/components/content-section.astro";
import ServiceTiles from "~/components/ServiceTiles/ServiceTiles.astro";
import type { FeatureItem } from "~/types";

const features: Array<FeatureItem> = [
  {
    title: "Custom Application Development",
    description:
      "Transforming complex business challenges into elegant software solutions that drive efficiency, adaptability, and innovation across your organization's unique operational landscape.",
    icon: "mdi:code-braces",
  },
  {
    title: "Modern Web Development",
    description:
      "Building lightning-fast, visually stunning web experiences with cutting-edge technologies that engage users and deliver seamless interactions across all devices and platforms.",
    icon: "mdi:language-javascript",
  },
  {
    title: "Mobile App Development",
    description:
      "Crafting immersive, feature-rich mobile experiences that resonate with users, leveraging native capabilities to deliver performance-optimized apps for both iOS and Android ecosystems.",
    icon: "mdi:cellphone-link",
  },
  {
    title: "Strategic Technology Consulting",
    description:
      "Navigating the complex technology landscape with expert guidance to align your digital strategy with business objectives, identifying opportunities for innovation and competitive advantage.",
    icon: "mdi:chart-timeline-variant",
  },
  {
    title: "UI/UX Design Excellence",
    description:
      "Creating intuitive, emotionally resonant digital experiences through user-centered design methodologies that transform complex workflows into beautiful, accessible interfaces users love.",
    icon: "mdi:palette-outline",
  },
  {
    title: "Cloud & DevOps Solutions",
    description:
      "Orchestrating resilient, self-healing cloud infrastructure with automated deployment pipelines that scale effortlessly, optimize costs, and empower rapid iteration with enterprise-grade reliability.",
    icon: "mdi:cloud-outline",
  },
];
---

<ContentSection title="What We Offer" id="features">
  <!-- Include the Three.js service tiles component -->
  <!-- <ServiceTiles /> --> <!-- Temporarily commented out for debugging -->
  
  <div class="features-wrapper w-full">
    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 w-full">
      {
        features.map(({ title, description, icon }, index) => (
          <li class="service-card" data-index={index}>
            <div class="service-card-inner flex flex-col items-center gap-4 p-6 rounded-lg">
              <div class="icon-container h-16 w-16 rounded-full border-2 border-current p-3">
                <div class="icon-3d-wrapper">
                  <div class="icon-3d-face icon-3d-front">
                    <Icon name={icon} class="h-full w-full service-icon" />
                  </div>
                  <div class="icon-3d-face icon-3d-back">
                    <span class="number-indicator">{index + 1}</span>
                  </div>
                </div>
              </div>
              <p class="text-center font-extrabold text-xl">{title}</p>
              <p class="text-center text-offset text-sm">{description}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</ContentSection>

<style>
  .features-wrapper {
    position: relative;
    padding: 2rem 1rem;
  }

  .service-card {
    perspective: 1000px;
    opacity: 0;
    transform: translateY(20px);
    position: relative;
  }

  .service-card-inner {
    min-height: 280px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    transform-style: preserve-3d;
    position: relative;
    background: rgba(15, 15, 25, 0.4);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  .icon-container {
    position: relative;
    transform-style: preserve-3d;
    background: transparent;
    z-index: 5;
  }
  
  .icon-3d-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.8s;
  }
  
  .icon-3d-face {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .icon-3d-front {
    color: var(--color-primary);
    transform: translateZ(1px);
  }
  
  .icon-3d-back {
    transform: rotateY(180deg);
  }
  
  .number-indicator {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--color-primary);
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  /* Enhanced Service card hover effect with glow */
  .service-card-inner:hover {
    transform: scale(1.02);
    background: rgba(20, 20, 35, 0.5);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
  }
  
  .service-card-inner:hover .icon-3d-wrapper {
    transform: rotateY(180deg);
  }
  
  /* Make text more readable against the 3D background */
  .service-card-inner p {
    position: relative;
    z-index: 2;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
  }
  
  /* Make sure content is properly positioned above the canvas */
  .service-card-inner > *:not(.tile-canvas-container) {
    position: relative; /* Ensure content stays above canvas */
    z-index: 2; /* Higher than the canvas container */
  }
  
  /* Add subtle pulse effect to icons */
  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
  }
  
  .service-card-inner:hover .icon-container {
    animation: pulse 2s ease-in-out infinite;
  }
</style>

<script>
  // Dynamic CSS variable for primary color in RGB format
  function setupCssVariables() {
    // Get the primary color from CSS variables
    const primaryColor = getComputedStyle(document.documentElement)
      .getPropertyValue('--color-primary')
      .trim();
    
    // Convert hex to RGB if it's a hex color
    if (primaryColor.startsWith('#')) {
      const r = parseInt(primaryColor.slice(1, 3), 16);
      const g = parseInt(primaryColor.slice(3, 5), 16);
      const b = parseInt(primaryColor.slice(5, 7), 16);
      
      document.documentElement.style.setProperty('--color-primary-rgb', `${r}, ${g}, ${b}`);
    }
  }

  // Entrance animation with intersection observer
  function setupEntranceAnimation() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const card = entry.target;
          const dataIndex = (card as HTMLElement).dataset.index || '0';
          const index = parseInt(dataIndex, 10);
          
          setTimeout(() => {
            (card as HTMLElement).style.transition = 'opacity 0.8s ease, transform 0.8s cubic-bezier(0.23, 1, 0.32, 1)';
            (card as HTMLElement).style.opacity = '1';
            (card as HTMLElement).style.transform = 'translateY(0)';
          }, 150 * index); // Slightly slower sequence for a more dramatic effect
          
          observer.unobserve(card);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.service-card').forEach((card) => {
      observer.observe(card);
    });
  }

  // Run once the DOM is fully loaded
  document.addEventListener('DOMContentLoaded', () => {
    setupCssVariables();
    setupEntranceAnimation();
  });
</script>
