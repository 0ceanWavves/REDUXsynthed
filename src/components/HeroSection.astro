---
import AmorphousPrism from "./AmorphousPrism.astro";
import Splash from "./splash.astro";
import CrossBrowserFix from "./crossBrowserFix.astro";
import InteractionHint from "./InteractionHint.astro";
---

<!-- HeroSection.astro - Encapsulates the entire hero section of the homepage -->
<section class="hero-section">
  <div class="relative min-h-screen">
    <!-- Add SplashPrism disabler script -->
    <script is:inline src="/disable-splash-prism.js"></script>
    
    <!-- Amorphous prism container with gooey effect applied -->
    <div id="hero-prism-container" class="absolute top-0 left-0 w-full h-screen pointer-events-auto gooey-container" 
         style="z-index: 35; transform: translateZ(0); will-change: transform; cursor: grab; touch-action: none;" 
         data-priority="high" data-interactive="true">
      <AmorphousPrism />
    </div>
    
    <!-- Move the interaction hint outside the prism container for proper positioning -->
    <InteractionHint />
    
    <!-- Splash content with higher z-index to appear over prism but not block interaction -->
    <div class="relative z-60 pointer-events-none" style="transform: translateZ(0.1px);">
      <Splash />
    </div>
    
    <!-- Add cross-browser fix component -->
    <CrossBrowserFix />
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: transparent;
    contain: layout paint style;
  }
  
  /* Make sure the hero takes up full viewport height */
  .hero-section > div {
    min-height: 100vh;
    position: relative;
    background: transparent;
  }
  
  #hero-prism-container {
    backface-visibility: hidden;
    perspective: 1000px;
    transform-style: preserve-3d;
    will-change: transform;
    z-index: 35 !important; /* Increased from 6 to match direct-rotation-fix.js */
    pointer-events: auto !important;
    touch-action: none !important; /* Critical: ensure consistent with canvas */
  }
  
  /* Apply gooey effect to the container */
  .gooey-container {
    filter: url('#gooey-effect');
  }
  
  /* Make sure splash content is above 3D elements */
  .z-60 {
    z-index: 999 !important;
    pointer-events: none !important; /* Critical: allow clicks to pass through to the canvas */
  }
  
  @media (max-width: 768px) {
    /* Mobile-specific adjustments */
    #hero-prism-container {
      transform: scale(0.9) translateZ(0);
      height: 90vh; /* Increase height to make object more prominent */
      top: 5vh; /* Adjust vertical positioning */
      left: 0; /* Center horizontally */
      width: 100%; /* Use full width */
    }
  }
</style>

<script>
  // Hero-specific interactions
  document.addEventListener('DOMContentLoaded', () => {
    const prismContainer = document.getElementById('hero-prism-container');
    const prismBackground = document.getElementById('prism-background');
    const canvas = document.getElementById('prism-bg-canvas');
    const heroSection = document.querySelector('.hero-section');
    
    // Force all interactive elements to have pointer events and touch-action: none
    if (canvas) {
      canvas.style.pointerEvents = 'auto';
      canvas.style.zIndex = '5';
      canvas.style.touchAction = 'none'; // Critical for iOS/Chrome
    }
    
    if (prismBackground) {
      prismBackground.style.pointerEvents = 'auto';
      prismBackground.style.zIndex = '6';
      prismBackground.style.touchAction = 'none'; // Critical for iOS/Chrome
    }
    
    if (prismContainer && heroSection) {
      // Add touch-action: auto to the prism container
      prismContainer.style.touchAction = 'auto';
      
      // Log visibility for debugging
      console.log('Hero section initialized');
      
      // Add a smooth parallax effect on scroll with optimizations
      let lastScrollY = 0;
      let animationFrame: number | null = null;
      
      // More efficient scroll handler with debounce
      function onScroll() {
        if (animationFrame) return;
        
        animationFrame = window.requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          
          // Only update if scroll position changed significantly
          if (Math.abs(scrollY - lastScrollY) > 1) {
            // Only apply effect for first 500px of scrolling
            if (scrollY < 500) {
              // Smoother transition values
              const scale = Math.max(0.95, 1 - (scrollY * 0.0001)); // Limit minimum scale
              const yOffset = scrollY * 0.08; // Reduced movement
              
              // Apply hardware-accelerated transform but keep z-index and pointer-events
              if (prismContainer) {
                prismContainer.style.transform = `scale3d(${scale}, ${scale}, 1) translate3d(0, ${yOffset}px, 0)`;
                prismContainer.style.zIndex = '6'; // Maintain correct z-index during scroll
                prismContainer.style.pointerEvents = 'auto';
              }
            }
            
            lastScrollY = scrollY;
          }
          
          animationFrame = null;
        });
      }
      
      // Use passive scroll listener for better performance
      window.addEventListener('scroll', onScroll, { passive: true });
      
      // Set initial transform with a slight delay to ensure proper initial rendering
      setTimeout(() => {
        if (window.scrollY > 0) {
          onScroll();
        }
        
        // Force event handling for all interactive elements
        document.querySelectorAll('#prism-bg-canvas, #prism-background').forEach(el => {
          if (el instanceof HTMLElement) {
            el.style.pointerEvents = 'auto';
            el.style.touchAction = 'auto'; // Changed from 'none' to 'auto'
          }
        });
      }, 100);
    }
    
    // Listen for fallback canvas creation and ensure it has proper styling
    window.addEventListener('fallbackCanvasCreated', (event) => {
      console.log('Fallback canvas created event received:', (event as CustomEvent).detail);
      
      // Find the fallback canvas
      const fallbackCanvas = document.getElementById((event as CustomEvent).detail.canvasId);
      if (fallbackCanvas) {
        console.log('Ensuring fallback canvas has proper styling for HeroSection');
        
        // Apply critical styles
        fallbackCanvas.style.zIndex = '50'; // Ensure high z-index
        fallbackCanvas.style.pointerEvents = 'auto';
        fallbackCanvas.style.touchAction = 'none';
        fallbackCanvas.style.cursor = 'grab';
        fallbackCanvas.style.opacity = '1';
        
        // Ensure the container has proper z-index as well
        if (prismContainer) {
          prismContainer.style.zIndex = '35'; // Match the original z-index
        }
        
        console.log('Fallback canvas styling applied successfully');
      }
    });
  });
</script>
