---
import AmorphousPrism from "./AmorphousPrism.astro";
import Splash from "./splash.astro";
---

<!-- HeroSection.astro - Encapsulates the entire hero section of the homepage -->
<section class="hero-section">
  <div class="relative min-h-screen">
    <!-- Amorphous prism container with gooey effect applied -->
    <div id="prism-background" class="absolute top-0 left-0 w-full h-screen pointer-events-auto gooey-container" 
         style="z-index: 15; transform: translateZ(0); will-change: transform; cursor: grab;">
      <AmorphousPrism />
    </div>
    
    <!-- Splash content with higher z-index to appear over prism but not block interaction -->
    <div class="relative z-30 pointer-events-none" style="transform: translateZ(0.1px);">
      <Splash />
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: transparent;
    contain: layout paint style;
  }
  
  /* Make sure the hero takes up full viewport height */
  .hero-section > div {
    min-height: 100vh;
    position: relative;
    background: transparent;
  }
  
  #prism-background {
    backface-visibility: hidden;
    perspective: 1000px;
    transform-style: preserve-3d;
    will-change: transform;
  }
  
  /* Apply gooey effect to the container */
  .gooey-container {
    filter: url('#gooey-effect');
  }
  
  @media (max-width: 768px) {
    /* Mobile-specific adjustments */
    #prism-background {
      transform: scale(0.9) translateZ(0);
      height: 90vh; /* Increase height to make object more prominent */
      top: 5vh; /* Adjust vertical positioning */
      left: 0; /* Center horizontally */
      width: 100%; /* Use full width */
    }
  }
</style>

<script>
  // Hero-specific interactions
  document.addEventListener('DOMContentLoaded', () => {
    const prismBackground = document.getElementById('prism-background');
    const heroSection = document.querySelector('.hero-section');
    
    if (prismBackground && heroSection) {
      // Log visibility for debugging
      console.log('Hero section initialized');
      
      // Add a smooth parallax effect on scroll with optimizations
      let lastScrollY = 0;
      let animationFrame: number | null = null;
      
      // Pre-calculate values to avoid layout thrashing
      const initialTransform = {
        scale: 1,
        y: 0,
        z: 0
      };
      
      // More efficient scroll handler with debounce
      function onScroll() {
        if (animationFrame) return;
        
        animationFrame = window.requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          
          // Only update if scroll position changed significantly
          if (Math.abs(scrollY - lastScrollY) > 1) {
            // Only apply effect for first 500px of scrolling
            if (scrollY < 500) {
              // Smoother transition values
              const scale = Math.max(0.95, 1 - (scrollY * 0.0001)); // Limit minimum scale
              const yOffset = scrollY * 0.08; // Reduced movement
              
              // Apply hardware-accelerated transform
              if (prismBackground) {
                prismBackground.style.transform = `scale3d(${scale}, ${scale}, 1) translate3d(0, ${yOffset}px, 0)`;
              }
            }
            
            lastScrollY = scrollY;
          }
          
          animationFrame = null;
        });
      }
      
      // Use passive scroll listener for better performance
      window.addEventListener('scroll', onScroll, { passive: true });
      
      // Set initial transform with a slight delay to ensure proper initial rendering
      setTimeout(() => {
        if (window.scrollY > 0) {
          onScroll();
        }
      }, 100);
    }
  });
</script> 