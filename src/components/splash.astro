---
import { Icon } from "astro-icon/components";

const widths = [450, 800];
const sizes = "(min-width: 640px) 42vw, 67vw";

/**
 * Interactive 3D Cube Menu Feature Documentation
 * -----------------------------------------
 * 
 * This component includes an innovative 3D cube that serves as both a visual 
 * element and an interactive menu. Each face of the cube represents a different
 * section of the website and can be clicked to navigate to that section.
 * 
 * Key Features:
 * - Interactive rotation with mouse/touch support
 * - Each cube face acts as a clickable menu item
 * - Custom textures on each face with section titles
 * - Visual feedback on hover/interaction
 * - Responsive design that works on all devices
 * - Ambient motion when not being interacted with
 * 
 * Cube Menu Sections:
 * - Front: Projects - Showcases completed work
 * - Back: Services - Features custom solutions
 * - Top: About Us - Company information
 * - Bottom: Contact - Get in touch
 * - Left: Process - How we work with clients
 * - Right: Tech Stack - Technologies we use
 * 
 * Customization Options:
 * - Adjust cube position: cube.position.set(x, y, z)
 * - Change cube size: cube.scale.set(width, height, depth)
 * - Modify face textures: Edit the createFaceTexture function
 * - Change menu labels: Update the faceContent array
 * - Adjust rotation speed: cube.rotation.y += 0.003 (higher = faster)
 * 
 * Performance Notes:
 * - The cube uses minimal geometry segments for better performance
 * - Face textures are generated once at initialization
 * - Event listeners are properly cleaned up to prevent memory leaks
 * - Uses efficient rendering techniques with Three.js
 */
---

<section class="relative h-full bg-transparent pb-0 md:pb-0">
  <div class="absolute inset-0 overflow-hidden bg-gradient-to-b from-gray-900/70 to-black/70">
    <!-- Remove static background pattern -->
    
    <!-- Add Three.js canvas here but ensure it doesn't block prism interaction -->
    <canvas id="splash-animation-canvas" class="absolute top-0 left-0 w-full h-full pointer-events-none"></canvas>
  </div>
  
  <div class="relative z-10 flex flex-col items-center justify-center min-h-[85vh] gap-6 pt-0 pb-16 pointer-events-none">
    <!-- "Create Design Build" centered in viewport -->
    <div class="splash-title flex flex-col items-center gap-1 pointer-events-none mt-8 px-4">
      <div class="gradient-text text-center font-extrabold tracking-tighter text-5xl md:text-7xl browser-optimized-text">
        <div class="title-word pointer-events-none">Create</div>
        <div class="title-word pointer-events-none">Design</div>
        <div class="title-word pointer-events-none">Build</div>
      </div>
    </div>
    
    <!-- Content section below the title -->
    <div class="splash-content w-full max-w-2xl text-center mt-4 browser-optimized-text pointer-events-none px-4 mx-auto">
      <div class="text-white text-lg md:text-xl leading-relaxed">
        <p class="mb-1 content-item">Transforming ideas into</p>
        <p class="text-primary text-2xl md:text-3xl font-bold mb-3 content-item">Digital Solutions</p>
        <div class="flex flex-col md:flex-row md:flex-wrap justify-center gap-3 mb-6">
          <div class="flex items-center gap-2 content-item">
            <div class="check-circle">
              <Icon name="mdi:check-circle" class="h-5 w-5 text-primary" />
            </div>
            <p>Custom Business Applications</p>
          </div>
          <div class="flex items-center gap-2 content-item">
            <div class="check-circle">
              <Icon name="mdi:check-circle" class="h-5 w-5 text-primary" />
            </div>
            <p>Modern Web & Mobile Development</p>
          </div>
          <div class="flex items-center gap-2 content-item">
            <div class="check-circle">
              <Icon name="mdi:check-circle" class="h-5 w-5 text-primary" />
            </div>
            <p>Strategic Technology Consulting</p>
          </div>
          <div class="flex items-center gap-2 content-item">
            <div class="check-circle">
              <Icon name="mdi:check-circle" class="h-5 w-5 text-primary" />
            </div>
            <p>UI/UX Design Excellence</p>
          </div>
        </div>
        
        <!-- Call to action buttons -->
        <div class="flex flex-wrap justify-center gap-4 mt-3">
          <a href="#features" class="bg-purple-600 hover:bg-purple-700 text-white font-medium py-2 px-6 rounded-md transition-colors duration-300 flex items-center gap-2">
            <Icon name="mdi:code-tags" class="h-5 w-5" /> Our Services
          </a>
          <a href="#process" class="bg-transparent border border-teal-400 hover:bg-teal-900/20 text-teal-300 font-medium py-2 px-6 rounded-md transition-colors duration-300 flex items-center gap-2">
            <Icon name="mdi:chart-timeline-variant" class="h-5 w-5" /> Our Process
          </a>
        </div>
      </div>
    </div>
    
    <!-- Scroll indicator - moved up to prevent overlap with navbar -->
    <div class="scroll-indicator content-item absolute bottom-20 left-1/2 transform -translate-x-1/2 flex flex-col items-center">
      <p class="text-white/70 text-sm mb-1">Scroll for more</p>
      <div class="animate-bounce">
        <Icon name="mdi:chevron-down" class="h-7 w-7 text-purple-500" />
      </div>
    </div>
  </div>
</section>

<style>
  /* Base styling for gradient text */
  .gradient-text {
    background: linear-gradient(45deg, #8162ff, #00e599);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-fill-color: transparent;
    filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.3));
  }
  
  /* Browser optimizations */
  .browser-optimized-text {
    /* Force proper stacking context in all browsers */
    transform: translateZ(0);
    will-change: transform, opacity;
    
    /* Prevent flickering */
    backface-visibility: hidden;
    
    /* Improve text rendering */
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  
  /* Firefox-specific optimizations */
  @-moz-document url-prefix() {
    .browser-optimized-text {
      /* Firefox benefits from these settings */
      transform: none !important; /* Avoid hardware acceleration for better text rendering */
      filter: none !important; /* Filters are expensive in Firefox */
    }
    
    .gradient-text {
      /* Alternative approach for Firefox that's less GPU intensive */
      background: linear-gradient(45deg, #8162ff, #00e599);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      color: #8162ff; /* Fallback */
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }
  }
  
  /* Chrome-specific fixes */
  @media screen and (-webkit-min-device-pixel-ratio: 0) and (min-resolution: 0.001dpcm) {
    .browser-optimized-text {
      /* Chrome benefits from hardware acceleration but needs it consistently applied */
      transform: translateZ(0);
      z-index: 30 !important;
      position: relative;
    }
    
    .gradient-text {
      /* Enhance visibility in Chrome */
      filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.5));
    }
    
    .title-word {
      /* Make text more visible against the prism background */
      text-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
    }
  }
  
  /* Title and content animation optimizations */
  .title-word, .content-item, .check-circle {
    opacity: 0;
    will-change: opacity, transform;
  }
  
  @media (prefers-reduced-motion: reduce) {
    .title-word, .content-item, .check-circle {
      opacity: 1 !important;
      transform: none !important;
    }
    
    .gradient-text {
      animation: none;
    }
  }
  
  /* Add a special rule to ensure text elements don't block pointer events */
  .pointer-events-none {
    pointer-events: none !important;
  }
  
  /* Ensure the buttons are clickable */
  a.bg-purple-600, a.bg-transparent {
    pointer-events: auto !important;
  }
</style>

<script>
  // Use IntersectionObserver for more efficient animation triggering
  function animateSplashScreen() {
    // Title word animation
    const titleWords = document.querySelectorAll('.title-word');
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          titleWords.forEach((word, index) => {
            const el = word as HTMLElement;
            el.style.opacity = '0';
            el.style.transform = 'translateY(-20px)';
            
            setTimeout(() => {
              el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
              el.style.opacity = '1';
              el.style.transform = 'translateY(0)';
            }, 200 + (index * 200));
          });
          observer.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    
    if (titleWords.length > 0) {
      observer.observe(titleWords[0].parentElement as HTMLElement);
    }
    
    // Content items animation
    const contentItems = document.querySelectorAll('.content-item');
    const contentObserver = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          contentItems.forEach((item, index) => {
            const el = item as HTMLElement;
            setTimeout(() => {
              el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
              el.style.opacity = '1';
              el.style.transform = 'translateY(0)';
            }, 600 + (index * 150));
          });
          contentObserver.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    
    if (contentItems.length > 0) {
      contentItems.forEach(item => {
        (item as HTMLElement).style.opacity = '0';
        (item as HTMLElement).style.transform = 'translateY(20px)';
      });
      contentObserver.observe(contentItems[0] as HTMLElement);
    }
    
    // Check circles animation
    const checkCircles = document.querySelectorAll('.check-circle');
    const checkObserver = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          checkCircles.forEach((circle, index) => {
            const el = circle as HTMLElement;
            setTimeout(() => {
              el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
              el.style.opacity = '1';
              el.style.transform = 'scale(1)';
            }, 800 + (index * 100));
          });
          checkObserver.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    
    if (checkCircles.length > 0) {
      checkCircles.forEach(circle => {
        (circle as HTMLElement).style.opacity = '0';
        (circle as HTMLElement).style.transform = 'scale(0)';
      });
      checkObserver.observe(checkCircles[0].parentElement as HTMLElement);
    }
  }
  
  // More efficient scroll interaction with throttling
  function setupScrollInteraction() {
    if (typeof window === 'undefined') return;
    
    const splashSection = document.querySelector('section');
    if (!splashSection) return;
    
    let ticking = false;
    
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          const scrollPos = window.scrollY;
          
          // Limit the parallax effect to avoid content disappearing
          // Apply a much milder effect that stops after 200px of scrolling
          const maxParallax = 20; // Maximum pixels to move
          const parallaxAmount = Math.min(maxParallax, scrollPos * 0.05);
          
          // Only apply subtle parallax to title with a minimum opacity
          const title = document.querySelector('.splash-title');
          if (title) {
            (title as HTMLElement).style.transform = `translateY(${parallaxAmount}px)`;
          }
          
          // Keep content visible with minimum opacity of 0.7
          const content = document.querySelector('.splash-content');
          if (content) {
            const contentOpacity = Math.max(0.7, 1 - scrollPos / 800);
            (content as HTMLElement).style.opacity = contentOpacity.toString();
            // No transform on content to keep it in place
            (content as HTMLElement).style.transform = 'none';
          }
          
          ticking = false;
        });
        
        ticking = true;
      }
    });
  }
  
  // Wait for the DOM to be fully loaded
  document.addEventListener('DOMContentLoaded', () => {
    // Initialize animations
    animateSplashScreen();
    
    // Setup scroll interaction on all devices (mobile friendly version)
    setupScrollInteraction();
  });
</script>
