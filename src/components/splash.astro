---
// Import new modular components
import SplashTitle from './SplashTitle.astro';
import SplashContent from './SplashContent.astro';
import SplashPrism from './SplashPrism.astro';
import SplashActionButtons from './SplashActionButtons.astro';
import SplashScrollIndicator from './SplashScrollIndicator.astro';

const widths = [450, 800];
const sizes = "(min-width: 640px) 42vw, 67vw";
---

<section class="relative h-full bg-transparent pb-0 md:pb-0">
  <div class="absolute inset-0 overflow-hidden">
    <!-- Canvas for Three.js animation -->
    <canvas id="splash-animation-canvas" class="absolute top-0 left-0 w-full h-full pointer-events-none"></canvas>

    <!-- 3D Prism component -->
    <SplashPrism />
  </div>

  <!-- IMPORTANT: Added pointer-events-none to ensure all text content passes through clicks/touches -->
  <div class="relative z-50 flex flex-col items-center justify-center min-h-[75vh] gap-4 md:gap-6 pt-0 pb-10 md:pb-12 pointer-events-none">
    <!-- Title component -->
    <SplashTitle />

    <!-- Content component -->
    <SplashContent />

    <!-- Scroll indicator component -->
    <SplashScrollIndicator />
  </div>

  <!-- IMPORTANT: Made sure action buttons still receive pointer events -->
  <div class="action-buttons-container">
    <SplashActionButtons />
  </div>
</section>

<!-- Inline Critical CSS for FOUC prevention - Updated to avoid conflicting with animations -->
<style is:inline>
  /* Only apply to content elements, NOT title words */
  .splash-content, .scroll-indicator {
    z-index: 900 !important;
    position: relative !important;
    visibility: visible !important;
    opacity: 1 !important;
    pointer-events: none !important; /* ADDED to ensure clicks pass through */
  }
  
  /* Ensure content text is visible during CSS loading */
  .splash-content {
    color: white !important;
    visibility: visible !important;
    opacity: 1 !important;
    pointer-events: none !important; /* ADDED to ensure clicks pass through */
  }
  
  .splash-content p {
    opacity: 1 !important;
    pointer-events: none !important; /* ADDED to ensure clicks pass through */
  }
  
  /* Prevent empty black screen while loading */
  body {
    background-color: #0a0a1a !important;
  }

  /* Force content to be above canvas */
  .z-50 {
    z-index: 999 !important;
  }

  /* IMPORTANT: Do NOT force title words to be visible immediately */
  /* Let the SplashTitle component handle its own animations */
  
  /* Ensure all text content is non-interactive but buttons remain interactive */
  .action-buttons-container {
    position: relative;
    z-index: 999;
    pointer-events: auto !important;
  }
  
  /* Ensure individual buttons get pointer events */
  .action-buttons-container a, 
  .action-buttons-container button {
    pointer-events: auto !important;
  }
</style>

<style>
  /* Add a special rule to ensure text elements don't block pointer events */
  .pointer-events-none {
    pointer-events: none !important;
  }
  
  /* Additional styling to ensure interactive elements are accessible */
  #prism-bg-canvas, #prism-background {
    pointer-events: auto !important;
  }

  /* Ensure text elements appear above the 3D prism */
  .relative.z-50 {
    z-index: 999 !important;
    pointer-events: none !important; /* ADDED to ensure clicks pass through */
  }
</style>

<script>
  // Wait for the DOM to be fully loaded
  document.addEventListener('DOMContentLoaded', () => {
    console.log("Splash section initialized");
    
    // IMPORTANT: Apply pointer-events: none to ALL text elements
    const textElements = document.querySelectorAll('.splash-content, .content-item, .check-circle, .splash-title, .title-word, .gradient-text, p, h1, h2, h3, h4, h5, h6');
    textElements.forEach(el => {
      if (el instanceof HTMLElement) {
        el.style.opacity = '1';
        el.style.visibility = 'visible';
        el.style.zIndex = '999';
        el.style.pointerEvents = 'none'; // Ensure clicks pass through
      }
    });
    
    // Make sure buttons and links still receive pointer events
    const interactiveElements = document.querySelectorAll('a, button, .button, [role="button"]');
    interactiveElements.forEach(el => {
      if (el instanceof HTMLElement) {
        el.style.pointerEvents = 'auto';
      }
    });
    
    // Force 3D elements to have lower z-index but receive pointer events
    const canvas = document.getElementById('prism-bg-canvas');
    if (canvas && canvas instanceof HTMLElement) {
      canvas.style.zIndex = '5';
      canvas.style.pointerEvents = 'auto';
    }
    
    const prismBackground = document.getElementById('prism-background');
    if (prismBackground && prismBackground instanceof HTMLElement) {
      prismBackground.style.zIndex = '6';
      prismBackground.style.pointerEvents = 'auto';
    }
    
    // Ensure the prism interactive area gets all the events
    const prismInteractiveArea = document.querySelector('.prism-interactive-area');
    if (prismInteractiveArea instanceof HTMLElement) {
      prismInteractiveArea.style.pointerEvents = 'auto';
      console.log('Enhanced prism interaction area');
    }
  });
</script>