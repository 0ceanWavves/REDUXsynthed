---
import { Icon } from "astro-icon/components";

const widths = [450, 800];
const sizes = "(min-width: 640px) 42vw, 67vw";
---

<section class="relative h-full bg-black pb-16 md:pb-0">
  <div class="absolute inset-0 overflow-hidden bg-gradient-to-b from-gray-900 to-black">
    <!-- Video background - optimized but available on all devices -->
    <video 
      class="absolute min-h-full min-w-full object-cover opacity-40"
      autoplay 
      loop 
      muted 
      playsinline
      preload="metadata"
      poster="/images/video-poster.jpg"
    >
      <source src="/videos/landing_page_video.mp4" type="video/mp4" />
    </video>
    
    <!-- Static background pattern as fallback/enhancement -->
    <div class="absolute inset-0 opacity-30">
      <div class="w-full h-full bg-dots-pattern"></div>
    </div>
  </div>
  
  <div class="relative grid h-full place-items-center sm:grid-cols-2 gap-16 sm:gap-8 pt-16 sm:pt-0">
    <div class="splash-title flex flex-col items-center gap-2 self-center sm:gap-4 sm:self-auto sm:justify-self-end">
      <div class="gradient-text text-center font-extrabold tracking-tighter text-6xl md:text-8xl">
        <div class="title-word">Create</div>
        <div class="title-word">Design</div>
        <div class="title-word">Build</div>
      </div>
    </div>
    
    <div class="splash-content w-2/3 max-w-3xl self-center sm:w-10/12 sm:self-auto sm:justify-self-start">
      <div class="text-white text-xl md:text-2xl leading-relaxed">
        <p class="mb-4 content-item">Transforming ideas into</p>
        <p class="text-primary text-3xl md:text-4xl font-bold mb-6 content-item">Tailored Digital Solutions</p>
        <div class="space-y-1 mb-12 md:mb-0">
          <div class="flex items-center gap-2 content-item">
            <div class="check-circle">
              <Icon name="mdi:check-circle" class="h-5 w-5 text-primary" />
            </div>
            <p>Custom Business Applications</p>
          </div>
          <div class="flex items-center gap-2 content-item">
            <div class="check-circle">
              <Icon name="mdi:check-circle" class="h-5 w-5 text-primary" />
            </div>
            <p>Modern Web & Mobile Development</p>
          </div>
          <div class="flex items-center gap-2 content-item mb-6 md:mb-0">
            <div class="check-circle">
              <Icon name="mdi:check-circle" class="h-5 w-5 text-primary" />
            </div>
            <p>Strategic Technology Consulting</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .gradient-text {
    background-image: linear-gradient(45deg, var(--tw-gradient-stops));
    --tw-gradient-from: #818cf8;
    --tw-gradient-to: #d8b4fe;
    --tw-gradient-stops: var(--tw-gradient-from), #c084fc, var(--tw-gradient-to);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 150% 150%;
    animation: gradient 8s ease infinite;
  }
  
  @keyframes gradient {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }
  
  /* Background pattern for mobile */
  .bg-dots-pattern {
    background-image: radial-gradient(rgba(96, 165, 250, 0.2) 1px, transparent 1px);
    background-size: 20px 20px;
  }
  
  /* Title and content animation optimizations */
  .title-word, .content-item, .check-circle {
    opacity: 0;
    will-change: opacity, transform;
  }
  
  @media (prefers-reduced-motion: reduce) {
    video {
      @apply hidden;
    }
    
    .title-word, .content-item, .check-circle {
      opacity: 1 !important;
      transform: none !important;
    }
    
    .gradient-text {
      animation: none;
    }
  }
</style>

<script>
  // Use IntersectionObserver for more efficient animation triggering
  function animateSplashScreen() {
    // More efficient title word animation
    const titleWords = document.querySelectorAll('.title-word');
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          titleWords.forEach((word, index) => {
            const el = word as HTMLElement;
            el.style.opacity = '0';
            el.style.transform = 'translateY(-20px)';
            
            setTimeout(() => {
              el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
              el.style.opacity = '1';
              el.style.transform = 'translateY(0)';
            }, 200 + (index * 200));
          });
          observer.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    
    if (titleWords.length > 0) {
      observer.observe(titleWords[0].parentElement as HTMLElement);
    }
    
    // More efficient content animation
    const contentItems = document.querySelectorAll('.content-item');
    const contentObserver = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          contentItems.forEach((item, index) => {
            const el = item as HTMLElement;
            setTimeout(() => {
              el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
              el.style.opacity = '1';
              el.style.transform = 'translateY(0)';
            }, 600 + (index * 150));
          });
          contentObserver.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    
    if (contentItems.length > 0) {
      contentItems.forEach(item => {
        (item as HTMLElement).style.opacity = '0';
        (item as HTMLElement).style.transform = 'translateY(20px)';
      });
      contentObserver.observe(contentItems[0] as HTMLElement);
    }
    
    // More efficient check circle animation
    const checkCircles = document.querySelectorAll('.check-circle');
    const checkObserver = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          checkCircles.forEach((circle, index) => {
            const el = circle as HTMLElement;
            setTimeout(() => {
              el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
              el.style.opacity = '1';
              el.style.transform = 'scale(1)';
            }, 800 + (index * 100));
          });
          checkObserver.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    
    if (checkCircles.length > 0) {
      checkCircles.forEach(circle => {
        (circle as HTMLElement).style.opacity = '0';
        (circle as HTMLElement).style.transform = 'scale(0)';
      });
      checkObserver.observe(checkCircles[0].parentElement as HTMLElement);
    }
  }
  
  // More efficient scroll interaction with throttling
  function setupScrollInteraction() {
    if (typeof window === 'undefined') return;
    
    const splashSection = document.querySelector('section');
    if (!splashSection) return;
    
    let ticking = false;
    
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          const scrollPos = window.scrollY;
          const opacity = Math.max(0, 1 - scrollPos / 400);
          
          // Parallax effect on title
          const title = document.querySelector('.splash-title');
          if (title) {
            (title as HTMLElement).style.transform = `translateY(${scrollPos * 0.1}px)`;
          }
          
          // Fade out content with parallax
          const content = document.querySelector('.splash-content');
          if (content) {
            (content as HTMLElement).style.opacity = opacity.toString();
            (content as HTMLElement).style.transform = `translateY(${scrollPos * 0.05}px)`;
          }
          
          ticking = false;
        });
        
        ticking = true;
      }
    });
  }
  
  // Initialize video properly on all devices
  function initVideo() {
    const video = document.querySelector('video');
    if (!video) return;
    
    // Smaller viewport devices will use poster image first for performance
    const isSmallDevice = window.innerWidth < 768;
    
    // Add event listeners for video loading
    video.addEventListener('loadedmetadata', function() {
      // Video metadata loaded successfully
      if (isSmallDevice) {
        // For mobile: only play if the user has scrolled less than 100px (still on splash screen)
        if (window.scrollY < 100) {
          video.play().catch(e => {
            // Fallback if autoplay fails on mobile
            console.log('Video autoplay not allowed on this device');
          });
        }
      } else {
        // Desktop: play immediately
        video.play().catch(e => {
          console.log('Video autoplay not allowed on this device');
        });
      }
    });
    
    // Add error handling
    video.addEventListener('error', function() {
      // Hide video and show only the pattern background if error
      video.style.display = 'none';
      console.log('Video failed to load, using fallback background');
    });
  }
  
  // Wait for the DOM to be fully loaded
  document.addEventListener('DOMContentLoaded', () => {
    // Initialize animations
    animateSplashScreen();
    
    // Setup scroll interaction on all devices (mobile friendly version)
    setupScrollInteraction();
    
    // Initialize video loading
    initVideo();
  });
</script>
