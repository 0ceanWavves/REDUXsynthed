---
import { Icon } from "astro-icon/components";

const widths = [450, 800];
const sizes = "(min-width: 640px) 42vw, 67vw";
---

<section class="relative h-full bg-black">
  <div class="absolute inset-0 overflow-hidden">
    <video 
      class="absolute min-h-full min-w-full object-cover opacity-40"
      autoplay 
      loop 
      muted 
      playsinline
    >
      <source src="https://pub-c929c30fe7224689b55ff91bc5136ff1.r2.dev/landing_page_video.mp4" type="video/mp4" />
    </video>
  </div>
  <div class="relative grid h-full place-items-center sm:grid-cols-2 gap-16 sm:gap-8 pt-16 sm:pt-0">
    <div
      class="flex flex-col items-center gap-2 self-center sm:gap-4 sm:self-auto sm:justify-self-end"
    >
      <div
        class="gradient-text text-center font-extrabold tracking-tighter text-6xl md:text-8xl"
      >
        Create
        <br /> Design
        <br /> Build
      </div>
    </div>
    <div
      class="w-2/3 max-w-3xl self-center sm:w-10/12 sm:self-auto sm:justify-self-start"
    >
      <div class="text-white text-xl md:text-2xl leading-relaxed">
        <p class="mb-4">Transforming ideas into</p>
        <p class="text-primary text-3xl md:text-4xl font-bold mb-6">Tailored Digital Solutions</p>
        <div class="space-y-1">
          <div class="flex items-center gap-2">
            <Icon name="mdi:check-circle" class="h-5 w-5 text-primary" />
            <p>Custom Business Applications</p>
          </div>
          <div class="flex items-center gap-2">
            <Icon name="mdi:check-circle" class="h-5 w-5 text-primary" />
            <p>Modern Web & Mobile Development</p>
          </div>
          <div class="flex items-center gap-2">
            <Icon name="mdi:check-circle" class="h-5 w-5 text-primary" />
            <p>Strategic Technology Consulting</p>
          </div>
        </div>
        <div class="mt-8">
          <a 
            href="#intro" 
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white rounded-md hover:bg-blue-600 transition-colors"
          >
            Learn More
            <Icon name="mdi:arrow-right" class="h-5 w-5" />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: reduce) {
    video {
      @apply hidden;
    }
  }
</style>
