---
// Import new modular components
import SplashTitle from './SplashTitle.astro';
import SplashContent from './SplashContent.astro';
import SplashPrism from './SplashPrism.astro';
import SplashActionButtons from './SplashActionButtons.astro';
import SplashScrollIndicator from './SplashScrollIndicator.astro';

const widths = [450, 800];
const sizes = "(min-width: 640px) 42vw, 67vw";
---

<section class="relative h-full bg-transparent pb-0 md:pb-0">
  <div class="absolute inset-0 overflow-hidden">
    <!-- Canvas for Three.js animation -->
    <canvas id="splash-animation-canvas" class="absolute top-0 left-0 w-full h-full pointer-events-none"></canvas>

    <!-- 3D Prism component -->
    <SplashPrism />
  </div>

  <div class="relative z-10 flex flex-col items-center justify-center min-h-[75vh] gap-4 md:gap-6 pt-0 pb-10 md:pb-12 pointer-events-none">
    <!-- Title component -->
    <SplashTitle />

    <!-- Content component -->
    <SplashContent />

    <!-- Scroll indicator component -->
    <SplashScrollIndicator />
  </div>

  <!-- Action buttons component -->
  <SplashActionButtons />
</section>

<style>
  /* Add a special rule to ensure text elements don't block pointer events */
  .pointer-events-none {
    pointer-events: none !important;
  }
  
  /* Additional styling to ensure interactive elements are accessible */
  #prism-bg-canvas, #prism-background {
    pointer-events: auto !important;
  }
</style>

<script>
  // More efficient scroll interaction with throttling
  function setupScrollInteraction() {
    if (typeof window === 'undefined') return;

    const splashSection = document.querySelector('section');
    if (!splashSection) return;

    let ticking = false;

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          const scrollPos = window.scrollY;

          // Limit the parallax effect to avoid content disappearing
          // Apply a much milder effect that stops after 200px of scrolling
          const maxParallax = 20; // Maximum pixels to move
          const parallaxAmount = Math.min(maxParallax, scrollPos * 0.05);

          // Only apply subtle parallax to title with a minimum opacity
          const title = document.querySelector('.splash-title');
          if (title) {
            (title as HTMLElement).style.transform = `translateY(${parallaxAmount}px)`;
          }

          // Keep content visible with minimum opacity of 0.7
          const content = document.querySelector('.splash-content');
          if (content) {
            const contentOpacity = Math.max(0.7, 1 - scrollPos / 800);
            (content as HTMLElement).style.opacity = contentOpacity.toString();
            // No transform on content to keep it in place
            (content as HTMLElement).style.transform = 'none';
          }

          ticking = false;
        });

        ticking = true;
      }
    });
  }

  // Wait for the DOM to be fully loaded
  document.addEventListener('DOMContentLoaded', () => {
    // Setup scroll interaction on all devices (mobile friendly version)
    setupScrollInteraction();
  });
</script> 