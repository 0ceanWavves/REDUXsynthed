---
// src/components/ThreeJsSceneWrapper.astro
// Sets up the Three.js scene and manages the loading overlay.
import LoadingOverlay from './LoadingOverlay.astro';

// Props could be added here if needed (e.g., scene configuration)
---

<!-- Include the loading overlay -->
<LoadingOverlay />

<!-- Container for the Three.js canvas -->
<div id="three-container"></div>

<style>
  /* Ensure the container takes up space but stays hidden until loaded */
  #three-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1; /* Behind the overlay initially */
    visibility: hidden; /* Hide until loaded */
    opacity: 0; /* Start fully transparent */
    transition: opacity 0.5s ease-in-out, visibility 0.5s ease-in-out; /* Smooth transition */
    background-color: transparent; /* Changed to transparent so it doesn't flash */
  }
  
  /* Visible state that will be applied when loading completes */
  #three-container.visible {
    visibility: visible;
    opacity: 1;
  }
</style>

<script>
  // Import Three.js using regular import
  import * as THREE from 'three';
  
  // Also import from centralized loader as fallback
  import { loadThreeJS } from './three/utils/ThreeJSLoader.js';

  // Wait for the full page to load, including styles and potentially the spinner script
  window.addEventListener('load', async () => {
    let THREE_INSTANCE = THREE;
    
    try {
      // Try to get Three.js from centralized loader if regular import failed
      if (!THREE_INSTANCE || Object.keys(THREE_INSTANCE).length === 0) {
        console.log("Regular THREE import failed, using centralized loader");
        THREE_INSTANCE = await loadThreeJS();
      }
      
      if (!THREE_INSTANCE) {
        throw new Error("Failed to load Three.js");
      }
    } catch (error) {
      console.error("Failed to load Three.js:", error);
      // If loading overlay exists, add error message
      const loadingEl = document.getElementById('loading-overlay');
      if (loadingEl) {
        loadingEl.innerHTML += '<p style="color:red">Error loading 3D engine. Please try refreshing.</p>';
      }
      return;
    }
    
    const container = document.getElementById('three-container');
    const loadingOverlay = document.getElementById('loading-overlay');

    if (!container || !loadingOverlay) {
      console.error('Required elements (container or overlay) not found!');
      return;
    }

    // Add loading class to body to prevent scrolling while Three.js loads
    document.body.classList.add('loading-active');
    document.documentElement.classList.add('loading-active');

    let renderer = null; // Keep track for cleanup
    let animationFrameId = null;
    let scene = null;
    let camera = null;
    let cube = null; // Example object
    let hasManagedItems = false; // Flag to track if manager loads anything

    function initThree() {
      if (!container) return;

      // --- Scene Setup ---
      scene = new THREE_INSTANCE.Scene();
      camera = new THREE_INSTANCE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
      renderer = new THREE_INSTANCE.WebGLRenderer({ 
        antialias: true,
        alpha: true // Make renderer background transparent if needed
      });
      
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(window.devicePixelRatio);
      container.appendChild(renderer.domElement);

      // --- Loading Manager ---
      const loadingManager = new THREE_INSTANCE.LoadingManager(
        // onLoad: Called only when items loaded via the manager are complete
        () => {
          console.log('Three.js resources loaded via LoadingManager');
          hideLoadingOverlay();
          startAnimation(); // Start animation after loading
        },
        // onProgress: Called during loading of managed items
        (url, itemsLoaded, itemsTotal) => {
          const progress = itemsTotal > 0 ? (itemsLoaded / itemsTotal) * 100 : 100;
          console.log(`Loading Three.js: ${progress.toFixed(0)}% (${itemsLoaded}/${itemsTotal}) - ${url}`);
          // Optionally update a progress indicator within the overlay here
        },
        // onError: Called if a managed item fails to load
        (url) => {
          console.error('Error loading Three.js resource:', url);
          hideLoadingOverlay(); // Still hide overlay on error
          // Maybe display an error message instead of starting the scene
        }
      );

      // onStart: Called when the first managed item starts loading
      loadingManager.onStart = (url, itemsLoaded, itemsTotal) => {
          console.log(`Started loading first item: ${url} (${itemsLoaded}/${itemsTotal})`);
          hasManagedItems = true; // Set flag indicating manager is active
      };

      // --- Setup complete, check if the manager was used ---
      // We need to wait a microtask tick to ensure any synchronous load calls
      // within loaders might have triggered onStart.
      setTimeout(() => {
        if (!hasManagedItems) {
          console.log("No assets were loaded via LoadingManager. Hiding overlay.");
          hideLoadingOverlay();
          startAnimation();
        }
        // If hasManagedItems is true, the onLoad or onError handlers will
        // take care of hiding the overlay and starting the animation.
      }, 0);

      if (camera) {
        camera.position.z = 5;
      }

      // --- Handle Window Resize ---
      window.addEventListener('resize', handleResize);
    }

    function hideLoadingOverlay() {
      if (loadingOverlay) {
        // Add hidden class to loading overlay
        loadingOverlay.classList.add('hidden');
        
        // Immediately make the Three.js container visible but with transition
        if (container) {
          container.classList.add('visible');
        }
        
        // Remove from DOM after transition for cleanliness (optional)
        setTimeout(() => {
          // Check if it still has a parent before removing
          if (loadingOverlay.parentNode) {
            loadingOverlay.remove();
            console.log('Loading overlay removed from DOM');
          }
        }, 500); // Match CSS transition duration
      }
      
      // Re-enable scrolling
      document.body.classList.remove('loading-active');
      document.documentElement.classList.remove('loading-active');
      console.log('Loading overlay hidden, scrolling enabled.');
    }

    function startAnimation() {
        if (animationFrameId === null) { // Prevent multiple loops
           animate();
        }
    }

    // --- Animation Loop ---
    function animate() {
      if (!renderer || !scene || !camera) return;
      animationFrameId = requestAnimationFrame(animate);
      
      // Example animation (if cube exists)
      if (cube) {
        cube.rotation.x += 0.01;
        cube.rotation.y += 0.01;
      }
      
      renderer.render(scene, camera);
    }

    // --- Handle Window Resize ---
    function handleResize() {
      if (camera && renderer) {
         camera.aspect = window.innerWidth / window.innerHeight;
         camera.updateProjectionMatrix();
         renderer.setSize(window.innerWidth, window.innerHeight);
      }
    }

    // --- Cleanup on Unload/Navigation ---
    function cleanup() {
        console.log('Cleaning up Three.js scene...');
        window.removeEventListener('resize', handleResize);
        if (animationFrameId !== null) {
           cancelAnimationFrame(animationFrameId);
           animationFrameId = null;
        }
        if (container && renderer?.domElement && container.contains(renderer.domElement)) {
           container.removeChild(renderer.domElement);
        }
        renderer?.dispose();
        // Dispose geometry, materials, textures here if needed
        scene = null;
        camera = null;
        renderer = null;
        cube = null;
        // Ensure loading styles are removed
        document.body.classList.remove('loading-active');
        document.documentElement.classList.remove('loading-active');
    }

    // Use Astro's page lifecycle events for cleanup if available and needed,
    // especially with View Transitions. Otherwise, rely on unload.
    document.addEventListener('astro:before-swap', cleanup, { once: true });
    window.addEventListener('unload', cleanup, { once: true });

    // --- Start Initialization ---
    initThree();
  }); // End window.onload
</script>