---
// InteractionHint.astro - Component for showing a swipe hint for the 3D object
---

<div id="interaction-hint" class="interaction-hint">
  <div class="hint-arrow">
    <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M20 5L35 20L20 35" stroke="rgba(255, 255, 255, 0.8)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M5 20H35" stroke="rgba(255, 255, 255, 0.8)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
  <div class="hint-text">Drag to rotate</div>
</div>

<style>
  .interaction-hint {
    position: absolute;
    top: calc(70% + 10px); /* Adjusted to sit perfectly between "Build" and "Transforming ideas into" */
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
    z-index: 100;
    opacity: 0;
    animation: fadeInOut 3s ease-in-out 3s forwards;
  }

  .hint-arrow {
    position: relative;
    animation: swipeHint 2s ease-in-out infinite;
  }

  .hint-text {
    margin-top: 10px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
    font-family: 'Inter', sans-serif;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
    opacity: 0.8;
  }

  @keyframes swipeHint {
    0%, 100% {
      transform: translateX(-15px);
    }
    50% {
      transform: translateX(15px);
    }
  }

  @keyframes fadeInOut {
    0% {
      opacity: 0;
    }
    20%, 80% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  /* Mobile optimization adjustments */
  @media (max-width: 768px) {
    .interaction-hint {
      top: calc(75% + 5px); /* Better positioning for mobile */
      transform: translate(-50%, -50%) scale(0.9);
    }
  }

  /* Reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .interaction-hint {
      animation: none;
      opacity: 1;
    }
    
    .hint-arrow {
      animation: none;
    }
  }
</style>

<script>
  // Only show the hint if not on a touch device
  document.addEventListener('DOMContentLoaded', () => {
    const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
    const interactionHint = document.getElementById('interaction-hint');
    
    if (interactionHint) {
      if (isTouchDevice) {
        // On touch devices, change the text to "Swipe to rotate"
        const hintText = interactionHint.querySelector('.hint-text');
        if (hintText) {
          hintText.textContent = 'Swipe to rotate';
        }
      }
      
      // Remove the hint after animation completes
      setTimeout(() => {
        if (interactionHint && interactionHint.parentNode) {
          interactionHint.style.display = 'none';
        }
      }, 6000); // 3s delay + 3s animation
    }
  });
</script>
