---
// SplashContent.astro - Component for the content section
---

<div class="splash-content w-full max-w-2xl text-center mt-3 md:mt-4 browser-optimized-text pointer-events-none px-5 mx-auto">
  <div class="text-white text-lg md:text-xl leading-relaxed">
    <p class="mb-1 content-item">Transforming ideas into</p>
    <p class="text-primary text-2xl md:text-3xl font-bold mb-2 md:mb-3 content-item">Digital Solutions</p>
    
    <!-- Service items with better spacing -->
    <div class="flex flex-col items-center md:flex-row md:flex-wrap justify-center gap-2 md:gap-3 mb-5 md:mb-6">
      <div class="flex items-center justify-center gap-2 content-item w-full md:w-auto">
        <div class="check-circle">
          <!-- SVG Check Circle -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-400" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
        </div>
        <p class="text-center">Custom Business Applications</p>
      </div>
      <div class="flex items-center justify-center gap-2 content-item w-full md:w-auto">
        <div class="check-circle">
          <!-- SVG Check Circle -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-400" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
        </div>
        <p class="text-center">Modern Web & Mobile Development</p>
      </div>
      <div class="flex items-center justify-center gap-2 content-item w-full md:w-auto">
        <div class="check-circle">
          <!-- SVG Check Circle -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-400" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
        </div>
        <p class="text-center">Strategic Technology Consulting</p>
      </div>
      <div class="flex items-center justify-center gap-2 content-item w-full md:w-auto">
        <div class="check-circle">
          <!-- SVG Check Circle -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-400" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
        </div>
        <p class="text-center">UI/UX Design Excellence</p>
      </div>
    </div>
  </div>
</div>

<style>
  /* Browser optimizations */
  .browser-optimized-text {
    /* Force proper stacking context in all browsers */
    transform: translateZ(0);
    will-change: transform, opacity;

    /* Prevent flickering */
    backface-visibility: hidden;

    /* Improve text rendering */
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Mobile specific adjustments */
  @media (max-width: 768px) {
    /* Move content to create more room around the 3D object */
    .splash-content {
      max-width: 100%;
      opacity: 0.95;
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
    }
    
    /* Add text outline for better readability against 3D background */
    .splash-content p {
      text-shadow: 0 1px 3px rgba(0, 0, 0, 0.7);
    }
    
    .text-primary {
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.6);
    }
  }

  /* Content item and check circle animation */
  .content-item, .check-circle {
    opacity: 0;
    will-change: opacity, transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .content-item, .check-circle {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script>
  function animateContentItems() {
    if (typeof window === 'undefined') return;

    // Content items animation
    const contentItems = document.querySelectorAll('.content-item');
    const contentObserver = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          contentItems.forEach((item, index) => {
            const el = item as HTMLElement;
            setTimeout(() => {
              el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
              el.style.opacity = '1';
              el.style.transform = 'translateY(0)';
            }, 600 + (index * 150));
          });
          contentObserver.disconnect();
        }
      },
      { threshold: 0.1 }
    );

    if (contentItems.length > 0) {
      contentItems.forEach(item => {
        (item as HTMLElement).style.opacity = '0';
        (item as HTMLElement).style.transform = 'translateY(20px)';
      });
      contentObserver.observe(contentItems[0] as HTMLElement);
    }

    // Check circles animation
    const checkCircles = document.querySelectorAll('.check-circle');
    const checkObserver = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          checkCircles.forEach((circle, index) => {
            const el = circle as HTMLElement;
            setTimeout(() => {
              el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
              el.style.opacity = '1';
              el.style.transform = 'scale(1)';
            }, 800 + (index * 100));
          });
          checkObserver.disconnect();
        }
      },
      { threshold: 0.1 }
    );

    if (checkCircles.length > 0) {
      checkCircles.forEach(circle => {
        (circle as HTMLElement).style.opacity = '0';
        (circle as HTMLElement).style.transform = 'scale(0)';
      });
      checkObserver.observe(checkCircles[0].parentElement as HTMLElement);
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    animateContentItems();
  });
</script> 