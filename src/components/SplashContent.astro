---
// SplashContent.astro - Main component for the content section
import AnimationUtils from './AnimationUtils.astro';
import SplashHeading from './SplashHeading.astro';
import ServiceBullets from './ServiceBullets.astro';
---

<AnimationUtils />

<div class="splash-content w-full max-w-2xl text-center mt-3 md:mt-4 browser-optimized-text px-5 mx-auto" style="z-index: 90;">
  <div class="text-white text-lg md:text-xl leading-relaxed">
    <SplashHeading />
    <ServiceBullets />
  </div>
</div>

<!-- Import the letter animation script -->
<script src="../scripts/letter-animation.js"></script>
