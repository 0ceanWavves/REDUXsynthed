---
// SplashContent.astro - Component for the content section
---

<div class="splash-content w-full max-w-2xl text-center mt-3 md:mt-4 browser-optimized-text px-5 mx-auto" style="z-index: 90;">
  <div class="text-white text-lg md:text-xl leading-relaxed">
    <!-- Removed duplicate Create Design Build text -->
    
    <p class="mb-1 content-item" style="opacity: 1; transform: none;">Transforming ideas into</p>
    
    <!-- Digital Solutions heading -->
    <p class="text-primary text-2xl md:text-3xl font-bold mb-4 md:mb-5 content-item pointer-events-none digital-solutions-text" style="opacity: 1; transform: none;">Digital Solutions</p>
    
    <!-- Service bullet points -->
    <div class="service-bullets my-4 mb-8">
      <div class="bullet-item"><span class="bullet">○</span> Custom Business Applications</div>
      <div class="bullet-item"><span class="bullet">○</span> Modern Web & Mobile Development</div>
      <div class="row-bullets">
        <div class="bullet-item"><span class="bullet">○</span> Strategic Technology Consulting</div>
        <div class="bullet-item"><span class="bullet">○</span> UI/UX Design Excellence</div>
      </div>
    </div>
    
    <!-- Removed the action buttons as they are in SplashActionButtons component -->
  </div>
</div>

<style>
  /* Browser optimizations */
  .browser-optimized-text {
    /* Force proper stacking context in all browsers */
    transform: translateZ(0);
    will-change: transform, opacity;

    /* Prevent flickering */
    backface-visibility: hidden;

    /* Improve text rendering */
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    
    /* Ensure content is visible above 3D elements */
    position: relative;
    z-index: 75;
  }

  /* Digital Solutions text styling */
  .digital-solutions-text {
    text-shadow: 0 0 15px rgba(0, 229, 153, 0.7);
    animation: fadeInUp 0.8s ease-out both;
    animation-delay: 0.7s;
  }

  @keyframes fadeInUp {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Ensure text visibility */
  .splash-content {
    color: white !important;
    visibility: visible !important;
    opacity: 1 !important;
  }
  
  .splash-content p {
    opacity: 1 !important;
  }
  
  .text-primary {
    color: #00e599 !important;
    pointer-events: none !important;
  }
  
  /* Service bullets styling */
  .service-bullets {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin: 1rem 0;
    animation: fadeIn 0.8s ease-out both;
    animation-delay: 0.9s;
  }

  .bullet-item {
    display: flex;
    align-items: center;
    font-size: 0.9rem;
    color: white;
    margin: 0.25rem 0;
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
  }

  .bullet {
    color: white;
    margin-right: 0.5rem;
    font-size: 1.1rem;
  }

  .row-bullets {
    display: flex;
    gap: 1.5rem;
  }

  @keyframes fadeIn {
    0% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }
  
  /* Mobile adjustments */
  @media (max-width: 768px) {
    .row-bullets {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    console.log("SplashContent: Content initialization");
  });
</script>