---
// SplashContent.astro - Component for the content section
---

<div class="splash-content w-full max-w-2xl text-center mt-3 md:mt-4 browser-optimized-text pointer-events-none px-5 mx-auto" style="z-index: 90;">
  <div class="text-white text-lg md:text-xl leading-relaxed pointer-events-none">
    <p class="mb-1 content-item pointer-events-none" style="opacity: 1; transform: none;">Transforming ideas into</p>
    <p class="text-primary text-2xl md:text-3xl font-bold mb-2 md:mb-3 content-item pointer-events-none" style="opacity: 1; transform: none;">Digital Solutions</p>
    
    <!-- Service items with better spacing - All with pointer-events-none -->
    <div class="flex flex-col items-center md:flex-row md:flex-wrap justify-center gap-2 md:gap-3 mb-5 md:mb-6 pointer-events-none">
      <div class="flex items-center justify-center gap-2 content-item w-full md:w-auto pointer-events-none" style="opacity: 1; transform: none;">
        <div class="check-circle pointer-events-none" style="opacity: 1; transform: none;">
          <!-- SVG Check Circle -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-400 pointer-events-none" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
        </div>
        <p class="text-center pointer-events-none">Custom Business Applications</p>
      </div>
      <div class="flex items-center justify-center gap-2 content-item w-full md:w-auto pointer-events-none" style="opacity: 1; transform: none;">
        <div class="check-circle pointer-events-none" style="opacity: 1; transform: none;">
          <!-- SVG Check Circle -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-400 pointer-events-none" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
        </div>
        <p class="text-center pointer-events-none">Modern Web & Mobile Development</p>
      </div>
      <div class="flex items-center justify-center gap-2 content-item w-full md:w-auto pointer-events-none" style="opacity: 1; transform: none;">
        <div class="check-circle pointer-events-none" style="opacity: 1; transform: none;">
          <!-- SVG Check Circle -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-400 pointer-events-none" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
        </div>
        <p class="text-center pointer-events-none">Strategic Technology Consulting</p>
      </div>
      <div class="flex items-center justify-center gap-2 content-item w-full md:w-auto pointer-events-none" style="opacity: 1; transform: none;">
        <div class="check-circle pointer-events-none" style="opacity: 1; transform: none;">
          <!-- SVG Check Circle -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-400 pointer-events-none" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
        </div>
        <p class="text-center pointer-events-none">UI/UX Design Excellence</p>
      </div>
    </div>
  </div>
</div>

<style>
  /* Make sure ALL elements have pointer-events: none */
  .splash-content, .splash-content * {
    pointer-events: none !important;
  }

  /* Browser optimizations */
  .browser-optimized-text {
    /* Force proper stacking context in all browsers */
    transform: translateZ(0);
    will-change: transform, opacity;

    /* Prevent flickering */
    backface-visibility: hidden;

    /* Improve text rendering */
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    
    /* Ensure content is visible above 3D elements */
    position: relative;
    z-index: 75;
    pointer-events: none !important;
  }

  /* Mobile specific adjustments */
  @media (max-width: 768px) {
    /* Move content to create more room around the 3D object */
    .splash-content {
      max-width: 100%;
      opacity: 0.95;
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
      pointer-events: none !important;
    }
    
    /* Add text outline for better readability against 3D background */
    .splash-content p {
      text-shadow: 0 1px 3px rgba(0, 0, 0, 0.7);
      pointer-events: none !important;
    }
    
    .text-primary {
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.6);
      pointer-events: none !important;
    }
  }

  /* Override content item animation to ensure visibility */
  .content-item, .check-circle {
    opacity: 1 !important;
    transform: none !important;
    pointer-events: none !important;
  }

  /* Ensure text visibility */
  .splash-content {
    color: white !important;
    visibility: visible !important;
    opacity: 1 !important;
    pointer-events: none !important;
  }
  
  .splash-content p {
    opacity: 1 !important;
    pointer-events: none !important;
  }
  
  .text-primary {
    color: #00e599 !important;
    pointer-events: none !important;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    console.log("SplashContent: Content initialization");
    
    // Apply pointer-events: none to ALL elements in the splash content
    const allElements = document.querySelectorAll('.splash-content, .splash-content *');
    allElements.forEach(item => {
      if (item instanceof HTMLElement) {
        item.style.opacity = '1';
        item.style.transform = 'none';
        item.style.pointerEvents = 'none'; // Ensure all elements pass through clicks
      }
    });
  });
</script>