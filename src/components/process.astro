---
// import { Icon } from "astro-icon/components";
import Icon from "./Icon.astro";
import ContentSection from "~/components/content-section.astro";

const processSteps = [
  {
    title: "Strategy & Planning",
    description: "Together, we develop a tailored roadmap that aligns technology solutions with your specific business needs.",
    icon: "mdi:strategy",
    iconClass: "step-icon-strategy",
  },
  {
    title: "Design & Development",
    description: "Our experts build your solution using modern technologies and best practices, with regular feedback loops throughout.",
    icon: "mdi:code-tags",
    iconClass: "step-icon-design",
  },
  {
    title: "Testing & Deployment",
    description: "Rigorous quality assurance ensures your product is robust, secure, and performs optimally before launch.",
    icon: "mdi:test-tube",
    iconClass: "step-icon-testing",
  },
  {
    title: "Launch & Support",
    description: "We ensure a smooth launch and provide ongoing support, maintenance, and iterative improvements to your solution.",
    icon: "mdi:rocket-launch",
    iconClass: "step-icon-launch",
  },
];
---

<ContentSection title="Our Process" id="process">
  <Fragment slot="lead">
    A <span class="text-primary">structured approach</span> that delivers 
    <span class="text-primary">consistent results</span>.
  </Fragment>
  
  <div class="timeline-container max-w-5xl mx-auto">
    <!-- Vertical timeline line -->
    <div class="timeline-line"></div>
    
    <!-- Process steps -->
    {
      processSteps.map((step, index) => (
        <div class="process-step" data-index={index}>
          <!-- Timeline indicator/dot -->
          <div class="timeline-indicator" style={`top: ${index * 25 + 12}%`}></div>
          
          <div class="flex items-start gap-4">
            <div class={`text-4xl ${step.iconClass}`}>
              <Icon name={step.icon} class="h-10 w-10" />
            </div>
            <div>
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</ContentSection>

<script>
  function animateProcessSteps() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const step = entry.target;
          const index = parseInt((step as HTMLElement).dataset.index || '0', 10);
          
          // Staggered animation for each step
          setTimeout(() => {
            (step as HTMLElement).style.transition = 'opacity 0.8s ease, transform 0.8s ease';
            (step as HTMLElement).style.opacity = '1';
            (step as HTMLElement).style.transform = 'translateY(0)';
          }, 200 * index);
          
          observer.unobserve(step);
        }
      });
    }, { threshold: 0.2 });
    
    // Observe all process steps
    document.querySelectorAll('.process-step').forEach((step) => {
      observer.observe(step);
    });
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    // Force immediate visibility for all steps while keeping animations
    setTimeout(() => {
      document.querySelectorAll('.process-step').forEach((step) => {
        (step as HTMLElement).style.opacity = '1';
        (step as HTMLElement).style.transform = 'translateY(0)';
      });
    }, 1000);
    
    animateProcessSteps();
  });
</script>
