---
// SimpleObject3D.astro - A simple Three.js 3D object that can be placed anywhere on the site
export interface Props {
  containerId?: string;  // ID for the container element
  width?: string;        // Width of the container (CSS value)
  height?: string;       // Height of the container (CSS value)
  position?: string;     // CSS position value
  top?: string;          // CSS top value
  left?: string;         // CSS left value
  right?: string;        // CSS right value
  bottom?: string;       // CSS bottom value
  zIndex?: number;       // Z-index for the container
  objectColor?: string;  // Color for the 3D object
  objectType?: 'cube' | 'sphere' | 'torus' | 'pyramid'; // Type of object to render
  background?: string;   // Background color/gradient for the container
  autoRotate?: boolean;  // Whether the object should auto-rotate
  interactive?: boolean; // Whether the object is interactive (mouse control)
}

const {
  containerId = "simple-3d-object",
  width = "100%",
  height = "300px",
  position = "relative",
  top = "auto",
  left = "auto",
  right = "auto",
  bottom = "auto",
  zIndex = 10,
  objectColor = "#6d28d9", // Purple default to match site theme
  objectType = "cube",
  background = "transparent",
  autoRotate = true,
  interactive = true
} = Astro.props;
---

<div 
  id={containerId} 
  class="simple-3d-container"
  style={`
    width: ${width}; 
    height: ${height}; 
    position: ${position}; 
    top: ${top}; 
    left: ${left}; 
    right: ${right}; 
    bottom: ${bottom}; 
    z-index: ${zIndex};
    background: ${background};
    overflow: hidden;
    touch-action: none; /* Prevent scroll within container only */
  `}
>
  <!-- Canvas will be created and appended by Three.js -->
</div>

<script define:vars={{ 
  containerId, 
  objectColor, 
  objectType, 
  autoRotate, 
  interactive 
}}>
// We'll use the global THREE object which is set by three-loader.js
// Import OrbitControls dynamically
let OrbitControls;

// Initialize the 3D scene when the DOM is fully loaded
document.addEventListener('DOMContentLoaded', async () => {
  try {
    // Dynamically import OrbitControls
    const OrbitControlsModule = await import('three/examples/jsm/controls/OrbitControls.js');
    OrbitControls = OrbitControlsModule.OrbitControls;
    
    // Make sure THREE is defined
    if (!window.THREE) {
      console.error('THREE is not defined. Make sure three-loader.js is loaded before this script.');
      return;
    }
    
    // Get the container element
    const container = document.getElementById(containerId);
    if (!container) {
      console.error(`Container with ID "${containerId}" not found.`);
      return;
    }
    
    // Create scene, camera, and renderer
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(
      75, // Field of view
      container.clientWidth / container.clientHeight, // Aspect ratio
      0.1, // Near clipping plane
      1000 // Far clipping plane
    );
    
    // Set camera position
    camera.position.z = 5;
    
    // Create WebGL renderer
    const renderer = new THREE.WebGLRenderer({ 
      antialias: true,
      alpha: true // Enable transparency
    });
    
    // Set renderer size and pixel ratio
    renderer.setSize(container.clientWidth, container.clientHeight);
    renderer.setPixelRatio(window.devicePixelRatio);
    renderer.setClearColor(0x000000, 0); // Transparent background
    
    // Important: Set canvas style to prevent scrolling issues on mobile
    renderer.domElement.style.touchAction = 'none';
    
    // Append renderer's canvas to container
    container.appendChild(renderer.domElement);
    
    // Add orbital controls if interactive
    let controls;
    if (interactive && OrbitControls) {
      controls = new OrbitControls(camera, renderer.domElement);
      controls.enableDamping = true;
      controls.dampingFactor = 0.1;
      controls.enableZoom = false;
      
      // Important: Limit controls to the container area only
      controls.domElement = renderer.domElement;
      
      // Configure controls for better mobile experience
      controls.enablePan = false; // Disable panning
      
      // Detect mobile device
      const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
      
      if (isMobile) {
        // Set specific limits for mobile rotation
        controls.minPolarAngle = Math.PI * 0.1; // Limit up rotation
        controls.maxPolarAngle = Math.PI * 0.9; // Limit down rotation
        controls.rotateSpeed = 0.5; // Slower rotation for mobile
        
        // Prevent touch events from propagating outside the canvas
        renderer.domElement.addEventListener('touchstart', function(e) {
          e.preventDefault();
          e.stopPropagation();
        }, { passive: false });
        
        renderer.domElement.addEventListener('touchmove', function(e) {
          e.preventDefault();
          e.stopPropagation();
        }, { passive: false });
        
        renderer.domElement.addEventListener('touchend', function(e) {
          e.preventDefault();
          e.stopPropagation();
        }, { passive: false });
      }
    }
    
    // Add lights
    const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
    scene.add(ambientLight);
    
    const directionalLight = new THREE.DirectionalLight(0xffffff, 1);
    directionalLight.position.set(5, 5, 5);
    scene.add(directionalLight);
    
    // Create geometry based on objectType
    let geometry;
    switch (objectType) {
      case 'sphere':
        geometry = new THREE.SphereGeometry(2, 32, 32);
        break;
      case 'torus':
        geometry = new THREE.TorusGeometry(1.5, 0.5, 16, 100);
        break;
      case 'pyramid':
        geometry = new THREE.ConeGeometry(1.5, 3, 4);
        break;
      case 'cube':
      default:
        geometry = new THREE.BoxGeometry(2, 2, 2);
        break;
    }
    
    // Create material
    const material = new THREE.MeshStandardMaterial({
      color: objectColor,
      roughness: 0.3,
      metalness: 0.7,
    });
    
    // Create mesh by combining geometry and material
    const mesh = new THREE.Mesh(geometry, material);
    scene.add(mesh);
    
    // Handle window resize
    window.addEventListener('resize', () => {
      // Update camera aspect ratio
      camera.aspect = container.clientWidth / container.clientHeight;
      camera.updateProjectionMatrix();
      
      // Update renderer size
      renderer.setSize(container.clientWidth, container.clientHeight);
    });
    
    // Animation loop
    function animate() {
      requestAnimationFrame(animate);
      
      // Auto-rotate the object if enabled
      if (autoRotate) {
        mesh.rotation.x += 0.005;
        mesh.rotation.y += 0.01;
      }
      
      // Update controls if interactive
      if (interactive && controls) {
        controls.update();
      }
      
      // Render the scene
      renderer.render(scene, camera);
    }
    
    // Start animation loop
    animate();
    
    console.log(`3D object initialized in container #${containerId}`);
  } catch (error) {
    console.error('Error initializing 3D object:', error);
  }
});
</script>
