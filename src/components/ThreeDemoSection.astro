---
import SimpleObject3D from '~/components/three/SimpleObject3D.astro';
---

<section id="three-demo-section" class="py-20 bg-gradient-to-b from-slate-900 to-indigo-900 text-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Interactive 3D Experience</h2>
      <p class="text-xl text-slate-300 max-w-3xl mx-auto">
        Explore our cutting-edge 3D capabilities. Drag to rotate the object and see how we 
        bring digital experiences to life with modern web technologies.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
      <div class="order-2 md:order-1">
        <h3 class="text-2xl font-bold mb-4">Why 3D Matters</h3>
        <ul class="space-y-4">
          <li class="flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-indigo-400 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>Increased user engagement with interactive elements</span>
          </li>
          <li class="flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-indigo-400 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>Memorable brand experiences that set you apart</span>
          </li>
          <li class="flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-indigo-400 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>Showcase products in a dynamic, immersive way</span>
          </li>
          <li class="flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-indigo-400 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>Future-proof technology that grows with your needs</span>
          </li>
        </ul>
      </div>
      
      <div class="order-1 md:order-2 bg-gray-900 rounded-lg p-4 shadow-lg">
        <!-- This is where our 3D object component goes with a special mobile class -->
        <div class="relative three-demo-wrapper rounded-lg overflow-hidden">
          <SimpleObject3D 
            containerId="demo-3d-object" 
            height="350px" 
            objectType="torus" 
            objectColor="#8b5cf6"
            autoRotate={true}
            interactive={true}
            background="linear-gradient(135deg, rgba(15,23,42,0.8) 0%, rgba(49,46,129,0.8) 100%)"
          />
          <!-- Mobile instruction overlay -->
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none mobile-only-instruction">
            <div class="bg-indigo-900 bg-opacity-70 text-white px-4 py-2 rounded-full text-sm">
              <span class="flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11.5V14m0-2.5v-6a2.5 2.5 0 115 0v6a2.5 2.5 0 01-5 0z" />
                </svg>
                Tap and drag to rotate
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Only show mobile instruction on mobile devices */
  .mobile-only-instruction {
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  /* Show instruction on mobile */
  html.mobile .mobile-only-instruction {
    opacity: 1;
  }
  
  /* Hide after 5 seconds */
  @media (max-width: 767px) {
    .three-demo-wrapper:hover .mobile-only-instruction {
      opacity: 0;
    }
  }
</style>

<script>
  // Hide the mobile instruction after 5 seconds
  document.addEventListener('DOMContentLoaded', function() {
    const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
    
    if (isMobile) {
      setTimeout(() => {
        const instruction = document.querySelector('.mobile-only-instruction');
        if (instruction) {
          (instruction as HTMLElement).style.opacity = '0';
        }
      }, 5000);
    }
  });
</script>
