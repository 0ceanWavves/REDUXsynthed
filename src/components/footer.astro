---
import { Icon } from "astro-icon/components";
import HeroImage from "~/components/hero-image.astro";
import type { FooterLink } from "~/types";

const links: Array<FooterLink> = [
  {
    url: "https://github.com/synthed",
    description: "Synthed on GitHub",
    icon: "fa-brands:github-alt",
  },
  {
    url: "https://twitter.com/syntheddev",
    description: "Synthed on Twitter",
    icon: "fa-brands:twitter",
  },
  {
    url: "https://linkedin.com/company/synthed",
    description: "Synthed on LinkedIn",
    icon: "fa-brands:linkedin",
  },
  {
    url: "mailto:contact@synthed.dev",
    description: "Email Synthed",
    icon: "mdi:email",
  },
];
---

<footer class="relative flex h-64 items-center justify-center" id="contact">
  <div class="absolute inset-0 overflow-hidden opacity-40">
    <HeroImage />
  </div>
  <div class="relative flex flex-col items-center gap-8">
    <div class="text-center">
      <h2 class="text-2xl font-bold mb-2">Get in Touch</h2>
      <p class="text-offset">Let's discuss your next project</p>
    </div>
    <ul class="grid grid-cols-2 gap-4 sm:grid-cols-4">
      {
        links.map((link) => (
          <li>
            <a
              class="flex h-16 w-16 items-center justify-center rounded-full border-2 border-current p-4"
              href={link.url}
            >
              <span class="sr-only">{link.description}</span>
              <Icon class="h-full w-full" name={link.icon} />
            </a>
          </li>
        ))
      }
    </ul>
    <p class="text-center text-sm text-offset">
      © {new Date().getFullYear()} Synthed. All rights reserved.
    </p>
  </div>
</footer>
