<!-- ServiceTiles.astro - Wrapper for Three.js animated tiles -->
<!-- No need to load Three.js again, it's already in the main page -->

<style>
  /* Service tile styles */
  .service-card-inner {
    /* Enhance the inner card to accommodate the 3D background */
    position: relative;
    background: rgba(15, 15, 25, 0.4) !important; /* Semi-transparent background */
    backdrop-filter: blur(5px); /* Blur effect for glass morphism */
    -webkit-backdrop-filter: blur(5px);
    border: 1px solid rgba(255, 255, 255, 0.05); /* Subtle border */
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
  }

  .service-card-inner:hover {
    background: rgba(20, 20, 35, 0.5) !important;
    transform: translateY(-8px) scale(1.02) !important;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
  }

  /* Make sure content is properly positioned above the canvas */
  .service-card-inner > *:not(.tile-canvas-container) {
    position: relative; /* Ensure content stays above canvas */
    z-index: 2; /* Higher than the canvas container */
  }
  
  /* Animation for icons */
  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
  }
  
  .service-card-inner:hover .icon-container {
    animation: pulse 2s ease-in-out infinite;
  }
</style>

<script>
// Import only the initializer
import { initializeServiceTiles } from './serviceTilesInit.js';

// Removed the ServiceTiles class definition (moved to ServiceTiles.js)
// Removed export { ServiceTiles };

// Wait for DOM content to be loaded before attempting initialization
document.addEventListener('DOMContentLoaded', () => {
  console.log("DOM Content Loaded in ServiceTiles.astro - calling initializer.");
  
  // Removed the check for window.THREE and setTimeout logic.
  // The module system handles the timing.
  initializeServiceTiles(); 
});
</script>
