<!-- ServiceTiles.astro - Wrapper for Three.js animated tiles -->
<!-- No need to load Three.js again, it's already in the main page -->

<style>
  /* Service tile styles */
  .service-card-inner {
    /* Enhance the inner card to accommodate the 3D background */
    position: relative;
    background: rgba(15, 15, 25, 0.4) !important; /* Semi-transparent background */
    backdrop-filter: blur(5px); /* Blur effect for glass morphism */
    -webkit-backdrop-filter: blur(5px);
    border: 1px solid rgba(255, 255, 255, 0.05); /* Subtle border */
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
  }

  .service-card-inner:hover {
    background: rgba(20, 20, 35, 0.5) !important;
    transform: translateY(-8px) scale(1.02) !important;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
  }

  /* Make sure content is properly positioned above the canvas */
  .service-card-inner > *:not(.tile-canvas-container) {
    position: relative; /* Ensure content stays above canvas */
    z-index: 2; /* Higher than the canvas container */
  }
  
  /* Animation for icons */
  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
  }
  
  .service-card-inner:hover .icon-container {
    animation: pulse 2s ease-in-out infinite;
  }
</style>

<script is:inline>
/**
 * ServiceTiles - Animated 3D tiles for service cards
 */
document.addEventListener('DOMContentLoaded', () => {
  // Make sure THREE is defined before proceeding
  if (typeof THREE === 'undefined') {
    console.error('THREE is not defined. Make sure Three.js is loaded.');
    return;
  }
  
  console.log('Initializing ServiceTiles...');
  
  class ServiceTiles {
    constructor() {
      this.scenes = [];
      this.cameras = [];
      this.renderers = [];
      this.meshes = [];
      this.canvases = [];
      this.animationFrameIds = [];
      this.serviceCards = document.querySelectorAll('.service-card');
      this.isInitialized = false;
      this.colors = [
        '#4f46e5', // Indigo
        '#2563eb', // Blue
        '#0ea5e9', // Sky blue
        '#10b981', // Emerald
        '#6366f1', // Violet
        '#8b5cf6'  // Purple
      ];
      
      console.log(`Found ${this.serviceCards.length} service cards`);
    }

    init() {
      if (this.isInitialized || !this.serviceCards.length) return;
      
      // For each service card, create a 3D scene
      this.serviceCards.forEach((card, index) => {
        this.setupTileForCard(card, index);
      });
      
      this.isInitialized = true;
      
      // Initialize resize and visibility listeners
      this.setupEventListeners();

      // Start animation for visible tiles
      this.checkVisibility();
    }

    setupTileForCard(card, index) {
      console.log(`Setting up tile for card ${index}`);
      
      // Create container for the canvas
      const canvasContainer = document.createElement('div');
      canvasContainer.className = 'tile-canvas-container';
      canvasContainer.style.position = 'absolute';
      canvasContainer.style.top = '0';
      canvasContainer.style.left = '0';
      canvasContainer.style.width = '100%';
      canvasContainer.style.height = '100%';
      canvasContainer.style.zIndex = '0';
      canvasContainer.style.borderRadius = '0.5rem';
      canvasContainer.style.overflow = 'hidden';
      canvasContainer.style.pointerEvents = 'none';
      
      // Find the inner element to append to
      const cardInner = card.querySelector('.service-card-inner');
      if (cardInner) {
        // Insert the canvas container at the start of the card inner
        cardInner.insertBefore(canvasContainer, cardInner.firstChild);
        
        // Create Three.js scene
        this.createScene(canvasContainer, index);
      }
    }

    createScene(container, index) {
      // Create a new scene
      const scene = new THREE.Scene();
      
      // Create camera
      const camera = new THREE.PerspectiveCamera(50, container.offsetWidth / container.offsetHeight, 0.1, 1000);
      camera.position.z = 3;
      
      // Create renderer
      const canvas = document.createElement('canvas');
      canvas.style.width = '100%';
      canvas.style.height = '100%';
      container.appendChild(canvas);
      
      const renderer = new THREE.WebGLRenderer({
        canvas,
        alpha: true,
        antialias: true
      });
      renderer.setPixelRatio(window.devicePixelRatio);
      renderer.setSize(container.offsetWidth, container.offsetHeight);
      
      // Create the geometry based on index
      let geometry;
      switch (index % 3) {
        case 0:
          geometry = new THREE.BoxGeometry(1.5, 1.5, 0.2);
          break;
        case 1:
          geometry = new THREE.OctahedronGeometry(1);
          break;
        case 2:
          geometry = new THREE.IcosahedronGeometry(1);
          break;
      }
      
      // Apply color from palette
      const color = this.colors[index % this.colors.length];
      const material = new THREE.MeshPhongMaterial({
        color: color,
        transparent: true,
        opacity: 0.7,
        shininess: 80,
        side: THREE.DoubleSide
      });
      
      // Create mesh and add to scene
      const mesh = new THREE.Mesh(geometry, material);
      scene.add(mesh);
      
      // Add ambient light
      const ambientLight = new THREE.AmbientLight(0xffffff, 0.4);
      scene.add(ambientLight);
      
      // Add directional light
      const directionalLight = new THREE.DirectionalLight(0xffffff, 0.8);
      directionalLight.position.set(1, 1, 1);
      scene.add(directionalLight);
      
      // Add a backlight to create depth
      const backLight = new THREE.DirectionalLight(color, 0.5);
      backLight.position.set(-1, -1, -1);
      scene.add(backLight);
      
      // Store all the components
      this.scenes.push(scene);
      this.cameras.push(camera);
      this.renderers.push(renderer);
      this.meshes.push(mesh);
      this.canvases.push(canvas);
      this.animationFrameIds.push(null);
      
      // Initial render
      this.renderTile(index);
    }

    renderTile(index) {
      if (index >= this.scenes.length) return;
      
      const scene = this.scenes[index];
      const camera = this.cameras[index];
      const renderer = this.renderers[index];
      const mesh = this.meshes[index];
      
      // Animate the mesh
      const animate = () => {
        this.animationFrameIds[index] = requestAnimationFrame(animate);
        
        // Rotate mesh for animation effect
        mesh.rotation.x += 0.002;
        mesh.rotation.y += 0.003;
        
        // Subtle floating effect
        mesh.position.y = Math.sin(Date.now() * 0.001) * 0.05;
        
        // Render the scene
        renderer.render(scene, camera);
      };
      
      // Cancel any existing animation
      if (this.animationFrameIds[index]) {
        cancelAnimationFrame(this.animationFrameIds[index]);
      }
      
      // Start the animation
      animate();
    }

    stopRenderingTile(index) {
      if (this.animationFrameIds[index]) {
        cancelAnimationFrame(this.animationFrameIds[index]);
        this.animationFrameIds[index] = null;
      }
    }

    checkVisibility() {
      this.serviceCards.forEach((card, index) => {
        const rect = card.getBoundingClientRect();
        const isVisible = (
          rect.top < window.innerHeight &&
          rect.bottom > 0
        );
        
        if (isVisible && !this.animationFrameIds[index]) {
          this.renderTile(index);
        } else if (!isVisible && this.animationFrameIds[index]) {
          this.stopRenderingTile(index);
        }
      });
    }

    setupEventListeners() {
      // Handle window resize
      window.addEventListener('resize', () => {
        this.serviceCards.forEach((card, index) => {
          if (index < this.renderers.length) {
            const container = card.querySelector('.tile-canvas-container');
            if (container) {
              const renderer = this.renderers[index];
              const camera = this.cameras[index];
              
              // Update camera aspect ratio
              camera.aspect = container.offsetWidth / container.offsetHeight;
              camera.updateProjectionMatrix();
              
              // Update renderer size
              renderer.setSize(container.offsetWidth, container.offsetHeight);
            }
          }
        });
      });
      
      // Check visibility on scroll
      window.addEventListener('scroll', () => {
        this.checkVisibility();
      }, { passive: true });
    }

    dispose() {
      // Stop all animations
      this.animationFrameIds.forEach((id, index) => {
        if (id) {
          cancelAnimationFrame(id);
        }
      });
      
      // Dispose of all Three.js resources
      this.meshes.forEach(mesh => {
        if (mesh.geometry) mesh.geometry.dispose();
        if (mesh.material) {
          if (Array.isArray(mesh.material)) {
            mesh.material.forEach(material => material.dispose());
          } else {
            mesh.material.dispose();
          }
        }
      });
      
      // Clear arrays
      this.scenes = [];
      this.cameras = [];
      this.renderers = [];
      this.meshes = [];
      this.canvases = [];
      this.animationFrameIds = [];
      this.isInitialized = false;
    }
  }

  // Wait a moment for everything to load
  setTimeout(() => {
    try {
      console.log('Creating ServiceTiles instance');
      const serviceTiles = new ServiceTiles();
      serviceTiles.init();
      window.serviceTiles = serviceTiles; // For debugging
    } catch (error) {
      console.error('Error initializing ServiceTiles:', error);
    }
  }, 1000);
});
</script>
