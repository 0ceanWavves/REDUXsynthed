---
import ContentSection from "~/components/content-section.astro";
import { Icon } from "astro-icon/components";

const projects = [
  {
    title: "MRO Connect",
    description: "A HIPAA-compliant platform built for Medical Review Officers, streamlining review processes with secure, efficient solutions.",
    challenge: "The client needed a secure, compliant platform to manage sensitive medical review data while improving workflow efficiency.",
    solution: "We developed a custom HIPAA-compliant application with role-based access control, automated workflows, and secure document management.",
    results: "50% reduction in processing time, 99.9% uptime, and full compliance with all regulatory requirements.",
    icon: "mdi:medical-bag",
    link: "https://mroconnect.net",
    tags: ["Healthcare", "Compliance", "Workflow Automation"]
  },
  {
    title: "AgriWeather Pro",
    description: "Advanced weather analytics platform helping farmers optimize crop yields through AI-powered climate trend analysis and predictions.",
    challenge: "Agricultural businesses needed accurate, localized weather predictions to optimize planting and harvesting schedules.",
    solution: "We built a custom application integrating multiple weather data sources with machine learning algorithms to provide highly localized forecasts.",
    results: "Improved crop yields by 15-20% for client farms through more precise planning and reduced weather-related losses.",
    icon: "mdi:weather-cloudy",
    link: "#",
    tags: ["Agriculture", "AI/ML", "Data Analytics"]
  },
  {
    title: "FleetMaster Dashboard",
    description: "Custom enterprise dashboard for a logistics company, managing fleet operations, maintenance schedules, and performance metrics.",
    challenge: "A logistics company struggled to efficiently manage their growing fleet with disparate systems and manual processes.",
    solution: "We created a centralized dashboard that integrated with vehicle telematics, maintenance systems, and dispatch software.",
    results: "30% reduction in maintenance costs, 22% improvement in fleet utilization, and enhanced driver safety metrics.",
    icon: "mdi:view-dashboard-outline",
    link: "#",
    tags: ["Logistics", "IoT Integration", "Real-time Analytics"]
  },
  {
    title: "Prism Financial",
    description: "Secure client portal for a financial services firm providing investment tracking, document management, and advisory services.",
    challenge: "The client needed to modernize their legacy system to improve client engagement and meet evolving security requirements.",
    solution: "We developed a responsive web application with real-time data visualization, secure document sharing, and integrated communication tools.",
    results: "Client engagement increased by 45%, paperwork processing time reduced by 60%, and significant improvement in client retention.",
    icon: "mdi:chart-line",
    link: "https://prism-financial.com",
    tags: ["FinTech", "Security", "Client Portal"]
  },
];
---

<ContentSection title="Our Projects" id="projects">
  <Fragment slot="lead">
    Delivering <span class="text-primary">impactful solutions</span> that drive{" "}
    <span class="text-primary">measurable business outcomes</span>.
  </Fragment>
  
  <div class="grid grid-cols-1 gap-12 md:gap-16">
    {
      projects.map(({ title, description, challenge, solution, results, icon, link, tags }, index) => (
        <div class={`project-item flex flex-col lg:flex-row gap-8 ${index % 2 === 1 ? 'lg:flex-row-reverse' : ''}`} data-index={index}>
          <div class="project-business lg:w-1/3 flex flex-col items-center lg:items-start gap-4" data-project-id={index}>
            <div class="project-icon h-20 w-20 rounded-full border-2 border-current p-4 transition-colors">
              <Icon name={icon} class="h-full w-full" />
            </div>
            <h3 class="text-2xl font-bold text-center lg:text-left project-title">{title}</h3>
            <p class="text-center lg:text-left text-offset">{description}</p>
            <div class="flex flex-wrap gap-2 justify-center lg:justify-start">
              {tags.map(tag => (
                <span class="project-tag text-xs px-2 py-1 bg-blue-900/30 text-blue-300 rounded">{tag}</span>
              ))}
            </div>
            <a 
              href={link} 
              class="project-link mt-2 text-primary hover:underline flex items-center gap-1"
            >
              View Project <Icon name="mdi:arrow-right" class="h-4 w-4 arrow-icon" />
            </a>
          </div>
          
          <div class="project-card lg:w-2/3 p-6 rounded-lg" data-project-id={index}>
            <div class="connecting-line"></div>
            <h3 class="project-card-title md:hidden text-xl font-bold mb-4 text-primary">
              {title}
            </h3>
            <div class="space-y-4">
              <div class="project-section" data-section="challenge">
                <h4 class="font-bold mb-1">The Challenge</h4>
                <p class="text-sm text-offset">{challenge}</p>
              </div>
              <div class="project-section" data-section="solution">
                <h4 class="font-bold mb-1">Our Solution</h4>
                <p class="text-sm text-offset">{solution}</p>
              </div>
              <div class="project-section" data-section="results">
                <h4 class="font-bold mb-1">The Results</h4>
                <p class="text-sm text-offset">{results}</p>
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>
  
  <div class="mt-12 text-center">
    <a 
      href="#contact" 
      class="cta-button inline-flex items-center justify-center gap-3 border-2 border-current px-6 py-4 transition-colors duration-300 hover:bg-primary hover:text-white"
    >
      <Icon name="mdi:lightbulb-outline" class="h-6 w-6" />
      <span>Start Your Project</span>
    </a>
  </div>
</ContentSection>

<style>
  .project-item {
    opacity: 0;
    transform: translateY(40px);
    position: relative;
  }
  
  /* Visual connection between project title and description */
  .connecting-line {
    display: none;
  }
  
  @media (min-width: 1024px) {
    .connecting-line {
      display: block;
      position: absolute;
      background: linear-gradient(90deg, var(--color-primary), transparent);
      height: 2px;
      width: 40px;
      top: 30px;
    }
    
    .project-item:nth-child(odd) .connecting-line {
      left: -40px;
    }
    
    .project-item:nth-child(even) .connecting-line {
      right: -40px;
      background: linear-gradient(270deg, var(--color-primary), transparent);
    }
  }
  
  /* Enhance the project title to make it stand out */
  .project-title {
    position: relative;
    color: var(--color-primary);
    display: inline-block;
    transition: all 0.3s ease;
  }
  
  .project-title::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--color-primary);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s ease;
  }
  
  .project-business:hover .project-title::after,
  .project-business.highlight .project-title::after {
    transform: scaleX(1);
    transform-origin: left;
  }
  
  /* Card styling */
  .project-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    background: rgba(30, 30, 30, 0.2);
    border-left: 3px solid transparent;
    border-right: 3px solid transparent;
    position: relative;
  }
  
  .project-item:nth-child(odd) .project-card {
    border-left-color: var(--color-primary);
  }
  
  .project-item:nth-child(even) .project-card {
    border-right-color: var(--color-primary);
  }
  
  .project-card-title {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  
  .project-card:hover,
  .project-card.highlight {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px -10px rgba(0, 0, 0, 0.2);
  }
  
  /* Highlight effects for linked elements */
  .project-business.highlight .project-title {
    text-shadow: 0 0 10px rgba(var(--color-primary-rgb), 0.5);
    transform: translateY(-2px);
  }
  
  .project-business.highlight .project-icon {
    transform: scale(1.05);
  }
  
  .project-icon {
    position: relative;
    transition: transform 0.3s ease;
    color: currentColor;
  }
  
  .project-icon::after {
    content: '';
    position: absolute;
    top: -5px;
    left: -5px;
    right: -5px;
    bottom: -5px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, rgba(96, 165, 250, 0.6), rgba(74, 222, 128, 0.6), rgba(96, 165, 250, 0));
    z-index: -1;
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  
  .project-icon:hover,
  .project-business.highlight .project-icon {
    transform: scale(1.05);
    color: currentColor;
  }
  
  .project-icon:hover::after,
  .project-business.highlight .project-icon::after {
    opacity: 1;
    transform: scale(1);
    animation: spin 4s linear infinite;
  }
  
  @keyframes spin {
    from {
      transform: scale(1) rotate(0deg);
    }
    to {
      transform: scale(1) rotate(360deg);
    }
  }
  
  .project-tag {
    transform: translateY(0);
    transition: transform 0.3s ease, background-color 0.3s ease;
  }
  
  .project-tag:hover {
    transform: translateY(-3px);
    background-color: rgba(96, 165, 250, 0.4);
  }
  
  .project-section {
    opacity: 0;
    transform: translateX(20px);
    border-left: 2px solid rgba(var(--color-primary-rgb), 0.3);
    padding-left: 12px;
    position: relative;
  }
  
  .project-section::before {
    content: '';
    position: absolute;
    left: -6px;
    top: 0;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-primary);
  }
  
  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color 0.3s ease;
  }
  
  .arrow-icon {
    transition: transform 0.3s ease;
    color: currentColor;
  }
  
  .project-link:hover .arrow-icon {
    transform: translateX(4px);
    color: currentColor;
  }
  
  .cta-button {
    position: relative;
    overflow: hidden;
  }
  
  .cta-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    transition: left 0.7s ease;
  }
  
  .cta-button:hover::before {
    left: 100%;
  }
</style>

<script>
  function setupProjectConnections() {
    // Define dynamic color variables
    const root = document.documentElement;
    const primaryColor = getComputedStyle(root).getPropertyValue('--color-primary').trim();
    
    // Convert hex to RGB for use in rgba values
    const hexToRgb = (hex) => {
      // Remove # if present
      hex = hex.replace('#', '');
      
      // Parse hex values
      const r = parseInt(hex.substring(0, 2), 16);
      const g = parseInt(hex.substring(2, 4), 16);
      const b = parseInt(hex.substring(4, 6), 16);
      
      // Set the RGB variable
      root.style.setProperty('--color-primary-rgb', `${r}, ${g}, ${b}`);
      
      return { r, g, b };
    };
    
    // If primary color is a hex value, convert to RGB
    if (primaryColor.startsWith('#')) {
      hexToRgb(primaryColor);
    }
    
    // Set up hover synchronization between cards and business names
    const setupHoverSync = () => {
      const projectCards = document.querySelectorAll('.project-card');
      const projectBusinesses = document.querySelectorAll('.project-business');
      
      // When hovering over a card, highlight the corresponding business name
      projectCards.forEach(card => {
        card.addEventListener('mouseenter', () => {
          const projectId = card.getAttribute('data-project-id');
          const matchingBusiness = document.querySelector(`.project-business[data-project-id="${projectId}"]`);
          if (matchingBusiness) {
            matchingBusiness.classList.add('highlight');
          }
        });
        
        card.addEventListener('mouseleave', () => {
          const projectId = card.getAttribute('data-project-id');
          const matchingBusiness = document.querySelector(`.project-business[data-project-id="${projectId}"]`);
          if (matchingBusiness) {
            matchingBusiness.classList.remove('highlight');
          }
        });
      });
      
      // When hovering over a business name, highlight the corresponding card
      projectBusinesses.forEach(business => {
        business.addEventListener('mouseenter', () => {
          const projectId = business.getAttribute('data-project-id');
          const matchingCard = document.querySelector(`.project-card[data-project-id="${projectId}"]`);
          if (matchingCard) {
            matchingCard.classList.add('highlight');
          }
        });
        
        business.addEventListener('mouseleave', () => {
          const projectId = business.getAttribute('data-project-id');
          const matchingCard = document.querySelector(`.project-card[data-project-id="${projectId}"]`);
          if (matchingCard) {
            matchingCard.classList.remove('highlight');
          }
        });
      });
    };
    
    // Initialize hover synchronization
    setupHoverSync();
  }

  function animateProjectItems() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const item = entry.target as HTMLElement;
          const index = parseInt(item.dataset.index || '0', 10);
          
          // Animate project item
          setTimeout(() => {
            item.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
            item.style.opacity = '1';
            item.style.transform = 'translateY(0)';
            
            // Animate project sections
            const sections = item.querySelectorAll('.project-section');
            sections.forEach((section, sectionIndex) => {
              setTimeout(() => {
                (section as HTMLElement).style.transition = 'opacity 0.5s ease, transform 0.5s ease';
                (section as HTMLElement).style.opacity = '1';
                (section as HTMLElement).style.transform = 'translateX(0)';
              }, 300 + (sectionIndex * 150));
            });
          }, 200 * index);
          
          observer.unobserve(item);
        }
      });
    }, { threshold: 0.1 });
    
    // Observe all project items
    document.querySelectorAll('.project-item').forEach((item) => {
      observer.observe(item);
    });
  }
  
  // Add background ripple effect to project cards
  function addCardRippleEffect() {
    // Add ripple styles
    const style = document.createElement('style');
    style.textContent = `
      .project-card {
        position: relative;
        overflow: hidden;
      }
      
      .project-card:hover,
      .project-card.highlight {
        background: rgba(40, 40, 50, 0.6);
      }
      
      .project-card:hover::after,
      .project-card.highlight::after {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 50%;
        height: 100%;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(255, 255, 255, 0.1),
          transparent
        );
        animation: shimmer 2s infinite;
      }
      
      @keyframes shimmer {
        100% {
          left: 100%;
        }
      }
    `;
    document.head.appendChild(style);
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    setupProjectConnections();
    animateProjectItems();
    addCardRippleEffect();
  });
</script>
