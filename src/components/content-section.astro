---
import { Icon } from "astro-icon/components";

interface Props {
  id: string;
  title: string;
}

const { title, id } = Astro.props;
---

<section
  id={id}
  class="flex scroll-mt-24 flex-col items-center gap-2 md:gap-4 space-y-2 md:space-y-4 py-4 md:py-6 lg:py-8 relative section-container w-full"
>
  <div class="flex flex-col items-center gap-2 md:gap-4 relative z-10 w-full">
    <slot name="eyebrow" />
    <h2 class="gradient-heading text-center text-3xl md:text-4xl lg:text-6xl">{title}</h2>
  </div>
  <p class="text-center text-offset text-sm md:text-base lg:text-xl relative z-10 max-w-xs md:max-w-2xl mx-auto">
    <slot name="lead" />
  </p>
  <slot />
</section>

<style>
  .section-container {
    position: relative;
    margin-top: 0; /* Removed negative margin */
    padding-top: 2.5rem;
    padding-bottom: 2.5rem;
    min-height: auto;
    width: 100%;
    border: none; /* Ensure no borders */
    box-shadow: none; /* Ensure no shadows */
    background: transparent; /* Make background transparent */
    overflow: hidden; /* Prevent any overflow issues */
    backdrop-filter: blur(5px); /* Subtle blur effect */
  }
  
  @media (max-width: 768px) {
    .section-container {
      padding-top: 1rem;
      padding-bottom: 1rem;
    }
    
    .gradient-heading::after {
      filter: blur(30px); /* Less blur on mobile */
      opacity: 0.1; /* Slightly reduced glow on mobile */
    }
  }
  
  /* Remove the section background styling
  .section-background::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(ellipse at center, rgba(10, 10, 30, 0.1), transparent 70%);
    pointer-events: none;
  }
  */
  
  /* Add subtle glow around headings */
  .gradient-heading {
    position: relative;
  }
  
  .gradient-heading::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    transform: translate(-50%, -50%);
    filter: blur(50px);
    opacity: 0.15;
    background: radial-gradient(ellipse at center, var(--color-primary), transparent 70%);
    z-index: -1;
    pointer-events: none;
  }
  
  /* Add a gradient overlay to each section for better transitions */
  .section-container::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, 
                rgba(10, 10, 26, 0.4) 0%, 
                rgba(6, 12, 22, 0.6) 50%,
                rgba(10, 10, 26, 0.4) 100%);
    opacity: 0.7;
    z-index: -1;
    transition: opacity 0.5s ease;
  }
</style>
