---
// TitleWord.astro - Component for individual title words with animation

interface Props {
  text: string;
  index: number;
}

const { text, index } = Astro.props;
---

<div class="title-word" data-index={index}>
  {text}
  <div class="title-shadow" data-index={index}></div>
</div>

<style>
  /* Enhanced title word styling for better visibility and impact */
  .title-word {
    /* Initial state for animation - positioned above viewport */
    opacity: 0;
    transform: translateY(-100vh) scale(1.2); /* Start off-screen above */
    will-change: transform, opacity;
    
    position: relative;
    display: block;
    pointer-events: none;
    z-index: 999;
    letter-spacing: -1px;
    margin-bottom: 5px;

    /* Enhanced gradient with more vibrant colors */
    background: linear-gradient(to bottom, #00ffaa, #8162ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-fill-color: transparent;
    filter: drop-shadow(0 0 8px rgba(129, 98, 255, 0.7)); /* Increased glow */
  }

  /* Shadow elements for added depth effect */
  .title-shadow {
    position: absolute;
    width: 100%;
    height: 15px; /* Increased size */
    background: radial-gradient(ellipse at center, rgba(0, 255, 170, 0.6) 0%, rgba(0, 0, 0, 0) 70%);
    border-radius: 50%;
    left: 0;
    bottom: -15px;
    opacity: 0;
    transform: scale(0);
    transform-origin: center;
  }

  /* Chrome-specific fixes - Extra brightness for Chrome */
  @media screen and (-webkit-min-device-pixel-ratio: 0) and (min-resolution: 0.001dpcm) {
    .title-word {
      text-shadow: 
        0 0 25px rgba(0, 255, 170, 0.9),
        0 0 50px rgba(0, 255, 170, 0.5),
        0 0 12px rgba(0, 0, 0, 0.9);
    }
  }

  /* Post-animation hover effects */
  .title-word.animation-complete:hover {
    filter: brightness(1.5) contrast(1.3);
    transform: translateY(-2px) scale(1.03) !important;
    transition: all 0.3s ease;
  }
  
  /* Mobile specific adjustments - Enhanced contrast */
  @media (max-width: 768px) {
    .title-word {
      text-shadow: 
        0 0 25px rgba(0, 255, 170, 0.9),
        0 0 50px rgba(0, 255, 170, 0.5),
        0 0 10px rgba(0, 0, 0, 0.9);
    }
  }
</style>
