---
// SplashTitle.astro - Component for the main title with consolidated animation logic
---

<div class="splash-title flex flex-col items-center gap-1 pointer-events-none mt-6 md:mt-8 px-4" style="position: relative; z-index: 999;">
  <div class="gradient-text text-center font-extrabold tracking-tighter text-5xl md:text-7xl browser-optimized-text">
    <div class="title-word title-word-create" data-index="0">Create</div>
    <div class="title-word title-word-design" data-index="1">Design</div>
    <div class="title-word title-word-build" data-index="2">Build</div>
  </div>
  <!-- Shadow elements for each word -->
  <div class="title-shadows absolute">
    <div class="title-shadow" data-index="0"></div>
    <div class="title-shadow" data-index="1"></div>
    <div class="title-shadow" data-index="2"></div>
  </div>
</div>

<style>
  /* Base styling for the container */
  .splash-title {
    position: relative;
    z-index: 999;
  }

  /* Base styling for gradient text */
  .gradient-text {
    background: linear-gradient(45deg, #8162ff, #00e599);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-fill-color: transparent;
    filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.3));
    position: relative;
    z-index: 75;
  }

  /* Title word styling with initial hidden state */
  .title-word {
    opacity: 0;
    transform: translateY(-100px) scale(1.2);
    will-change: transform, opacity;
    position: relative;
    display: block;
    pointer-events: none; 
    z-index: 999;
  }

  /* Shadow elements for added depth effect */
  .title-shadows {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    z-index: -1;
  }

  .title-shadow {
    position: absolute;
    width: 100%;
    height: 12px;
    background: radial-gradient(ellipse at center, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0) 70%);
    border-radius: 50%;
    left: 0;
    opacity: 0;
    transform: scale(0);
    transform-origin: center;
  }

  /* Position shadows beneath each word */
  .title-shadow[data-index="0"] {
    top: calc(33% - 6px);
  }
  .title-shadow[data-index="1"] {
    top: calc(66% - 6px);
  }
  .title-shadow[data-index="2"] {
    top: calc(100% - 6px);
  }

  /* Browser optimizations */
  .browser-optimized-text {
    transform: translateZ(0);
    will-change: transform, opacity;
    backface-visibility: hidden;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Mobile specific adjustments */
  @media (max-width: 768px) {
    .gradient-text {
      filter: drop-shadow(0 6px 10px rgba(0, 0, 0, 0.5));
    }
  }

  /* Animation keyframes - Ensure they end with opacity: 1 */
  @keyframes slamDown {
    0% {
      opacity: 0;
      transform: translateY(-100px) scale(1.2);
    }
    70% {
      opacity: 1;
      transform: translateY(10px) scale(0.95);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes shadowExpand {
    0% {
      opacity: 0;
      transform: scale(0);
    }
    50% {
      opacity: 1;
      transform: scale(1.5);
    }
    100% {
      opacity: 0.3;
      transform: scale(1);
    }
  }

  @keyframes shake {
    0%, 100% { 
      transform: translateY(0) translateX(0); 
      opacity: 1;
    }
    10%, 30%, 50%, 70% { 
      transform: translateY(0) translateX(-2px); 
      opacity: 1;
    }
    20%, 40%, 60% { 
      transform: translateY(0) translateX(2px); 
      opacity: 1;
    }
    80% { 
      transform: translateY(0) translateX(1px); 
      opacity: 1;
    }
    90% { 
      transform: translateY(0) translateX(-1px); 
      opacity: 1;
    }
  }

  /* Add a class for completed animations to ensure words stay visible */
  .animation-complete {
    opacity: 1 !important;
    transform: translateY(0) scale(1) !important;
  }

  /* Reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .title-word {
      opacity: 1;
      transform: none;
      animation: none;
      transition: none;
    }

    .title-shadow {
      display: none;
    }

    .gradient-text {
      animation: none;
    }
  }
</style>

<script>
  // Single source of truth for title animations
  // This function will be called after loading screen is removed
  function animateTitleWords() {
    console.log("Animating title words");
    
    // Get all title words
    const titleWords = document.querySelectorAll('.title-word');
    
    // Apply animations with staggered timing
    titleWords.forEach((word, index) => {
      const el = word as HTMLElement;
      
      // Ensure initial state
      el.style.opacity = '0';
      el.style.transform = 'translateY(-100px) scale(1.2)';
      
      // Apply the slam down animation with delay
      setTimeout(() => {
        // Apply animation
        el.style.animation = `slamDown 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.475) forwards`;
        
        // Add completed class to ensure visibility after animation
        el.classList.add('animation-complete');
        
        // Apply shake animation after slam completes
        setTimeout(() => {
          el.style.animation = `shake 0.4s cubic-bezier(0.36, 0.07, 0.19, 0.97) both`;
          
          // Force element to stay visible after shake animation
          setTimeout(() => {
            // Make absolutely sure the word stays visible
            el.style.opacity = '1';
            el.style.transform = 'translateY(0) scale(1)';
          }, 400);
        }, 500);
        
        // Animate shadow
        const shadow = document.querySelector(`.title-shadow[data-index="${index}"]`) as HTMLElement;
        if (shadow) {
          setTimeout(() => {
            shadow.style.animation = `shadowExpand 0.4s ease forwards`;
          }, 250);
        }
      }, 300 + (index * 250)); // First word starts after 300ms, then stagger by 250ms
    });
  }
  
  // Listen for custom event fired when loading screen is removed
  document.addEventListener('loadingScreenRemoved', () => {
    console.log("Loading screen removed event detected");
    animateTitleWords();
  });
  
  // Fallback in case the loading screen event doesn't fire
  document.addEventListener('DOMContentLoaded', () => {
    console.log("SplashTitle component loaded");
    
    // Check if loading screen exists
    const loadingScreen = document.getElementById('loading-overlay');
    if (!loadingScreen) {
      console.log("No loading screen found, animating title directly");
      setTimeout(animateTitleWords, 500);
    }
  });
  
  // Another fallback for window load event
  window.addEventListener('load', () => {
    console.log("Window load event in SplashTitle");
    
    // Force all title words to be visible after a safety timeout
    // This ensures they never disappear, even if animations fail
    setTimeout(() => {
      document.querySelectorAll('.title-word').forEach(word => {
        if (word instanceof HTMLElement) {
          word.style.opacity = '1';
          word.style.transform = 'translateY(0) scale(1)';
          word.classList.add('animation-complete');
        }
      });
      console.log("Safety fallback: Forced all title words to be visible");
    }, 5000);
    
    // Wait a bit longer to ensure loading screen has transitioned
    setTimeout(() => {
      const loadingScreen = document.getElementById('loading-overlay');
      if (loadingScreen && loadingScreen.style.display !== 'none') {
        console.log("Loading screen still visible, waiting for it to be removed");
      } else {
        console.log("Window loaded, loading screen gone, animating title");
        animateTitleWords();
      }
    }, 1000);
  });
</script>