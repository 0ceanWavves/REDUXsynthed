---
// SplashTitle.astro - Main container component for title section
import TitleWord from './TitleWord.astro';
import TitleImpactEffects from './TitleImpactEffects.astro';
---

<div class="splash-title flex flex-col items-center gap-1 pointer-events-none mt-6 md:mt-8 px-4" style="position: relative; z-index: 999;">
  <div class="gradient-text text-center font-extrabold tracking-tighter text-6xl md:text-8xl browser-optimized-text">
    <TitleWord text="Create" index={0} />
    <TitleWord text="Design" index={1} />
    <TitleWord text="Build" index={2} />
  </div>
  
  <!-- Impact effects container -->
  <TitleImpactEffects />
</div>

<style>
  /* Base styling for the container */
  .splash-title {
    position: relative;
    z-index: 999;
  }

  /* Enhanced gradient for better visibility */
  .gradient-text {
    position: relative;
    z-index: 999;
    line-height: 1.1;
  }

  /* Browser optimizations */
  .browser-optimized-text {
    transform: translateZ(0);
    will-change: transform, opacity;
    backface-visibility: hidden;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
</style>

<script>
  // Main controller for title animation that orchestrates the sequence
  document.addEventListener('DOMContentLoaded', () => {
    console.log("SplashTitle component loaded");
    
    // Begin animation after a short delay
    setTimeout(() => {
      // Dispatch event to trigger the animation sequence
      document.dispatchEvent(new CustomEvent('startTitleAnimation'));
    }, 300);
  });
  
  // Listen for loading screen removal (if applicable)
  document.addEventListener('loadingScreenRemoved', () => {
    console.log("Loading screen removed event detected");
    document.dispatchEvent(new CustomEvent('startTitleAnimation'));
  });
  
  // Another failsafe for animation - window load event
  window.addEventListener('load', () => {
    console.log("Window load event in SplashTitle");
    
    // Check if animation has started
    setTimeout(() => {
      const firstWord = document.querySelector('.title-word') as HTMLElement;
      if (firstWord && firstWord.style.opacity !== '1') {
        console.log("First word not animated yet, forcing animation");
        document.dispatchEvent(new CustomEvent('startTitleAnimation'));
      }
    }, 1000);
  });
</script>
