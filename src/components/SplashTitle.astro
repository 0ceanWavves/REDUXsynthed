---
// SplashTitle.astro - Component for the main title
---

<div class="splash-title flex flex-col items-center gap-1 pointer-events-none mt-6 md:mt-8 px-4" style="position: relative; z-index: 999;">
  <div class="gradient-text text-center font-extrabold tracking-tighter text-5xl md:text-7xl browser-optimized-text">
    <div class="title-word pointer-events-none">Create</div>
    <div class="title-word pointer-events-none">Design</div>
    <div class="title-word pointer-events-none">Build</div>
  </div>
  <!-- Shadow elements for each word -->
  <div class="title-shadows absolute">
    <div class="title-shadow" data-index="0"></div>
    <div class="title-shadow" data-index="1"></div>
    <div class="title-shadow" data-index="2"></div>
  </div>
</div>

<style>
  /* Add position and higher z-index */
  .splash-title {
    position: relative; /* Ensure stacking context */
    z-index: 999;     /* Bring it way above other elements */
  }

  /* Base styling for gradient text */
  .gradient-text {
    background: linear-gradient(45deg, #8162ff, #00e599);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-fill-color: transparent;
    filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.3));
    position: relative;
    z-index: 75; /* This z-index is relative to .splash-title now */
  }

  /* Shadow elements for added depth effect */
  .title-shadows {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    z-index: -1; /* Keep shadows behind text */
  }

  .title-shadow {
    position: absolute;
    width: 100%;
    height: 12px;
    background: radial-gradient(ellipse at center, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0) 70%);
    border-radius: 50%;
    left: 0;
    opacity: 0;
    transform: scale(0);
    transform-origin: center;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  /* Position shadows beneath each word */
  .title-shadow[data-index="0"] {
    top: calc(33% - 6px);
  }
  .title-shadow[data-index="1"] {
    top: calc(66% - 6px);
  }
  .title-shadow[data-index="2"] {
    top: calc(100% - 6px);
  }

  /* Browser optimizations */
  .browser-optimized-text {
    /* Force proper stacking context in all browsers */
    transform: translateZ(0);
    will-change: transform, opacity;

    /* Prevent flickering */
    backface-visibility: hidden;

    /* Improve text rendering */
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Firefox-specific optimizations - commented out properly */
  /*
  @-moz-document url-prefix() {
    .browser-optimized-text {
      transform: none !important;
      filter: none !important;
    }

    .gradient-text {
      background: linear-gradient(45deg, #8162ff, #00e599);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      color: #8162ff;
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }
  }
  */

  /* Chrome-specific fixes - commented out properly */
  /*
  @media screen and (-webkit-min-device-pixel-ratio: 0) and (min-resolution: 0.001dpcm) {
    .browser-optimized-text {
      transform: translateZ(0);
      z-index: 30 !important;
      position: relative;
    }

    .gradient-text {
      filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.5));
    }

    .title-word {
      text-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
    }
  }
  */

  /* Mobile specific adjustments */
  @media (max-width: 768px) {
    /* Brighten text for better visibility on mobile */
    .gradient-text {
      filter: drop-shadow(0 6px 10px rgba(0, 0, 0, 0.5));
    }
  }

  /* Title animation optimizations */
  .title-word {
    opacity: 0;
    will-change: opacity, transform;
    transform: translateY(-100px) scale(1.2);
    position: relative;
    display: block;
    pointer-events: none; /* Ensure this is still here if needed */
    z-index: 999;
  }

  /* Add shake animation keyframes */
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    10%, 30%, 50%, 70% { transform: translateX(-2px); }
    20%, 40%, 60% { transform: translateX(2px); }
    80% { transform: translateX(1px); }
    90% { transform: translateX(-1px); }
  }

  .shake {
    animation: shake 0.4s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
  }

  @media (prefers-reduced-motion: reduce) {
    .title-word {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }

    .title-shadow {
      display: none;
    }

    .gradient-text {
      animation: none;
    }
  }
</style>

<script>
  // Title words appearance staggered animation with slam-down effect
  function animateTitleWords() {
    if (typeof window === 'undefined') return;
    console.log("animateTitleWords: Function called");

    const titleWords = document.querySelectorAll('.title-word');
    const titleShadows = document.querySelectorAll('.title-shadow');
    console.log(`animateTitleWords: Found ${titleWords.length} title words`);

    // Reset title words to initial state to ensure animation plays
    titleWords.forEach((word, index) => {
      const el = word as HTMLElement;
      // Reset to initial state for animation
      el.style.opacity = '0';
      el.style.transform = `translateY(${-120 - (index * 20)}px) scale(${1.2 + (index * 0.1)})`;
    });

    const titleObserver = new IntersectionObserver(
      (entries) => {
        console.log("animateTitleWords: Observer triggered", entries[0].isIntersecting);
        if (entries[0].isIntersecting) {
          console.log("animateTitleWords: Element is intersecting, starting animation...");
          titleWords.forEach((word, index) => {
            const el = word as HTMLElement;
            const shadow = titleShadows[index] as HTMLElement;
            console.log(`animateTitleWords: Animating word ${index}`);
            
            // Apply the slam down effect with slight delay between words
            setTimeout(() => {
              // Apply a more dramatic "slam down" effect with bounce
              el.style.transition = 'opacity 0.3s ease, transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.475)';
              el.style.opacity = '1';
              el.style.transform = 'translateY(0) scale(1)';
              
              // Animate shadow on impact
              setTimeout(() => {
                shadow.style.opacity = '1';
                shadow.style.transform = 'scale(1.5)';
                
                // Fade out shadow after impact
                setTimeout(() => {
                  shadow.style.opacity = '0.3';
                  shadow.style.transform = 'scale(1)';
                }, 200);
              }, 450);
              
              // Add shake effect after landing
              setTimeout(() => {
                el.classList.add('shake');
                
                // Remove shake class after animation completes
                setTimeout(() => {
                  el.classList.remove('shake');
                }, 400);
              }, 500);
            }, 300 + (index * 250)); // Bigger delay between words for dramatic staggered effect
          });
          
          titleObserver.disconnect();
        }
      },
      { threshold: 0.1 }
    );

    if (titleWords.length > 0) {
      console.log("animateTitleWords: Observing the first title word");
      titleObserver.observe(titleWords[0] as HTMLElement);
    } else {
      console.error("animateTitleWords: No title words found to observe!");
    }
    
    // FALLBACK: If IntersectionObserver doesn't trigger, force the animation after a delay
    setTimeout(() => {
      if (titleWords[0] instanceof HTMLElement && titleWords[0].style.opacity === '0') {
        console.log("animateTitleWords: Fallback animation triggered");
        titleWords.forEach((word, index) => {
          const el = word as HTMLElement;
          const shadow = titleShadows[index] as HTMLElement;
          
          setTimeout(() => {
            el.style.transition = 'opacity 0.3s ease, transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.475)';
            el.style.opacity = '1';
            el.style.transform = 'translateY(0) scale(1)';
            
            setTimeout(() => {
              shadow.style.opacity = '1';
              shadow.style.transform = 'scale(1.5)';
              
              setTimeout(() => {
                shadow.style.opacity = '0.3';
                shadow.style.transform = 'scale(1)';
              }, 200);
            }, 450);
            
            setTimeout(() => {
              el.classList.add('shake');
              
              setTimeout(() => {
                el.classList.remove('shake');
              }, 400);
            }, 500);
          }, 300 + (index * 250));
        });
      }
    }, 1000);
  }

  document.addEventListener('DOMContentLoaded', () => {
    console.log("SplashTitle: DOMContentLoaded event fired");
    animateTitleWords();
  });

  // Add listener for Astro's page swaps too, just in case
  document.addEventListener('astro:page-load', () => {
    console.log("SplashTitle: astro:page-load event fired");
    animateTitleWords();
  });
  
  // Need to handle page refreshes too - run the animation after a small delay
  if (document.readyState === 'complete') {
    console.log("SplashTitle: Page already loaded, running animation directly");
    setTimeout(animateTitleWords, 500);
  }
</script>