---
// SplashTitle.astro - Component for the main title with consolidated animation logic
---

<div class="splash-title flex flex-col items-center gap-1 pointer-events-none mt-6 md:mt-8 px-4" style="position: relative; z-index: 999;">
  <div class="gradient-text text-center font-extrabold tracking-tighter text-6xl md:text-8xl browser-optimized-text">
    <div class="title-word title-word-create" data-index="0">Create</div>
    <div class="title-word title-word-design" data-index="1">Design</div>
    <div class="title-word title-word-build" data-index="2">Build</div>
  </div>
  <!-- Shadow elements for each word -->
  <div class="title-shadows absolute">
    <div class="title-shadow" data-index="0"></div>
    <div class="title-shadow" data-index="1"></div>
    <div class="title-shadow" data-index="2"></div>
  </div>
</div>

<style>
  /* Base styling for the container */
  .splash-title {
    position: relative;
    z-index: 999;
  }

  /* Enhanced gradient for better visibility */
  .gradient-text {
    position: relative;
    z-index: 999; /* Increased z-index */
    line-height: 1.1;
  }

  /* Enhanced title word styling for better visibility */
  .title-word {
    opacity: 0; /* Start hidden for animation */
    transform: translateY(-100px) scale(1.2); /* Start position for animation */
    will-change: transform, opacity;
    position: relative;
    display: block;
    pointer-events: none;
    z-index: 999;
    /* Add outline and shadow for better visibility */
    letter-spacing: -1px;
    margin-bottom: 5px;
  }

  /* Individual word styling for different gradient effects */
  .title-word-create {
    background: linear-gradient(45deg, #00ddff, #44eeff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-fill-color: transparent;
    filter: drop-shadow(0 0 8px rgba(0, 221, 255, 0.7));
  }

  .title-word-design {
    background: linear-gradient(45deg, #ffffff, #f0f0ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-fill-color: transparent;
    filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.7));
  }

  .title-word-build {
    background: linear-gradient(45deg, #8899ff, #aaeeff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-fill-color: transparent;
    filter: drop-shadow(0 0 8px rgba(136, 153, 255, 0.7));
  }

  /* Shadow elements for added depth effect */
  .title-shadows {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    z-index: -1;
  }

  .title-shadow {
    position: absolute;
    width: 100%;
    height: 12px;
    background: radial-gradient(ellipse at center, rgba(0, 221, 255, 0.4) 0%, rgba(0, 0, 0, 0) 70%);
    border-radius: 50%;
    left: 0;
    opacity: 0;
    transform: scale(0);
    transform-origin: center;
  }

  /* Position shadows beneath each word */
  .title-shadow[data-index="0"] {
    top: calc(33% - 6px);
  }
  .title-shadow[data-index="1"] {
    top: calc(66% - 6px);
  }
  .title-shadow[data-index="2"] {
    top: calc(100% - 6px);
  }

  /* Browser optimizations */
  .browser-optimized-text {
    transform: translateZ(0);
    will-change: transform, opacity;
    backface-visibility: hidden;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Mobile specific adjustments - Enhanced contrast */
  @media (max-width: 768px) {
    .title-word {
      text-shadow: 
        0 0 20px rgba(0, 221, 255, 0.9),
        0 0 40px rgba(0, 221, 255, 0.5),
        0 0 8px rgba(0, 0, 0, 0.9);
    }
  }

  /* More dramatic slam animation keyframes */
  @keyframes slamDown {
    0% {
      opacity: 0;
      transform: translateY(-160px) scale(1.5);
    }
    40% {
      opacity: 0.8;
      transform: translateY(20px) scale(0.9);
    }
    60% {
      opacity: 1;
      transform: translateY(-10px) scale(1.05);
    }
    80% {
      transform: translateY(5px) scale(0.98);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes shadowExpand {
    0% {
      opacity: 0;
      transform: scale(0);
    }
    50% {
      opacity: 1;
      transform: scale(1.5);
    }
    100% {
      opacity: 0.5;
      transform: scale(1);
    }
  }

  @keyframes shake {
    0%, 100% { 
      transform: translateY(0) translateX(0); 
      opacity: 1;
    }
    10%, 30%, 50%, 70% { 
      transform: translateY(0) translateX(-4px);
      opacity: 1;
    }
    20%, 40%, 60% { 
      transform: translateY(0) translateX(4px);
      opacity: 1;
    }
    80% { 
      transform: translateY(0) translateX(2px);
      opacity: 1;
    }
    90% { 
      transform: translateY(0) translateX(-2px);
      opacity: 1;
    }
  }

  /* Always visible class - Enhanced visibility when animation completes */
  .animation-complete {
    opacity: 1 !important;
    transform: translateY(0) scale(1) !important;
    visibility: visible !important;
    /* Keep the glow effect after animation */
    filter: brightness(1.2) contrast(1.1);
  }

  /* Chrome-specific fixes - Extra brightness for Chrome */
  @media screen and (-webkit-min-device-pixel-ratio: 0) and (min-resolution: 0.001dpcm) {
    .title-word {
      text-shadow: 
        0 0 20px rgba(0, 221, 255, 0.9),
        0 0 40px rgba(0, 221, 255, 0.5),
        0 0 10px rgba(0, 0, 0, 0.9);
    }
  }

  /* Reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .title-word {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
      transition: none !important;
    }

    .title-shadow {
      display: none;
    }

    .gradient-text {
      animation: none;
    }
  }
</style>

<script>
  // Enhanced title animation with more dramatic sequential effect
  function animateTitleWords() {
    console.log("Animating title words with sequential slam effect");
    
    // Get all title words
    const titleWords = document.querySelectorAll('.title-word');
    
    // Apply animations with more dramatic staggered timing
    titleWords.forEach((word, index) => {
      const el = word as HTMLElement;
      
      // Ensure initial state for animation
      el.style.opacity = '0';
      el.style.transform = 'translateY(-160px) scale(1.5)';
      
      // Apply the slam down animation with significant sequential delay
      // First word at 300ms, second word at 1200ms, third word at 2100ms
      setTimeout(() => {
        // Play a more dramatic slam animation
        el.style.animation = `slamDown 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.475) forwards`;
        
        // Add completed class to ensure visibility after animation
        setTimeout(() => {
          el.classList.add('animation-complete');
        }, 800); // Match animation duration
        
        // Apply shake animation after slam completes
        setTimeout(() => {
          el.style.animation = `shake 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97) both`;
          
          // Force element to stay visible after shake animation
          setTimeout(() => {
            // Make absolutely sure the word stays visible
            el.style.opacity = '1';
            el.style.transform = 'translateY(0) scale(1)';
            el.style.visibility = 'visible';
          }, 500);
        }, 800);
        
        // Animate shadow with more intensity
        const shadow = document.querySelector(`.title-shadow[data-index="${index}"]`) as HTMLElement;
        if (shadow) {
          setTimeout(() => {
            shadow.style.animation = `shadowExpand 0.5s ease forwards`;
          }, 500);
        }
      }, 300 + (index * 900)); // Much larger delay between words for dramatic effect
    });
  }
  
  // Listen for custom event fired when loading screen is removed
  document.addEventListener('loadingScreenRemoved', () => {
    console.log("Loading screen removed event detected");
    animateTitleWords();
  });
  
  // Safety function to ensure title is ALWAYS visible after animations
  function ensureTitleVisibility() {
    document.querySelectorAll('.title-word').forEach(word => {
      if (word instanceof HTMLElement) {
        word.style.opacity = '1';
        word.style.visibility = 'visible';
        word.style.transform = 'translateY(0) scale(1)';
        word.classList.add('animation-complete');
      }
    });
    console.log("Title visibility enforced");
  }
  
  // Apply the safety measure multiple times
  setTimeout(ensureTitleVisibility, 5000);
  setTimeout(ensureTitleVisibility, 8000);
  
  // Start animation immediately - More reliable approach for mobile
  document.addEventListener('DOMContentLoaded', () => {
    console.log("SplashTitle component loaded");
    
    // IMPORTANT: Always animate the title after a short delay regardless of loading screen
    setTimeout(animateTitleWords, 300);
    
    // Add specific check for loading screen presence
    const loadingScreen = document.getElementById('loading-overlay');
    if (!loadingScreen) {
      console.log("No loading screen found, animating title directly");
      animateTitleWords();
    }
  });
  
  // Another failsafe for animation
  window.addEventListener('load', () => {
    console.log("Window load event in SplashTitle");
    
    // Directly start animation
    setTimeout(animateTitleWords, 200);
    
    // Add another check for animation status
    setTimeout(() => {
      const firstWord = document.querySelector('.title-word') as HTMLElement;
      if (firstWord && firstWord.style.opacity !== '1') {
        console.log("First word not animated yet, forcing animation");
        animateTitleWords();
      }
    }, 1000);
  });
</script>