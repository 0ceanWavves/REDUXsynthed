---
// LoadingScreen.astro - A proper loading screen that appears while the page loads
---

<div id="loading-overlay" class="loading-overlay">
  <div class="loading-content">
    <div class="spinner"></div>
    <div class="loading-logo">SYNTHED</div>
    <div class="loading-message">Loading Experience...</div>
  </div>
</div>

<style>
  /* Add a class to the body when loading is active to prevent scrolling */
  :global(body.loading-active),
  :global(html.loading-active) {
    overflow: hidden !important;
    height: 100% !important;
    position: fixed !important;
    width: 100% !important;
    touch-action: none !important;
  }

  .loading-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #0a0a1a;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 10000;
    transition: opacity 0.5s ease-out, visibility 0.5s ease-out;
    /* Ensure the loading overlay prevents all interactions */
    pointer-events: all !important;
    touch-action: none !important;
  }

  .loading-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .loading-logo {
    font-size: 28px;
    font-weight: bold;
    color: white;
    letter-spacing: 2px;
    background: linear-gradient(45deg, #8162ff, #00e599);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.5));
  }

  .loading-message {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.8);
    margin-top: 10px;
    letter-spacing: 1px;
  }

  .spinner {
    width: 70px;
    height: 70px;
    border: 5px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    border-top-color: #8162ff;
    border-bottom-color: #00e599;
    border-left-color: #ff6b6b;
    border-right-color: #4deeea;
    animation: spin 1.5s ease-in-out infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Faded out state */
  .loading-overlay.hidden {
    opacity: 0;
    visibility: hidden;
  }
</style>

<script>
  // This script handles the loading screen fade-out and scroll prevention
  document.addEventListener('DOMContentLoaded', () => {
    console.log('Loading screen initialized');
    
    // Add loading-active class to body and html to prevent scrolling
    document.body.classList.add('loading-active');
    document.documentElement.classList.add('loading-active');
  });

  // Hide loading screen when everything is fully loaded
  window.addEventListener('load', () => {
    console.log('Window loaded, preparing to hide loading screen');

    // Give a slight delay to ensure everything is ready
    setTimeout(() => {
      const loadingOverlay = document.getElementById('loading-overlay');
      if (loadingOverlay) {
        loadingOverlay.classList.add('hidden');

        // Remove from DOM after transition completes
        setTimeout(() => {
          if (loadingOverlay.parentNode) {
            loadingOverlay.parentNode.removeChild(loadingOverlay);
            console.log('Loading overlay forcefully removed from DOM');
            
            // Remove loading-active class to re-enable scrolling
            document.body.classList.remove('loading-active');
            document.documentElement.classList.remove('loading-active');
          }

          // Dispatch event for components that listen for it
          document.dispatchEvent(new CustomEvent('loadingScreenRemoved'));
          console.log('Loading screen removed, event dispatched');
        }, 500); // Match transition duration
      }
    }, 2500); // Increased delay before starting fade out to 2.5 seconds
  });
</script>
