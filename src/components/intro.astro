---
import { Icon } from "astro-icon/components";
import ContentSection from "~/components/content-section.astro";
---

<ContentSection title="Innovative Technology Solutions" id="intro">
  <Icon slot="eyebrow" name="logomark" class="h-32" />
  <Fragment slot="lead">
    We transform <span class="text-primary">innovative ideas</span> into
    <span class="text-primary">powerful solutions</span>, delivering software that
    <span class="text-primary">exceeds expectations</span>.
  </Fragment>
  <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
    <a
      href="#features"
      class="flex items-center justify-center gap-3 border-2 border-current px-6 py-4"
    >
      <Icon name="mdi:code-braces" class="h-8" />
      <span>Our Services</span>
    </a>
    <a
      href="#process"
      class="flex items-center justify-center gap-3 border-2 border-current px-6 py-4"
    >
      <Icon name="mdi:timeline-check" class="h-8" />
      <span>Our Process</span>
    </a>
  </div>
</ContentSection>

<style>
  .logo-container {
    padding: 1.5rem;
    margin-bottom: 2rem;
    width: 100%;
    display: flex;
    justify-content: center;
  }
  
  .intro-icon {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 4rem;
  }
  
  .intro-icon img {
    width: 100%;
    height: auto;
    max-width: 364px;
    z-index: 2;
    filter: drop-shadow(0 0 14px rgba(59, 130, 246, 0.4));
  }
  
  /* Enhanced mobile styles */
  @media (max-width: 768px) {
    .logo-container {
      padding: 1rem;
      margin-bottom: 1.5rem;
    }
    
    .intro-icon {
      margin-bottom: 3rem;
    }
    
    .intro-icon img {
      max-width: 280px;
      filter: drop-shadow(0 0 10px rgba(59, 130, 246, 0.5));
    }
  }
  
  .highlight {
    position: relative;
    display: inline-block;
  }
  
  .highlight::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.5s ease;
  }
  
  .highlight.animated::after {
    transform: scaleX(1);
    transform-origin: left;
  }
  
  .intro-text, .intro-buttons {
    opacity: 0;
    transform: translateY(20px);
  }
  
  .intro-button {
    position: relative;
    overflow: hidden;
  }
  
  .intro-button::before {
    content: '';
    position: absolute;
    left: -100%;
    top: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: left 0.7s ease;
  }
  
  .intro-button:hover::before {
    left: 100%;
  }
  
  .feature-item {
    @apply bg-offset p-4 rounded-md border border-default w-[45%] sm:w-[22%] flex flex-col items-center;
    transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
  }
  
  .feature-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
  }
  
  @media (prefers-reduced-motion: reduce) {
    .feature-item:hover {
      transform: none;
      box-shadow: none;
    }
  }
</style>

<script>
  function animateIntroSection() {
    // Animate highlights
    const highlights = document.querySelectorAll('.highlight');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add('animated');
          }, 300);
        }
      });
    }, { threshold: 0.5 });
    
    highlights.forEach((highlight) => {
      observer.observe(highlight);
    });
    
    // Animate text and buttons
    const textObserver = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        setTimeout(() => {
          const text = document.querySelector('.intro-text');
          if (text) {
            (text as HTMLElement).style.transition = 'opacity 0.8s ease, transform 0.8s ease';
            (text as HTMLElement).style.opacity = '1';
            (text as HTMLElement).style.transform = 'translateY(0)';
          }
          
          setTimeout(() => {
            const buttons = document.querySelector('.intro-buttons');
            if (buttons) {
              (buttons as HTMLElement).style.transition = 'opacity 0.8s ease, transform 0.8s ease';
              (buttons as HTMLElement).style.opacity = '1';
              (buttons as HTMLElement).style.transform = 'translateY(0)';
            }
          }, 400);
        }, 500);
      }
    }, { threshold: 0.2 });
    
    const introSection = document.querySelector('#intro');
    if (introSection) {
      textObserver.observe(introSection);
    }
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    animateIntroSection();
  });
</script>
