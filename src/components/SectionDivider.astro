---
// SectionDivider.astro - Adds visual separation between major sections
---

<div class="section-divider">
  <div class="divider-line"></div>
  <div class="divider-accent"></div>
</div>

<style>
  .section-divider {
    position: relative;
    width: 100%;
    height: 40px;
    margin: 0; /* Removed all margins */
    pointer-events: none;
    z-index: 10;
  }

  .divider-line {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(129, 98, 255, 0.2) 20%,
      rgba(129, 98, 255, 0.5) 50%,
      rgba(129, 98, 255, 0.2) 80%,
      transparent 100%
    );
  }

  .divider-accent {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(129, 98, 255, 0.2) 0%,
      rgba(129, 98, 255, 0.1) 40%,
      transparent 70%
    );
    filter: blur(10px);
    animation: pulse 4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.7;
    }
    50% {
      transform: translate(-50%, -50%) scale(1.5);
      opacity: 0.3;
    }
  }

  @media (max-width: 768px) {
    .section-divider {
      height: 30px;
      /* margin: 2rem 0; */
    }
  }
</style>
