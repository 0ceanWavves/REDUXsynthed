/**
 * Cross-browser compatibility script for touch/pointer events
 * Ensures proper interaction on mobile and desktop browsers
 */
---

<!--- 
<script>
  // Import touch event fix functions
  import { setupCrossBrowserInteraction } from './touchEventFix.js';

  document.addEventListener('DOMContentLoaded', () => {
    // Get all interactive canvases
    const canvasElements = document.querySelectorAll('canvas');

    if (canvasElements.length > 0) {
      console.log(`CrossBrowserFix: Found ${canvasElements.length} canvas elements`);
      
      // Apply the fix to each canvas
      canvasElements.forEach((canvas, index) => {
        // Add ID if missing for easier debugging
        if (!canvas.id) {
          canvas.id = `canvas-${index}`;
        }
        
        // Skip hero canvases as they have their own interaction logic
        if (canvas.id === 'morphing-poly-canvas' || canvas.id === 'flow-bg-canvas' || canvas.id === 'splash-animation-canvas') {
          console.log(`CrossBrowserFix: Skipping setup for hero canvas ${canvas.id}`);
          return; // Skip this canvas
        }
        
        console.log(`CrossBrowserFix: Setting up for ${canvas.id}`);
        
        // Make sure pointer events are enabled
        canvas.style.pointerEvents = 'auto';
        
        // Apply the setupCrossBrowserInteraction function
        setupCrossBrowserInteraction(canvas);
      });
    } else {
      console.warn('CrossBrowserFix: No canvas elements found on page');
      
      // Wait for potential delayed canvas creation
      setTimeout(() => {
        const delayedCanvases = document.querySelectorAll('canvas');
        if (delayedCanvases.length > 0) {
          console.log(`CrossBrowserFix: Found ${delayedCanvases.length} canvas elements after delay`);
          delayedCanvases.forEach((canvas, index) => {
            if (!canvas.id) {
              canvas.id = `canvas-delayed-${index}`;
            }
            
            // Skip hero canvases as they have their own interaction logic
            if (canvas.id === 'morphing-poly-canvas' || canvas.id === 'flow-bg-canvas' || canvas.id === 'splash-animation-canvas') {
              console.log(`CrossBrowserFix: Skipping setup for hero canvas ${canvas.id} (delayed)`);
              return; // Skip this canvas
            }
            
            setupCrossBrowserInteraction(canvas);
          });
        }
      }, 1000);
    }
  });
</script>
