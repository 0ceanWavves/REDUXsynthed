---
// SplashScrollIndicator.astro - Component for the scroll down indicator
---

<!-- Scroll indicator - correctly centered -->
<div class="scroll-indicator content-item absolute left-0 right-0 mx-auto text-center flex flex-col items-center justify-center" style="bottom: 5vh; z-index: 70;" id="scroll-for-more">
  <div class="scroll-indicator-container backdrop-blur-sm bg-black/10 rounded-full px-5 py-2">
    <p class="text-white/80 text-sm mb-1">Scroll for more</p>
    <div class="animate-bounce">
      <!-- SVG Chevron Down -->
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-7 md:w-7 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>
</div>

<style>
  /* Improve scroll indicator visibility */
  .scroll-indicator {
    width: 100%;
    text-align: center;
    padding-bottom: 1rem;
    filter: drop-shadow(0 2px 10px rgba(0, 0, 0, 0.3));
    z-index: 70 !important; /* Ensure it's above the transition element */
  }
  
  .scroll-indicator-container {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
  
  .scroll-indicator p {
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
  }

  /* Mobile specific adjustments */
  @media (max-width: 768px) {
    /* Improve scroll indicator visibility */
    .scroll-indicator {
      width: 100%;
      text-align: center;
      padding-bottom: 1rem;
    }
    
    .scroll-indicator p {
      font-weight: 500;
      color: rgba(255, 255, 255, 0.9);
    }
  }

  /* Content item animation optimizations */
  .content-item {
    opacity: 0;
    will-change: opacity, transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .content-item {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Animate scroll indicator
    const contentItems = document.querySelectorAll('.content-item');
    contentItems.forEach((item, index) => {
      const el = item as HTMLElement;
      setTimeout(() => {
        el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      }, 1200 + (index * 100)); // Appear after content items
    });
  });
</script> 