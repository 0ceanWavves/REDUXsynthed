// Extract icon name without prefix (mdi:icon-name -> icon-name)
const iconName = name.includes(':') ? name.split(':')[1] : name;

// Select icon based on pack or prefix
let iconPath = '';
if (prefix === 'mdi' || pack === 'mdi') {
  iconPath = mdiIcons[iconName] || `<path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" />`; // Default house icon
} else if (prefix === 'fa-brands' || pack === 'fa-brands') {
  iconPath = faIcons[iconName] || `<circle cx="12" cy="12" r="10" />`; // Default circle
} else if (name === 'logomark') {
  // Custom logomark
  iconPath = `<path d="M7.51 0L0 13l7.51 13h15.01l7.51-13L22.52 0H7.51zm11.9 19.07H10.56l-3.9-6.78 3.9-6.75h8.85l3.9 6.75-3.9 6.78z" fill="currentColor" />`;
} else {
  // Default placeholder
  iconPath = `<rect width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" />
  <text x="12" y="14" text-anchor="middle" font-size="9" fill="currentColor">${iconName.substring(0, 2)}</text>`;
}
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={width}
  height={height}
  fill={color}
  viewBox="0 0 24 24"
  class={className}
  aria-hidden={!title}
  role={!title ? 'presentation' : 'img'}
  aria-label={title}
  set:html={iconPath}
/> 