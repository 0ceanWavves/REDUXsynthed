// Simple replacement for astro-icon that doesn't use virtual:astro-icon
// Just shows a placeholder for icons during build

export interface Props {
  name: string;
  class?: string;
  pack?: string;
  color?: string;
  size?: number;
  width?: number | string;
  height?: number | string;
  title?: string;
}

const {
  name,
  class: className = '',
  pack = '',
  color = 'currentColor',
  size,
  width = size || "1em",
  height = size || "1em",
  title
} = Astro.props;

