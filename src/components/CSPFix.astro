---
// This component addresses Content Security Policy (CSP) issues with scripts and font loading
---

<!-- Direct CSP meta tag with all necessary permissions -->
<meta http-equiv="Content-Security-Policy" content="
  default-src 'self';
  script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://unpkg.com;
  style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;
  img-src 'self' data: blob: https://*;
  font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net data:;
  connect-src 'self' https://*.jsdelivr.net https://*.unpkg.com;
  frame-src 'self';
  object-src 'none';
  base-uri 'self';
  form-action 'self';
  frame-ancestors 'self';
  media-src 'self' blob:;
  worker-src 'self' blob:;
">

<!-- Fallback meta tag for browsers that don't support CSP -->
<meta http-equiv="X-Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://unpkg.com">

<!-- Prefetch DNS for external resources to improve load times -->
<link rel="dns-prefetch" href="https://cdn.jsdelivr.net">
<link rel="dns-prefetch" href="https://unpkg.com">

